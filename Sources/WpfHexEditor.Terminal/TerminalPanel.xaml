// VS-Like Terminal panel. Toolbar (Row 0) + Output (Row 1) + Input (Row 2)
// Theme: PanelCommon.xaml DynamicResource brushes (all themes)
-->
<UserControl x:Class="WpfHexEditor.Terminal.TerminalPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WpfHexEditor.Terminal"
             Background="{DynamicResource Panel_ToolbarBrush}">

    <UserControl.Resources>
        <local:OutputKindToBrushConverter x:Key="KindToBrush"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Toolbar -->
            <RowDefinition Height="*"/>      <!-- Output -->
            <RowDefinition Height="Auto"/>   <!-- Input -->
        </Grid.RowDefinitions>

        <!-- ── Toolbar ──────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Style="{DynamicResource PanelToolbarStyle}">
            <DockPanel>
                <!-- Left: title -->
                <TextBlock Text="Terminal"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           DockPanel.Dock="Left"/>

                <!-- Right: icon buttons -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Style="{DynamicResource PanelIconButtonStyle}"
                            Command="{Binding ClearOutputCommand}"
                            ToolTip="Clear Output">
                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                    </Button>
                    <Button Style="{DynamicResource PanelIconButtonStyle}"
                            Command="{Binding CancelCommand}"
                            ToolTip="Cancel Running Command">
                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Output ───────────────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1"
                      x:Name="OutputScroll"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      Background="{DynamicResource DockBackgroundBrush}"
                      Padding="4,4,4,4">
            <ItemsControl ItemsSource="{Binding OutputLines}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Text}"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   Foreground="{Binding Kind, Converter={StaticResource KindToBrush}}"
                                   TextWrapping="Wrap"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ── Input row ────────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{DynamicResource Panel_ToolbarBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="4,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="InputBox"
                         Grid.Column="0"
                         Text="{Binding CommandInput, UpdateSourceTrigger=PropertyChanged}"
                         FontFamily="Consolas" FontSize="12"
                         Foreground="{DynamicResource DockMenuForegroundBrush}"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="2,2"
                         VerticalAlignment="Center"
                         KeyDown="OnInputKeyDown"/>

                <Button Grid.Column="1"
                        Content="Run"
                        Command="{Binding RunCommand}"
                        Padding="10,3"
                        Margin="4,0,2,0"
                        FontSize="12"
                        Foreground="{DynamicResource DockMenuForegroundBrush}"
                        Background="{DynamicResource Panel_ToolbarBrush}"
                        BorderBrush="{DynamicResource DockBorderBrush}"/>

                <Button Grid.Column="2"
                        Content="✕"
                        Command="{Binding CancelCommand}"
                        Padding="8,3"
                        Margin="0,0,2,0"
                        FontSize="12"
                        Foreground="{DynamicResource DockMenuForegroundBrush}"
                        Background="{DynamicResource Panel_ToolbarBrush}"
                        BorderBrush="{DynamicResource DockBorderBrush}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
