<!--
    Project: WpfHexEditor.Editor.DocumentEditor
    File: Options/SpellCheckerOptionsPage.xaml
    Description:
        Options page for the Document Editor spell checker.
        Shown under Tools > Options > Document Editor > Spell Checker.
        Allows enable/disable, language selection, dictionary install/remove,
        and user dictionary editing.
-->
<UserControl x:Class="WpfHexEditor.Editor.DocumentEditor.Options.SpellCheckerOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:docSvc="clr-namespace:WpfHexEditor.Editor.DocumentEditor.Services"
             Background="Transparent"
             Foreground="{DynamicResource PFP_TextBrush}"
             Padding="12">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <docSvc:DocumentEditorLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel>

        <!-- Enable toggle -->
        <CheckBox x:Name="ChkEnabled"
                  Content="{DynamicResource SpellCheck_Enable}"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  FontSize="13"
                  Margin="0,0,0,12"
                  Checked="OnEnabledChanged"
                  Unchecked="OnEnabledChanged"/>

        <!-- Section header -->
        <TextBlock Text="{DynamicResource SpellCheck_DictSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource PFP_AccentBrush}"
                   Margin="0,0,0,6"/>

        <!-- Dictionary list -->
        <Border BorderBrush="{DynamicResource PFP_BorderBrush}"
                BorderThickness="1"
                CornerRadius="2"
                Margin="0,0,0,8">
            <DataGrid x:Name="DictGrid"
                      AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      CanUserSortColumns="False"
                      GridLinesVisibility="Horizontal"
                      RowBackground="Transparent"
                      AlternatingRowBackground="Transparent"
                      Background="Transparent"
                      BorderThickness="0"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      FontSize="12"
                      MaxHeight="320"
                      SelectionMode="Single"
                      SelectionUnit="FullRow">
                <DataGrid.Columns>
                    <!-- Active radio -->
                    <DataGridTemplateColumn Width="36">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <RadioButton IsChecked="{Binding IsActive, Mode=TwoWay}"
                                             GroupName="ActiveLang"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             IsEnabled="{Binding IsInstalled}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <!-- Language name -->
                    <DataGridTextColumn Header="{DynamicResource SpellCheck_ColLanguage}"
                                        Binding="{Binding DisplayName}"
                                        Width="*"
                                        IsReadOnly="True"/>
                    <!-- Status badge -->
                    <DataGridTemplateColumn Header="{DynamicResource SpellCheck_ColStatus}" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="3"
                                        Padding="6,2"
                                        HorizontalAlignment="Left"
                                        Background="{Binding StatusColor}">
                                    <TextBlock Text="{Binding StatusText}"
                                               Foreground="White"
                                               FontSize="10"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <!-- Progress -->
                    <DataGridTemplateColumn Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ProgressBar Value="{Binding InstallProgress}"
                                             Minimum="0" Maximum="100"
                                             Height="8"
                                             Visibility="{Binding ProgressVisible}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <!-- Actions -->
                    <DataGridTemplateColumn Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,2">
                                    <!-- Download button (when not installed) -->
                                    <Button Content="{DynamicResource SpellCheck_Download}"
                                            Padding="6,2"
                                            FontSize="10"
                                            Margin="0,0,4,0"
                                            Visibility="{Binding DownloadVisible}"
                                            IsEnabled="{Binding IsNotInstalling}"
                                            Click="OnDownloadClick"/>
                                    <!-- Browse button -->
                                    <Button Content="{DynamicResource SpellCheck_Browse}"
                                            Padding="6,2"
                                            FontSize="10"
                                            Margin="0,0,4,0"
                                            Visibility="{Binding BrowseVisible}"
                                            Click="OnBrowseClick"/>
                                    <!-- Remove button (when installed) -->
                                    <Button Content="{DynamicResource SpellCheck_Remove}"
                                            Padding="6,2"
                                            FontSize="10"
                                            Visibility="{Binding RemoveVisible}"
                                            Click="OnRemoveClick"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Separator -->
        <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,8"/>

        <!-- User dictionary -->
        <TextBlock Text="{DynamicResource SpellCheck_UserDictSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource PFP_AccentBrush}"
                   Margin="0,0,0,6"/>

        <StackPanel Orientation="Horizontal">
            <TextBlock x:Name="TxtUserDictPath"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PFP_SubTextBrush}"
                       FontSize="11"
                       Margin="0,0,8,0"/>
            <Button Content="{DynamicResource SpellCheck_EditUserDict}"
                    Padding="8,3"
                    FontSize="11"
                    Click="OnEditUserDictClick"/>
        </StackPanel>

    </StackPanel>
</UserControl>
