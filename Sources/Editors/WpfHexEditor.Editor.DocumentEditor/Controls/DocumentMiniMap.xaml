<UserControl x:Class="WpfHexEditor.Editor.DocumentEditor.Controls.DocumentMiniMap"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:docSvc="clr-namespace:WpfHexEditor.Editor.DocumentEditor.Services"
             Width="80"
             Background="{DynamicResource DE_MiniMapBg}"
             Cursor="Hand">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <docSvc:DocumentEditorLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- Full-height canvas: code lines drawn top→bottom, viewport overlay on top -->
    <Grid>
        <Canvas x:Name="PART_Canvas" ClipToBounds="True"/>

        <!-- Viewport highlight rectangle (current visible area indicator) -->
        <Rectangle x:Name="PART_Viewport"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Top"
                   IsHitTestVisible="False"
                   Opacity="0.25"
                   Fill="{DynamicResource DE_SelectionBrush}"/>
    </Grid>
</UserControl>
