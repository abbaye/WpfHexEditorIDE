<UserControl x:Class="WpfHexEditor.Options.Pages.HexEditorEditingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <StackPanel Margin="0,0,0,16">

        <TextBlock Text="Editing Behavior"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,16"/>

        <!-- Mode édition par défaut -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Default edit mode:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="EditModeCombo"
                      Grid.Column="1"
                      SelectionChanged="OnComboChanged"/>
        </Grid>

        <!-- Vitesse molette -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Mouse wheel speed:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="MouseWheelCombo"
                      Grid.Column="1"
                      SelectionChanged="OnComboChanged"/>
        </Grid>

        <Separator Margin="0,8,0,16"
                   Background="{DynamicResource DockBorderBrush}"/>

        <!-- Zoom -->
        <CheckBox x:Name="CheckAllowZoom"
                  Content="Allow zoom (Ctrl + wheel)"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <!-- File drop -->
        <CheckBox x:Name="CheckAllowFileDrop"
                  Content="Allow file drop"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,0"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

    </StackPanel>
</UserControl>
