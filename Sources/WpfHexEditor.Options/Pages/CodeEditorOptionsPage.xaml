<!--
// ==========================================================
// Project: WpfHexEditor.Options
// File: CodeEditorOptionsPage.xaml
// Author: Auto
// Created: 2026-03-06
// Description:
//     Options page for the CodeEditor (full-featured, VS-like).
//     Covers: font, indentation, features (IntelliSense, line numbers,
//     zoom), .whchg changeset toggle, and syntax colour overrides.
//
// Theme: PanelCommon.xaml + DynamicResource brushes (all themes)
// ==========================================================
-->
<UserControl x:Class="WpfHexEditor.Options.Pages.CodeEditorOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <StackPanel Margin="0,0,0,16">

        <!-- ── Font ──────────────────────────────────────────────────────── -->
        <TextBlock Text="Font"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,10"/>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Font family:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="FontFamilyCombo" Grid.Column="1"
                      SelectionChanged="OnComboChanged">
                <ComboBoxItem Content="Consolas"        Tag="Consolas"/>
                <ComboBoxItem Content="Courier New"     Tag="Courier New"/>
                <ComboBoxItem Content="Lucida Console"  Tag="Lucida Console"/>
                <ComboBoxItem Content="Cascadia Code"   Tag="Cascadia Code"/>
                <ComboBoxItem Content="Fira Code"       Tag="Fira Code"/>
                <ComboBoxItem Content="JetBrains Mono"  Tag="JetBrains Mono"/>
            </ComboBox>
        </Grid>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Font size (pt):"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TxtFontSize" Grid.Column="1"
                     VerticalContentAlignment="Center"
                     LostFocus="OnTextLostFocus"/>
        </Grid>

        <Separator Margin="0,12,0,12"
                   Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Indentation ───────────────────────────────────────────────── -->
        <TextBlock Text="Indentation"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,10"/>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Indent size:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TxtIndentSize" Grid.Column="1"
                     VerticalContentAlignment="Center"
                     LostFocus="OnTextLostFocus"/>
        </Grid>

        <CheckBox x:Name="CheckUseSpaces"
                  Content="Insert spaces instead of tab characters"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <Separator Margin="0,12,0,12"
                   Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Features ──────────────────────────────────────────────────── -->
        <TextBlock Text="Features"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,10"/>

        <CheckBox x:Name="CheckIntelliSense"
                  Content="Enable IntelliSense auto-complete"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckLineNumbers"
                  Content="Show line numbers"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckHighlightLine"
                  Content="Highlight current line"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Default zoom (%):"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TxtZoom" Grid.Column="1"
                     VerticalContentAlignment="Center"
                     LostFocus="OnTextLostFocus"/>
        </Grid>

        <Separator Margin="0,12,0,12"
                   Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Changeset (.whchg) ─────────────────────────────────────────── -->
        <TextBlock Text="Changeset (.whchg)"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,10"/>

        <CheckBox x:Name="CheckChangeset"
                  Content="Track edits in .whchg companion file (requires Tracked save mode)"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <Separator Margin="0,12,0,12"
                   Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Syntax colours ────────────────────────────────────────────── -->
        <TextBlock Text="Syntax colour overrides"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,4"/>

        <TextBlock Text="Leave blank to use the active theme's default colour."
                   FontSize="11"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Opacity="0.65"
                   Margin="0,0,0,12"/>

        <!-- Background -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="110"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Background:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <Border x:Name="BgPreview" Grid.Column="1"
                    Width="16" Height="16"
                    CornerRadius="2"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource DockBorderBrush}"
                    VerticalAlignment="Center"/>
            <TextBox x:Name="TxtBgColor" Grid.Column="2"
                     VerticalContentAlignment="Center"
                     LostFocus="OnColorTextLostFocus"
                     Tag="BgPreview"/>
        </Grid>

        <!-- Foreground -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="110"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Foreground:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <Border x:Name="FgPreview" Grid.Column="1"
                    Width="16" Height="16"
                    CornerRadius="2"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource DockBorderBrush}"
                    VerticalAlignment="Center"/>
            <TextBox x:Name="TxtFgColor" Grid.Column="2"
                     VerticalContentAlignment="Center"
                     LostFocus="OnColorTextLostFocus"
                     Tag="FgPreview"/>
        </Grid>

        <!-- Keyword -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="110"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Keyword:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <Border x:Name="KwPreview" Grid.Column="1"
                    Width="16" Height="16"
                    CornerRadius="2"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource DockBorderBrush}"
                    VerticalAlignment="Center"/>
            <TextBox x:Name="TxtKwColor" Grid.Column="2"
                     VerticalContentAlignment="Center"
                     LostFocus="OnColorTextLostFocus"
                     Tag="KwPreview"/>
        </Grid>

        <!-- String -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="110"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="String:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <Border x:Name="StrPreview" Grid.Column="1"
                    Width="16" Height="16"
                    CornerRadius="2"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource DockBorderBrush}"
                    VerticalAlignment="Center"/>
            <TextBox x:Name="TxtStrColor" Grid.Column="2"
                     VerticalContentAlignment="Center"
                     LostFocus="OnColorTextLostFocus"
                     Tag="StrPreview"/>
        </Grid>

        <!-- Comment -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="110"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Comment:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <Border x:Name="CmtPreview" Grid.Column="1"
                    Width="16" Height="16"
                    CornerRadius="2"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource DockBorderBrush}"
                    VerticalAlignment="Center"/>
            <TextBox x:Name="TxtCmtColor" Grid.Column="2"
                     VerticalContentAlignment="Center"
                     LostFocus="OnColorTextLostFocus"
                     Tag="CmtPreview"/>
        </Grid>

        <!-- Number -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="110"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Number:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <Border x:Name="NumPreview" Grid.Column="1"
                    Width="16" Height="16"
                    CornerRadius="2"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource DockBorderBrush}"
                    VerticalAlignment="Center"/>
            <TextBox x:Name="TxtNumColor" Grid.Column="2"
                     VerticalContentAlignment="Center"
                     LostFocus="OnColorTextLostFocus"
                     Tag="NumPreview"/>
        </Grid>

    </StackPanel>
</UserControl>
