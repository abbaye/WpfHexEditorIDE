    WpfHexEditor.Plugins.Build.MSBuild
    ====================================
    Plugin: IBuildAdapter implementation that invokes MSBuild for
    .csproj / .vbproj compilation via Microsoft.Build.Locator.
-->

<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>false</UseWPF>
    <RootNamespace>WpfHexEditor.Plugins.Build.MSBuild</RootNamespace>
    <AssemblyName>WpfHexEditor.Plugins.Build.MSBuild</AssemblyName>
    <LangVersion>preview</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Description>WpfHexEditor plugin — MSBuild adapter for compiling .csproj / .vbproj projects.</Description>
    <Version>1.0.0</Version>

    <!-- Plugin metadata -->
    <PluginId>WpfHexEditor.Plugins.Build.MSBuild</PluginId>
    <PluginName>MSBuild Adapter</PluginName>
    <PluginVersion>1.0.0</PluginVersion>
    <PluginEntryPoint>WpfHexEditor.Plugins.Build.MSBuild.MSBuildPlugin</PluginEntryPoint>
    <PluginAuthor>Derek Tremblay</PluginAuthor>
    <PluginPublisher>WpfHexEditor</PluginPublisher>
    <PluginTrustedPublisher>true</PluginTrustedPublisher>
    <PluginDescription>MSBuild adapter that compiles Visual Studio project files (.csproj/.vbproj/.fsproj) via Microsoft.Build.Locator.</PluginDescription>
    <PluginIsolationMode>InProcess</PluginIsolationMode>
    <PluginLoadPriority>85</PluginLoadPriority>
    <PluginSdkVersion>1.2.0</PluginSdkVersion>
    <PluginMinIDEVersion>0.3.0</PluginMinIDEVersion>

    <!-- Permissions -->
    <PluginPermAccessHexEditor>false</PluginPermAccessHexEditor>
    <PluginPermAccessFileSystem>true</PluginPermAccessFileSystem>
    <PluginPermAccessNetwork>false</PluginPermAccessNetwork>
    <PluginPermRegisterMenus>false</PluginPermRegisterMenus>
    <PluginPermWriteOutput>true</PluginPermWriteOutput>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\WpfHexEditor.Editor.Core\WpfHexEditor.Editor.Core.csproj" />
    <ProjectReference Include="..\WpfHexEditor.BuildSystem\WpfHexEditor.BuildSystem.csproj" />
    <ProjectReference Include="..\WpfHexEditor.SDK\WpfHexEditor.SDK.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Microsoft.Build.Locator must be physically present in the plugin directory so the
         CLR can resolve it when the plugin is loaded in an isolated AssemblyLoadContext.
         No PrivateAssets here: the DLL must be copied to the output directory and then
         to the plugins deployment folder by CopyToPluginsDir.
         Microsoft.Build.* are compile-only references; MSBuildLocator loads them from the
         installed SDK at runtime, so their runtime assets are excluded. -->
    <PackageReference Include="Microsoft.Build.Locator"        Version="1.11.2" />
    <PackageReference Include="Microsoft.Build"                Version="18.4.0" ExcludeAssets="runtime"><PrivateAssets>all</PrivateAssets></PackageReference>
    <PackageReference Include="Microsoft.Build.Framework"      Version="18.4.0" ExcludeAssets="runtime"><PrivateAssets>all</PrivateAssets></PackageReference>
    <PackageReference Include="Microsoft.Build.Utilities.Core" Version="18.4.0" ExcludeAssets="runtime"><PrivateAssets>all</PrivateAssets></PackageReference>
  </ItemGroup>

  <Import Project="..\WpfHexEditor.SDK\Build\WpfHexEditor.SDK.targets" />

  <Target Name="CopyToPluginsDir" AfterTargets="GeneratePluginManifest">
    <PropertyGroup>
      <PluginDestDir>$(MSBuildThisFileDirectory)..\WpfHexEditor.App\bin\$(Configuration)\net8.0-windows\Plugins\$(AssemblyName)\</PluginDestDir>
    </PropertyGroup>
    <MakeDir Directories="$(PluginDestDir)" />
    <!-- Copy the plugin DLL + manifest, plus Microsoft.Build.Locator.dll which the
         MSBuildAdapter needs at runtime (loaded from the plugin's isolated directory). -->
    <Copy SourceFiles="$(OutputPath)$(AssemblyName).dll;
                       $(OutputPath)manifest.json;
                       $(OutputPath)Microsoft.Build.Locator.dll"
          DestinationFolder="$(PluginDestDir)"
          SkipUnchangedFiles="true" />
  </Target>

</Project>
