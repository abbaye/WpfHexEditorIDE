    ProjectPropertiesDocument
    =========================
    VS-Like project properties opened as a document tab in the IDE's central
    host area (not a modal dialog). Left nav + right section content.

    Theme  : DockMenuBackgroundBrush / DockMenuForegroundBrush / DockBorderBrush
    Pattern: MVVM — DataContext = ProjectPropertiesViewModel
-->

<UserControl x:Class="WpfHexEditor.ProjectSystem.Documents.ProjectPropertiesDocument"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WpfHexEditor.ProjectSystem.Documents"
             Background="{DynamicResource DockMenuBackgroundBrush}"
             Foreground="{DynamicResource DockMenuForegroundBrush}">

    <UserControl.Resources>
        <!-- ── Shared styles ──────────────────────────────────────────────── -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground"        Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground"        Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding"           Value="0,0,8,0" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background"   Value="{DynamicResource DockWindowBackgroundBrush}" />
            <Setter Property="Foreground"   Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="BorderBrush"  Value="{DynamicResource DockBorderBrush}" />
            <Setter Property="Padding"      Value="4,2" />
            <Setter Property="Margin"       Value="0,2,0,6" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background"   Value="{DynamicResource DockWindowBackgroundBrush}" />
            <Setter Property="Foreground"   Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="BorderBrush"  Value="{DynamicResource DockBorderBrush}" />
            <Setter Property="Margin"       Value="0,2,0,6" />
            <Setter Property="MinWidth"     Value="220" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground"   Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="Margin"       Value="0,2,0,6" />
        </Style>
        <Style TargetType="ListView">
            <Setter Property="Background"   Value="{DynamicResource DockWindowBackgroundBrush}" />
            <Setter Property="Foreground"   Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="BorderBrush"  Value="{DynamicResource DockBorderBrush}" />
        </Style>
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background"   Value="{DynamicResource DockMenuBackgroundBrush}" />
            <Setter Property="Foreground"   Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="BorderBrush"  Value="{DynamicResource DockBorderBrush}" />
        </Style>
        <Style TargetType="Separator">
            <Setter Property="Background"   Value="{DynamicResource DockBorderBrush}" />
            <Setter Property="Margin"       Value="0,8,0,8" />
        </Style>

        <!-- ── Nav ListBox styles ─────────────────────────────────────────── -->
        <Style x:Key="NavItemContainerStyle" TargetType="ListBoxItem">
            <Setter Property="Padding"            Value="0" />
            <Setter Property="Margin"             Value="0" />
            <Setter Property="BorderThickness"    Value="0" />
            <Setter Property="Background"         Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DockAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DockSideTabHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Root: 3 rows — title bar / main content -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- title + save button -->
            <RowDefinition Height="*" />      <!-- nav + content -->
        </Grid.RowDefinitions>

        <!-- ── Title / Save bar ──────────────────────────────────────────── -->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           x:Name="TitleText"
                           FontSize="15" FontWeight="SemiBold"
                           VerticalAlignment="Center" />

                <Button Grid.Column="1"
                        x:Name="BtnSave"
                        Content="Enregistrer"
                        Command="{Binding SaveCommand}"
                        Padding="16,5"
                        Background="{DynamicResource DockAccentBrush}"
                        Foreground="{DynamicResource DockMenuForegroundBrush}"
                        BorderBrush="{DynamicResource DockBorderBrush}" />
            </Grid>
        </Border>

        <!-- ── Main content: nav (left) + sections (right) ───────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left nav -->
            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource DockBorderBrush}"
                    BorderThickness="0,0,1,0"
                    Background="{DynamicResource DockMenuBackgroundBrush}">
                <ListBox x:Name="NavListBox"
                         ItemsSource="{Binding NavigationItems}"
                         SelectedItem="{Binding SelectedSection, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="0,8,0,8"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ItemContainerStyle="{StaticResource NavItemContainerStyle}"
                         SelectionChanged="OnNavSelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:NavItem}">
                            <TextBlock x:Name="NavLabel"
                                       Text="{Binding Label}"
                                       Padding="12,4"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}" />
                            <DataTemplate.Triggers>
                                <!-- Group headers: bolder, no indent -->
                                <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                    <Setter TargetName="NavLabel" Property="FontWeight" Value="SemiBold" />
                                    <Setter TargetName="NavLabel" Property="Padding"    Value="12,8,12,4" />
                                    <Setter TargetName="NavLabel" Property="Foreground"
                                            Value="{DynamicResource DockMenuForegroundBrush}" />
                                </DataTrigger>
                                <!-- Leaf items: indented -->
                                <DataTrigger Binding="{Binding IsHeader}" Value="False">
                                    <Setter TargetName="NavLabel" Property="Padding" Value="24,4,12,4" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- Resize grip (cosmetic) -->
            <GridSplitter Grid.Column="1" Width="1"
                          Background="{DynamicResource DockBorderBrush}"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch" />

            <!-- Right: section content swapped by code-behind -->
            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="24,20,24,20">
                <StackPanel>

                    <!-- ====================================================
                         Section: app-general  (Application > Général)
                         ==================================================== -->
                    <StackPanel x:Name="SectionAppGeneral">
                        <TextBlock Text="Application" FontSize="18" FontWeight="Bold"
                                   Margin="0,0,0,16" />

                        <TextBlock Text="Général" FontSize="13" FontWeight="SemiBold"
                                   Margin="0,0,0,10" />
                        <Separator />

                        <Label Content="Nom du projet" />
                        <TextBox Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}" />

                        <Label Content="Nom d'assembly" />
                        <TextBox Text="{Binding AssemblyName, UpdateSourceTrigger=PropertyChanged}" />

                        <Label Content="Espace de noms par défaut" />
                        <TextBox Text="{Binding DefaultNamespace, UpdateSourceTrigger=PropertyChanged}" />

                        <Label Content="Framework cible" />
                        <ComboBox x:Name="CbTargetFramework"
                                  Text="{Binding TargetFramework, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True">
                            <ComboBoxItem Content=".NET 8.0" />
                            <ComboBoxItem Content=".NET 8.0 (Windows)" />
                            <ComboBoxItem Content=".NET 9.0" />
                            <ComboBoxItem Content=".NET 9.0 (Windows)" />
                            <ComboBoxItem Content="net8.0" />
                            <ComboBoxItem Content="net8.0-windows" />
                            <ComboBoxItem Content="net9.0" />
                            <ComboBoxItem Content="net9.0-windows" />
                        </ComboBox>

                        <Label Content="Type de sortie" />
                        <ComboBox x:Name="CbOutputType"
                                  Text="{Binding OutputType, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True">
                            <ComboBoxItem Content="Bibliothèque de classes" />
                            <ComboBoxItem Content="Application console" />
                            <ComboBoxItem Content="Application Windows" />
                            <ComboBoxItem Content="Library" />
                            <ComboBoxItem Content="Exe" />
                            <ComboBoxItem Content="WinExe" />
                        </ComboBox>

                        <Label Content="Fichier projet" Margin="0,8,0,0" />
                        <TextBlock x:Name="TbFilePath"
                                   Text="{Binding ProjectFilePath}"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,0,4" />

                        <Label Content="Répertoire" />
                        <TextBlock Text="{Binding ProjectDirectory}"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,0,4" />

                        <Label Content="Type de projet" />
                        <TextBlock Text="{Binding ProjectType}" Margin="0,0,0,4" />
                    </StackPanel>

                    <!-- ====================================================
                         Section: build
                         ==================================================== -->
                    <StackPanel x:Name="SectionBuild" Visibility="Collapsed">
                        <TextBlock Text="Build" FontSize="18" FontWeight="Bold"
                                   Margin="0,0,0,16" />
                        <Separator />

                        <Label Content="Configuration" />
                        <ComboBox x:Name="CbConfig"
                                  Text="{Binding Configuration, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True">
                            <ComboBoxItem Content="Debug" />
                            <ComboBoxItem Content="Release" />
                        </ComboBox>

                        <Label Content="Plateforme" />
                        <ComboBox x:Name="CbPlatform"
                                  Text="{Binding Platform, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True">
                            <ComboBoxItem Content="Any CPU" />
                            <ComboBoxItem Content="x64" />
                            <ComboBoxItem Content="x86" />
                        </ComboBox>

                        <Label Content="Chemin de sortie" />
                        <Grid Margin="0,2,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0" />
                            <Button Grid.Column="1" Content="…"
                                    Padding="8,2" Margin="4,0,0,0"
                                    Click="OnBrowseOutputPath"
                                    Background="{DynamicResource DockMenuBackgroundBrush}"
                                    Foreground="{DynamicResource DockMenuForegroundBrush}"
                                    BorderBrush="{DynamicResource DockBorderBrush}" />
                        </Grid>

                        <CheckBox Content="Optimiser le code"
                                  IsChecked="{Binding OptimizeCode}" />
                    </StackPanel>

                    <!-- ====================================================
                         Section: app-dependencies  (Application > Dépendances)
                         ==================================================== -->
                    <StackPanel x:Name="SectionDependencies" Visibility="Collapsed">
                        <TextBlock Text="Dépendances" FontSize="18" FontWeight="Bold"
                                   Margin="0,0,0,16" />
                        <Separator />
                        <TextBlock Text="Références de projet et packages NuGet déclarés dans ce projet."
                                   TextWrapping="Wrap" Margin="0,0,0,12" Opacity="0.7" />
                        <ListView x:Name="DepsListView" MaxHeight="400">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Nom"  Width="260"
                                                    DisplayMemberBinding="{Binding Name}" />
                                    <GridViewColumn Header="Type" Width="120"
                                                    DisplayMemberBinding="{Binding RefType}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>

                    <!-- ====================================================
                         Section: items
                         ==================================================== -->
                    <StackPanel x:Name="SectionItems" Visibility="Collapsed">
                        <TextBlock Text="Éléments" FontSize="18" FontWeight="Bold"
                                   Margin="0,0,0,16" />
                        <Separator />
                        <TextBlock x:Name="ItemCountLabel" Margin="0,0,0,8" />
                        <ListView x:Name="ItemsListView" MaxHeight="500">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Nom"   Width="200"
                                                    DisplayMemberBinding="{Binding Name}" />
                                    <GridViewColumn Header="Type"  Width="100"
                                                    DisplayMemberBinding="{Binding ItemType}" />
                                    <GridViewColumn Header="Chemin" Width="300"
                                                    DisplayMemberBinding="{Binding RelativePath}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>

                    <!-- ====================================================
                         Section: references
                         ==================================================== -->
                    <StackPanel x:Name="SectionReferences" Visibility="Collapsed">
                        <TextBlock Text="Références" FontSize="18" FontWeight="Bold"
                                   Margin="0,0,0,16" />
                        <Separator />
                        <ListView x:Name="RefsListView" MaxHeight="500">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Nom"  Width="280"
                                                    DisplayMemberBinding="{Binding Name}" />
                                    <GridViewColumn Header="Type" Width="120"
                                                    DisplayMemberBinding="{Binding RefType}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>

                    <!-- ====================================================
                         Section: package  (VS only)
                         ==================================================== -->
                    <StackPanel x:Name="SectionPackage" Visibility="Collapsed">
                        <TextBlock Text="Package" FontSize="18" FontWeight="Bold"
                                   Margin="0,0,0,16" />
                        <Separator />
                        <TextBlock Text="Métadonnées NuGet générées lors de la publication du package."
                                   TextWrapping="Wrap" Margin="0,0,0,12" Opacity="0.7" />
                        <Label Content="ID du package" />
                        <TextBox x:Name="TbPackageId" />
                        <Label Content="Version du package" />
                        <TextBox x:Name="TbPackageVersion" />
                        <Label Content="Auteurs" />
                        <TextBox x:Name="TbPackageAuthors" />
                        <Label Content="Description" />
                        <TextBox x:Name="TbPackageDescription" AcceptsReturn="True" Height="60" />
                    </StackPanel>

                    <!-- ====================================================
                         Section: debug  (VS only)
                         ==================================================== -->
                    <StackPanel x:Name="SectionDebug" Visibility="Collapsed">
                        <TextBlock Text="Débogage" FontSize="18" FontWeight="Bold"
                                   Margin="0,0,0,16" />
                        <Separator />
                        <TextBlock Text="Configuration du profil de lancement pour le débogueur."
                                   TextWrapping="Wrap" Margin="0,0,0,12" Opacity="0.7" />
                        <Label Content="Arguments de ligne de commande" />
                        <TextBox x:Name="TbLaunchArgs" />
                        <Label Content="Répertoire de travail" />
                        <TextBox x:Name="TbWorkDir" />
                    </StackPanel>

                    <!-- ====================================================
                         Section: code-analysis  (VS only)
                         ==================================================== -->
                    <StackPanel x:Name="SectionCodeAnalysis" Visibility="Collapsed">
                        <TextBlock Text="Analyse du code" FontSize="18" FontWeight="Bold"
                                   Margin="0,0,0,16" />
                        <Separator />
                        <TextBlock Text="Paramètres d'analyse statique du code."
                                   TextWrapping="Wrap" Margin="0,0,0,12" Opacity="0.7" />
                        <CheckBox x:Name="CbAnalysisAll"
                                  Content="Activer l'analyse du code sur le build" />
                        <CheckBox x:Name="CbAnalysisRelease"
                                  Content="Activer uniquement sur la configuration Release"
                                  Margin="0,4,0,0" />
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>

</UserControl>
