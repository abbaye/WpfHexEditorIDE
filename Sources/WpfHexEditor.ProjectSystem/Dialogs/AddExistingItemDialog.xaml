<ec:ThemedDialog x:Class="WpfHexEditor.ProjectSystem.Dialogs.AddExistingItemDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ec="clr-namespace:WpfHexEditor.Editor.Core.Views;assembly=WpfHexEditor.Editor.Core"
        Title="Add Existing Item"
        Width="580" Height="540"
        MinWidth="480" MinHeight="460"
        ResizeMode="CanResizeWithGrip"
        AllowDrop="True"
        Drop="OnFileDrop"
        Background="{DynamicResource DockWindowBackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WpfHexEditor.ProjectSystem;component/Themes/DialogStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- HierarchicalDataTemplate for FolderNode tree -->
            <HierarchicalDataTemplate x:Key="FolderNodeTemplate"
                                      ItemsSource="{Binding Children}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE8B7;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,5,0"
                               Foreground="{DynamicResource DockMenuForegroundBrush}" />
                    <TextBlock Text="{Binding DisplayName}"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource DockMenuForegroundBrush}" />
                </StackPanel>
            </HierarchicalDataTemplate>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <!-- Row 0: File picker row -->
            <RowDefinition Height="Auto" />
            <!-- Row 1: spacing -->
            <RowDefinition Height="6" />
            <!-- Row 2: Multi-file list (collapsed when <= 1 file) -->
            <RowDefinition Height="Auto" />
            <!-- Row 3: spacing -->
            <RowDefinition Height="6" />
            <!-- Row 4: Detected type -->
            <RowDefinition Height="Auto" />
            <!-- Row 5: spacing -->
            <RowDefinition Height="10" />
            <!-- Row 6: Copy options section header -->
            <RowDefinition Height="Auto" />
            <!-- Row 7: Copy options content -->
            <RowDefinition Height="Auto" />
            <!-- Row 8: spacing -->
            <RowDefinition Height="10" />
            <!-- Row 9: Project placement section header -->
            <RowDefinition Height="Auto" />
            <!-- Row 10: Placement mode toggle -->
            <RowDefinition Height="Auto" />
            <!-- Row 11: spacing -->
            <RowDefinition Height="4" />
            <!-- Row 12: TreeView (manual) or hint (auto) — grows with window -->
            <RowDefinition Height="*" MinHeight="60" />
            <!-- Row 13: spacing -->
            <RowDefinition Height="10" />
            <!-- Row 14: Preview section header -->
            <RowDefinition Height="Auto" />
            <!-- Row 15: Preview content -->
            <RowDefinition Height="Auto" />
            <!-- Row 16: filler (collapsed — TreeView in Row 12 now takes extra space) -->
            <RowDefinition Height="Auto" />
            <!-- Row 17: buttons -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ── File picker ──────────────────────────────────────────────── -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="_File(s):" />
            <TextBox x:Name="FilePathBox" Grid.Column="1"
                     IsReadOnly="True"
                     Background="{DynamicResource DockBackgroundBrush}" />
            <Button Grid.Column="2" Content="Browse…" Margin="6,0,0,0"
                    Padding="10,5" MinWidth="70"
                    ToolTip="Select one or more files (multi-select supported). You can also drag and drop files onto this window."
                    Click="OnBrowse" />
        </Grid>

        <!-- ── Multi-file list (visible when >= 2 files selected) ───────── -->
        <Border Grid.Row="2"
                x:Name="FileListBorder"
                Visibility="Collapsed"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="1"
                CornerRadius="2"
                Background="{DynamicResource DockBackgroundBrush}"
                MaxHeight="78">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="FileList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4,2,4,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="24" />
                                </Grid.ColumnDefinitions>
                                <!-- Type icon glyph -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding IconGlyph}"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           Opacity="0.75" />
                                <!-- Filename -->
                                <TextBlock Grid.Column="1"
                                           Text="{Binding FileName}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}" />
                                <!-- Type label -->
                                <TextBlock Grid.Column="2"
                                           Text="{Binding TypeLabel}"
                                           FontSize="10"
                                           Opacity="0.65"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Margin="4,0"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}" />
                                <!-- Remove button -->
                                <Button Grid.Column="3"
                                        Content="&#xE711;"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="10"
                                        Width="20" Height="20"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        ToolTip="Remove this file from selection"
                                        Tag="{Binding}"
                                        Click="OnRemoveFileEntry"
                                        Style="{DynamicResource PanelIconButtonStyle}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ── Detected type ────────────────────────────────────────────── -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Detected type:" />
            <ComboBox x:Name="TypeCombo" Grid.Column="1"
                      MinWidth="140"
                      SelectionChanged="OnTypeChanged" />
        </Grid>

        <!-- ── Section: Copy options ─────────────────────────────────────── -->
        <Grid Grid.Row="6" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Copy options" FontWeight="SemiBold" Margin="0,0,8,0"
                       VerticalAlignment="Center" />
            <Rectangle Grid.Column="1" Height="1"
                       Fill="{DynamicResource Panel_ToolbarBorderBrush}"
                       VerticalAlignment="Center" />
        </Grid>

        <StackPanel Grid.Row="7">
            <RadioButton x:Name="KeepOriginalRadio"
                         Content="Keep original location  (reference only)"
                         GroupName="CopyMode"
                         Checked="OnCopyModeChanged"
                         Margin="0,0,0,6" />
            <RadioButton x:Name="CopyToProjectRadio"
                         Content="Copy into project"
                         GroupName="CopyMode"
                         IsChecked="True"
                         Checked="OnCopyModeChanged"
                         Margin="0,0,0,4" />
            <StackPanel x:Name="SubfolderPanel" Margin="20,0,0,0">
                <RadioButton x:Name="CopyRootRadio"
                             Content="Project root"
                             GroupName="DestMode"
                             Margin="0,0,0,4" />
                <RadioButton x:Name="CopyTypeSubfolderRadio"
                             Content="Type subfolder"
                             GroupName="DestMode"
                             IsChecked="True"
                             Checked="OnDestModeChanged"
                             Unchecked="OnDestModeChanged" />
            </StackPanel>
        </StackPanel>

        <!-- ── Section: Project placement ──────────────────────────────── -->
        <Grid Grid.Row="9" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Project placement" FontWeight="SemiBold" Margin="0,0,8,0"
                       VerticalAlignment="Center" />
            <Rectangle Grid.Column="1" Height="1"
                       Fill="{DynamicResource Panel_ToolbarBorderBrush}"
                       VerticalAlignment="Center" />
        </Grid>

        <!-- Mode toggle: Manual | Auto by type -->
        <StackPanel Grid.Row="10" Orientation="Horizontal">
            <RadioButton x:Name="ManualFolderRadio"
                         Content="Manual placement"
                         GroupName="PlacementMode"
                         IsChecked="True"
                         Checked="OnPlacementModeChanged" />
            <RadioButton x:Name="AutoFolderRadio"
                         Content="Auto by type"
                         GroupName="PlacementMode"
                         Margin="16,0,0,0"
                         Checked="OnPlacementModeChanged" />
        </StackPanel>

        <!-- TreeView (manual) / Auto hint -->
        <Grid Grid.Row="12">
            <!-- Manual mode: compact folder tree -->
            <Border x:Name="FolderTreeBorder"
                    BorderBrush="{DynamicResource DockBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="2">
                <TreeView x:Name="FolderTree"
                          Background="{DynamicResource DockBackgroundBrush}"
                          BorderThickness="0"
                          ItemTemplate="{StaticResource FolderNodeTemplate}"
                          SelectedItemChanged="OnFolderTreeSelectionChanged" />
            </Border>

            <!-- Auto mode: resolved hint -->
            <TextBlock x:Name="AutoPlacementHint"
                       Visibility="Collapsed"
                       FontStyle="Italic"
                       Opacity="0.7"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       VerticalAlignment="Center"
                       Margin="2,6" />
        </Grid>

        <!-- ── Section: Preview ──────────────────────────────────────────── -->
        <Grid Grid.Row="14" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Preview" FontWeight="SemiBold" Margin="0,0,8,0"
                       VerticalAlignment="Center" />
            <Rectangle Grid.Column="1" Height="1"
                       Fill="{DynamicResource Panel_ToolbarBorderBrush}"
                       VerticalAlignment="Center" />
        </Grid>

        <StackPanel x:Name="PreviewPanel" Grid.Row="15" Visibility="Collapsed">
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Physical: "
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           Opacity="0.7" />
                <TextBlock x:Name="PhysicalPreviewText" Grid.Column="1"
                           TextTrimming="CharacterEllipsis"
                           FontStyle="Italic"
                           Foreground="{DynamicResource DockMenuForegroundBrush}" />
            </Grid>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Virtual:    "
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           Opacity="0.7" />
                <TextBlock x:Name="VirtualPreviewText" Grid.Column="1"
                           TextTrimming="CharacterEllipsis"
                           FontStyle="Italic"
                           Foreground="{DynamicResource DockMenuForegroundBrush}" />
            </Grid>
        </StackPanel>

        <!-- ── Buttons ────────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="17" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="AddButton" Content="Add" IsDefault="True"
                    IsEnabled="False" Click="OnAdd" Margin="0,0,8,0" />
            <Button Content="Cancel" IsCancel="True" />
        </StackPanel>
    </Grid>
</ec:ThemedDialog>
