<Window x:Class="WpfHexEditor.ProjectSystem.Dialogs.ImportEmbeddedFormatDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import Built-in Format Definition"
        Width="720" Height="500"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        Background="{DynamicResource DockWindowBackgroundBrush}">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="0,0,8,0" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="Background" Value="{DynamicResource DockBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}" />
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="18,5" />
            <Setter Property="MinWidth" Value="80" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="Background" Value="{DynamicResource DockBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Filter bar -->
            <RowDefinition Height="6" />
            <RowDefinition Height="*" />     <!-- List + description -->
            <RowDefinition Height="6" />
            <RowDefinition Height="Auto" />  <!-- Folder picker -->
            <RowDefinition Height="6" />
            <RowDefinition Height="Auto" />  <!-- Status + buttons -->
        </Grid.RowDefinitions>

        <!-- ── Filter bar ──────────────────────────────────────────────── -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="_Category:" />
            <ComboBox x:Name="CategoryCombo" Grid.Column="1"
                      SelectionChanged="OnFilterChanged" />
            <Label Grid.Column="3" Content="_Search:" />
            <TextBox x:Name="SearchBox" Grid.Column="4"
                     TextChanged="OnFilterChanged" />
        </Grid>

        <!-- ── List + description ─────────────────────────────────────── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="200" />
            </Grid.ColumnDefinitions>

            <!-- Multi-select ListView -->
            <ListView x:Name="FormatList"
                      Grid.Column="0"
                      SelectionMode="Extended"
                      Background="{DynamicResource DockBackgroundBrush}"
                      BorderBrush="{DynamicResource DockBorderBrush}"
                      SelectionChanged="OnSelectionChanged">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Name"       Width="180"
                                        DisplayMemberBinding="{Binding Name}" />
                        <GridViewColumn Header="Category"   Width="100"
                                        DisplayMemberBinding="{Binding Category}" />
                        <GridViewColumn Header="Extensions" Width="100"
                                        DisplayMemberBinding="{Binding ExtensionsDisplay}" />
                        <GridViewColumn Header="Quality"    Width="60"
                                        DisplayMemberBinding="{Binding QualityScore}" />
                    </GridView>
                </ListView.View>
            </ListView>

            <!-- Description panel -->
            <Border Grid.Column="2"
                    Background="{DynamicResource DockBackgroundBrush}"
                    BorderBrush="{DynamicResource DockBorderBrush}"
                    BorderThickness="1"
                    Padding="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock x:Name="DescNameText"
                                   FontWeight="SemiBold" FontSize="13"
                                   TextWrapping="Wrap" Margin="0,0,0,4" />
                        <TextBlock x:Name="DescCategoryText"
                                   FontStyle="Italic" Opacity="0.7"
                                   Margin="0,0,0,6" />
                        <TextBlock x:Name="DescText"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ── Target folder ──────────────────────────────────────────── -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Label Content="_Destination folder:" />
            <ComboBox x:Name="FolderCombo" Grid.Column="1" />
        </Grid>

        <!-- ── Status + buttons ───────────────────────────────────────── -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="SelectionCountText"
                       VerticalAlignment="Center"
                       Opacity="0.7" />

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="ImportButton" Content="_Import" IsDefault="True"
                        IsEnabled="False" Click="OnImport" Margin="0,0,8,0" />
                <Button Content="Cancel" IsCancel="True" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
