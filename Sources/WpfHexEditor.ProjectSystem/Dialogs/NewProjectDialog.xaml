<Window x:Class="WpfHexEditor.ProjectSystem.Dialogs.NewProjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Project"
        Width="720" Height="520"
        MinWidth="580" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        Background="{DynamicResource DockWindowBackgroundBrush}">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="0,0,8,0" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="Background" Value="{DynamicResource DockBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}" />
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="18,5" />
            <Setter Property="MinWidth" Value="80" />
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Template picker -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Category filter -->
            <ListBox x:Name="CategoryList" Grid.Column="0"
                     BorderBrush="{DynamicResource DockBorderBrush}"
                     Background="{DynamicResource DockBackgroundBrush}"
                     SelectionChanged="OnCategoryChanged" />

            <!-- Template list -->
            <ListBox x:Name="TemplateList" Grid.Column="2"
                     BorderBrush="{DynamicResource DockBorderBrush}"
                     Background="{DynamicResource DockBackgroundBrush}"
                     SelectionChanged="OnTemplateSelected">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4,3">
                            <TextBlock Text="{Binding DisplayName}"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Description}"
                                       Foreground="{DynamicResource DockTabTextBrush}"
                                       TextWrapping="Wrap"
                                       FontSize="11"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- Name -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="_Name:" Target="{Binding ElementName=NameBox}" />
            <TextBox x:Name="NameBox" Grid.Column="1" TextChanged="OnNameOrLocationChanged" />
        </Grid>

        <!-- Location -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="_Location:" Target="{Binding ElementName=LocationBox}" />
            <TextBox x:Name="LocationBox" Grid.Column="1" TextChanged="OnNameOrLocationChanged" />
            <Button Grid.Column="3" Content="..." Width="30" Padding="0"
                    Click="OnBrowseLocation" ToolTip="Browse for folder" />
        </Grid>

        <!-- Preview path -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Will create:" />
            <TextBlock x:Name="PreviewText" Grid.Column="1"
                       Foreground="{DynamicResource DockTabTextBrush}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       FontStyle="Italic" />
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="OkButton" Content="OK" IsDefault="True"
                    IsEnabled="False" Click="OnOk" Margin="0,0,8,0" />
            <Button Content="Cancel" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
