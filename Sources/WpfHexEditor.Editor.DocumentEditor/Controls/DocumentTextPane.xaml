<UserControl x:Class="WpfHexEditor.Editor.DocumentEditor.Controls.DocumentTextPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource DE_TextPaneBackground}"
             Foreground="{DynamicResource DE_TextPaneForeground}">
    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Forensic gutter (16px, hidden unless forensic mode) -->
            <ColumnDefinition x:Name="PART_GutterCol" Width="0"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Forensic gutter strip -->
        <Canvas x:Name="PART_ForensicGutter"
                Grid.Column="0"
                Width="16"
                ClipToBounds="True"
                Visibility="Collapsed"/>

        <!-- FlowDocument scroll viewer -->
        <ScrollViewer Grid.Column="1"
                      x:Name="PART_ScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <RichTextBox x:Name="PART_RichTextBox"
                         Background="Transparent"
                         Foreground="{DynamicResource DE_TextPaneForeground}"
                         BorderThickness="0"
                         IsReadOnly="False"
                         AcceptsReturn="True"
                         FontFamily="Segoe UI"
                         FontSize="14"
                         SelectionChanged="OnRichTextBoxSelectionChanged"
                         TextChanged="OnRichTextBoxTextChanged">
                <RichTextBox.Resources>
                    <!-- Remove the default 5px paragraph margin -->
                    <Style TargetType="Paragraph">
                        <Setter Property="Margin" Value="0,2,0,2"/>
                    </Style>
                </RichTextBox.Resources>
            </RichTextBox>
        </ScrollViewer>
    </Grid>
</UserControl>
