<UserControl x:Class="WpfHexEditor.Editor.DocumentEditor.Controls.DocumentStructurePane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource DockBackgroundBrush}"
             Foreground="{DynamicResource DockMenuForegroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource DockBackgroundBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="6,3">
            <TextBlock Text="Structure"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource DE_StructureNodeFg}"/>
        </Border>

        <!-- Structure tree -->
        <TreeView x:Name="PART_Tree"
                  Grid.Row="1"
                  Background="Transparent"
                  BorderThickness="0"
                  SelectedItemChanged="OnTreeSelectedItemChanged">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate DataType="{x:Type local:DocumentBlockNode}"
                                          xmlns:local="clr-namespace:WpfHexEditor.Editor.DocumentEditor.Controls"
                                          ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal">
                        <!-- Forensic badge -->
                        <Border x:Name="PART_ForensicBadge"
                                Width="8" Height="8"
                                CornerRadius="4"
                                Margin="0,0,5,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding HasAlert, Converter={StaticResource BoolToVisibilityConverter}}"
                                Background="{Binding AlertBrushKey, Converter={StaticResource ResourceKeyToBrushConverter}}"
                                ToolTip="{Binding AlertMessage}"/>

                        <!-- Kind label (colored) -->
                        <TextBlock Text="{Binding KindLabel}"
                                   FontSize="11"
                                   Foreground="{DynamicResource DE_StructureKindFg}"
                                   Margin="0,0,4,0"/>

                        <!-- Text preview -->
                        <TextBlock Text="{Binding Preview}"
                                   Foreground="{DynamicResource DE_StructureNodeFg}"
                                   FontSize="12"/>

                        <!-- Offset badge -->
                        <TextBlock Text="{Binding OffsetText}"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                                   FontSize="10"
                                   Opacity="0.6"
                                   Margin="8,0,0,0"/>
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
            <TreeView.Resources>
                <Style TargetType="TreeViewItem">
                    <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource SE_HoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource DE_SelectedBlockBrush}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TreeView.Resources>
        </TreeView>
    </Grid>
</UserControl>
