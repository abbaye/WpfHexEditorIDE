<!--
    Project: WpfHexEditor.Plugins.ScreenRecorder
    File: Views/PropertiesPanel.xaml
    Description: Collapsible right panel: capture region, output scale, loop count,
                 repeat-last-frame delay, and timer interval.
-->
<UserControl x:Class="WpfHexEditor.Plugins.ScreenRecorder.Views.PropertiesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svc="clr-namespace:WpfHexEditor.Plugins.ScreenRecorder.Services"
             Background="{DynamicResource DockMenuBackgroundBrush}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <svc:ScreenRecorderLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Expander Header="{StaticResource ScreenRecorder_Properties}"
              IsExpanded="True"
              Foreground="{DynamicResource DockMenuForegroundBrush}">
        <StackPanel Margin="8,4">
            <!-- Capture Region -->
            <TextBlock Text="{StaticResource ScreenRecorder_CaptureRegion}"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       Margin="0,4,0,2"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="X:" FontSize="10"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           VerticalAlignment="Center" Margin="0,0,4,2"/>
                <TextBox   Grid.Row="0" Grid.Column="1"
                           Text="{Binding CaptureRegion.X, Mode=OneWay}"
                           IsReadOnly="True" FontSize="10" Padding="2,1" Margin="0,0,6,2"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Y:" FontSize="10"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           VerticalAlignment="Center" Margin="0,0,4,2"/>
                <TextBox   Grid.Row="0" Grid.Column="3"
                           Text="{Binding CaptureRegion.Y, Mode=OneWay}"
                           IsReadOnly="True" FontSize="10" Padding="2,1" Margin="0,0,0,2"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="W:" FontSize="10"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox   Grid.Row="1" Grid.Column="1"
                           Text="{Binding CaptureRegion.Width, Mode=OneWay}"
                           IsReadOnly="True" FontSize="10" Padding="2,1" Margin="0,0,6,0"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="H:" FontSize="10"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox   Grid.Row="1" Grid.Column="3"
                           Text="{Binding CaptureRegion.Height, Mode=OneWay}"
                           IsReadOnly="True" FontSize="10" Padding="2,1"/>
            </Grid>

            <Separator Margin="0,6"/>

            <!-- Output Scale -->
            <DockPanel Margin="0,0,0,4">
                <TextBlock DockPanel.Dock="Left"
                           Text="{StaticResource ScreenRecorder_OutputScale}"
                           FontSize="11"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>
                <TextBox DockPanel.Dock="Right" Width="50"
                         Text="{Binding OutputScale, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:P0}}"
                         FontSize="11" Padding="2,1" VerticalContentAlignment="Center"/>
            </DockPanel>

            <!-- Loop Count -->
            <DockPanel Margin="0,0,0,4">
                <TextBlock DockPanel.Dock="Left"
                           Text="{StaticResource ScreenRecorder_LoopCount}"
                           FontSize="11"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>
                <TextBox DockPanel.Dock="Right" Width="50"
                         Text="{Binding LoopCount, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="11" Padding="2,1" VerticalContentAlignment="Center"
                         ToolTip="0 = infinite loop"/>
            </DockPanel>

            <!-- Repeat Last Frame Delay -->
            <DockPanel Margin="0,0,0,4">
                <TextBlock DockPanel.Dock="Left"
                           Text="{StaticResource ScreenRecorder_RepeatLastFrame}"
                           FontSize="11"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>
                <TextBlock DockPanel.Dock="Right" Text="ms"
                           FontSize="10" Foreground="{DynamicResource DockMenuForegroundBrush}"
                           VerticalAlignment="Center" Margin="2,0,0,0"/>
                <TextBox DockPanel.Dock="Right" Width="50"
                         Text="{Binding RepeatLastFrameDelay, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="11" Padding="2,1" VerticalContentAlignment="Center"/>
            </DockPanel>

            <!-- Timer Interval -->
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="{StaticResource ScreenRecorder_Interval}"
                           FontSize="11"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>
                <TextBlock DockPanel.Dock="Right" Text="ms"
                           FontSize="10" Foreground="{DynamicResource DockMenuForegroundBrush}"
                           VerticalAlignment="Center" Margin="2,0,0,0"/>
                <TextBox DockPanel.Dock="Right" Width="50"
                         Text="{Binding TimerInterval, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="11" Padding="2,1" VerticalContentAlignment="Center"
                         ToolTip="Min 80ms"/>
            </DockPanel>
        </StackPanel>
    </Expander>
</UserControl>
