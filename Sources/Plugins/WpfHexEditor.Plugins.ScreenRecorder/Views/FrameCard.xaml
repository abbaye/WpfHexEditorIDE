<!--
    Project: WpfHexEditor.Plugins.ScreenRecorder
    File: Views/FrameCard.xaml
    Description: Single frame card in the timeline strip.
                 Shows thumbnail, frame index, delay spinbox, and selection highlight.
-->
<UserControl x:Class="WpfHexEditor.Plugins.ScreenRecorder.Views.FrameCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svc="clr-namespace:WpfHexEditor.Plugins.ScreenRecorder.Services"
             Width="100" Margin="2,4"
             Cursor="Hand">
    <UserControl.Style>
        <Style TargetType="UserControl">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DockTabActiveBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>
    <UserControl.ContextMenu>
        <!-- ContextMenu lives outside the visual tree; bind via PlacementTarget.DataContext
             which is the FrameCardViewModel. Timeline commands are delegated from there. -->
        <ContextMenu>
            <ContextMenu.Resources>
                <ResourceDictionary>
                    <ResourceDictionary.MergedDictionaries>
                        <svc:ScreenRecorderLocalizedDictionary/>
                    </ResourceDictionary.MergedDictionaries>
                </ResourceDictionary>
            </ContextMenu.Resources>
            <MenuItem Header="{StaticResource ScreenRecorder_DuplicateFrame}"
                      Command="{Binding PlacementTarget.DataContext.DuplicateCommand,
                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
            <MenuItem Header="{StaticResource ScreenRecorder_InsertBlank}"
                      Command="{Binding PlacementTarget.DataContext.InsertBlankCommand,
                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
            <Separator/>
            <MenuItem Header="{StaticResource ScreenRecorder_SetDelay}" />
            <Separator/>
            <MenuItem Header="{StaticResource ScreenRecorder_DeleteSelected}"
                      Command="{Binding PlacementTarget.DataContext.DeleteCommand,
                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
        </ContextMenu>
    </UserControl.ContextMenu>

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <svc:ScreenRecorderLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{Binding Background, RelativeSource={RelativeSource AncestorType=UserControl}}"
            BorderBrush="{DynamicResource DockBorderBrush}"
            BorderThickness="1"
            CornerRadius="4"
            Padding="4">
        <Grid>
            <StackPanel>
                <!-- Thumbnail -->
                <Border Height="64"
                        Background="{DynamicResource DockMenuBackgroundBrush}"
                        BorderBrush="{DynamicResource DockBorderBrush}"
                        BorderThickness="1">
                    <Image Source="{Binding Thumbnail}"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                </Border>

                <!-- Frame label -->
                <TextBlock Text="{Binding DisplayLabel}"
                           FontSize="10"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,3,0,0"
                           TextTrimming="CharacterEllipsis" />

                <!-- Delay spinbox -->
                <Grid Margin="0,2,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding Delay, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="10"
                             Padding="2,1"
                             VerticalContentAlignment="Center"
                             ToolTip="Frame delay (ms)" />
                    <TextBlock Grid.Column="1"
                               Text="ms"
                               FontSize="9"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                               VerticalAlignment="Center"
                               Margin="2,0,0,0" />
                </Grid>
            </StackPanel>

            <!-- Delete button — semi-transparent, visible on mouseover only -->
            <Button Command="{Binding DeleteCommand}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Width="18" Height="18"
                    Margin="0,-2,-2,0"
                    Padding="0"
                    Cursor="Arrow"
                    ToolTip="{StaticResource ScreenRecorder_DeleteSelected}"
                    Background="#AA1A1A1A"
                    BorderThickness="0"
                    Foreground="White"
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="10"
                    Content="&#xE711;">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Opacity" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="9"
                                            Width="18" Height="18">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             To="0.85" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CC333333"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Border>
</UserControl>
