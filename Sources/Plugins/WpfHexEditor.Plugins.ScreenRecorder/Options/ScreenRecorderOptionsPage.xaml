<!--
    Project: WpfHexEditor.Plugins.ScreenRecorder
    File: Options/ScreenRecorderOptionsPage.xaml
    Description: Options page UserControl for the Screen Recorder plugin.
                 Full implementation in Phase 10; stub shows category headers.
-->
<UserControl x:Class="WpfHexEditor.Plugins.ScreenRecorder.Options.ScreenRecorderOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Panel_Background}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16" >
            <TextBlock Text="{StaticResource ScreenRecorder_Options_Capture}"
                       FontWeight="SemiBold" FontSize="13"
                       Foreground="{DynamicResource Panel_Foreground}"
                       Margin="0,0,0,8" />
            <TextBlock Text="Options — full implementation in Phase 10"
                       Foreground="{DynamicResource Panel_ForegroundMuted}"
                       FontSize="11" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
