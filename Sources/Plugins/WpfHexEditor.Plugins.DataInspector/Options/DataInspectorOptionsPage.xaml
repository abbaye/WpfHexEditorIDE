    Description:
        Options page for the Data Inspector plugin.
        Displayed in the IDE Options panel under "Plugins > Data Inspector".
-->
<UserControl x:Class="WpfHexEditor.Plugins.DataInspector.Options.DataInspectorOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:diSvc="clr-namespace:WpfHexEditor.Plugins.DataInspector.Services"
             Background="Transparent"
             Foreground="{DynamicResource PFP_TextBrush}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <diSvc:DataInspectorLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,16">

        <!-- Auto-refresh -->
        <CheckBox x:Name="AutoRefreshCheckBox"
                  Content="{DynamicResource DI_AutoRefresh}"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,12"/>

        <!-- Little-endian default -->
        <CheckBox x:Name="LittleEndianCheckBox"
                  Content="{DynamicResource DI_DefaultByteOrder}"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,12"/>

        <!-- Show ByteChart -->
        <CheckBox x:Name="ShowByteChartCheckBox"
                  Content="{DynamicResource DI_ShowByteChart}"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,12"/>

        <!-- Chart position -->
        <DockPanel Margin="0,0,0,16">
            <TextBlock DockPanel.Dock="Left"
                       Text="{DynamicResource DI_ChartPosition}"
                       VerticalAlignment="Center"
                       Width="180"
                       Foreground="{DynamicResource PFP_TextBrush}"/>
            <ComboBox x:Name="ChartPositionComboBox"
                      Width="120" HorizontalAlignment="Left"
                      Background="{DynamicResource PFP_SectionBackgroundBrush}"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      BorderBrush="{DynamicResource PFP_BorderBrush}">
                <ComboBoxItem Content="{DynamicResource DI_PositionLeft}"   Tag="Left"/>
                <ComboBoxItem Content="{DynamicResource DI_PositionRight}"  Tag="Right"/>
                <ComboBoxItem Content="{DynamicResource DI_PositionTop}"    Tag="Top"/>
                <ComboBoxItem Content="{DynamicResource DI_PositionBottom}" Tag="Bottom"/>
            </ComboBox>
        </DockPanel>

        <!-- Max string bytes -->
        <DockPanel Margin="0,0,0,4" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left"
                       Text="{DynamicResource DI_MaxStringPreview}"
                       VerticalAlignment="Center"
                       Width="180"
                       Foreground="{DynamicResource PFP_TextBrush}"/>
            <Slider x:Name="MaxStringBytesSlider"
                    DockPanel.Dock="Left"
                    Minimum="8" Maximum="256" TickFrequency="8"
                    IsSnapToTickEnabled="True"
                    Width="180" VerticalAlignment="Center"/>
            <TextBlock DockPanel.Dock="Left"
                       Text="{Binding Value, ElementName=MaxStringBytesSlider, StringFormat={}{0:F0}}"
                       Margin="8,0,0,0" VerticalAlignment="Center" Width="30"
                       Foreground="{DynamicResource PFP_SubTextBrush}"/>
        </DockPanel>

        </StackPanel>
    </ScrollViewer>

</UserControl>
