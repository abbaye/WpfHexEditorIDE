<UserControl x:Class="WpfHexEditor.Plugins.ClaudeAssistant.Panel.ClaudeAssistantPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tabs="clr-namespace:WpfHexEditor.Plugins.ClaudeAssistant.Panel.Tabs"
             MinWidth="320" MinHeight="200">

    <Grid Background="{DynamicResource DockBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Tab strip -->
        <Border Grid.Row="0" Height="28" Padding="4,0"
                Background="{DynamicResource DockTabInactiveBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel VerticalAlignment="Center">
                <!-- New tab button (right side) -->
                <Border DockPanel.Dock="Right" Width="24" Height="22"
                        CornerRadius="2" Cursor="Hand" Margin="4,0,0,0"
                        ToolTip="New conversation"
                        MouseLeftButtonDown="OnNewTabClick">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource DockTabHoverBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="+" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Tab list -->
                <ItemsControl ItemsSource="{Binding Tabs}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,0" Height="28" Cursor="Hand"
                                    BorderThickness="0,2,0,0"
                                    MouseLeftButtonDown="OnTabClick">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource DockTabHoverBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <DockPanel VerticalAlignment="Center">
                                    <Border DockPanel.Dock="Right" Width="16" Height="16"
                                            CornerRadius="2" Cursor="Hand" Margin="6,0,0,0"
                                            MouseLeftButtonDown="OnCloseTabClick">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource DockTabHoverBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="x" FontSize="9"
                                                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{Binding Title}" FontSize="11"
                                               Foreground="{DynamicResource DockTabTextBrush}"
                                               TextTrimming="CharacterEllipsis" MaxWidth="120"
                                               VerticalAlignment="Center"/>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <!-- Active conversation -->
        <ContentControl Grid.Row="1" Content="{Binding ActiveTab}">
            <ContentControl.ContentTemplate>
                <DataTemplate>
                    <tabs:ConversationTab DataContext="{Binding}"/>
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>
    </Grid>
</UserControl>
