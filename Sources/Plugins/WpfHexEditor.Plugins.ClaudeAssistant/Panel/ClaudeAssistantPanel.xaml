<UserControl x:Class="WpfHexEditor.Plugins.ClaudeAssistant.Panel.ClaudeAssistantPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tabs="clr-namespace:WpfHexEditor.Plugins.ClaudeAssistant.Panel.Tabs"
             MinWidth="320" MinHeight="200">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource DockBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Tab strip -->
        <Border Grid.Row="0" Height="28" Padding="4,0"
                Background="{DynamicResource DockTabInactiveBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel VerticalAlignment="Center">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="+" Width="24" Height="22" FontSize="14" Padding="0"
                            ToolTip="New conversation"
                            Command="{Binding CreateNewTabCommand}"/>
                </StackPanel>
                <TextBlock Text="{Binding ActiveTab.Title, FallbackValue='Claude AI Assistant'}"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <!-- Active conversation -->
        <ContentControl Grid.Row="1" Content="{Binding ActiveTab}">
            <ContentControl.ContentTemplate>
                <DataTemplate>
                    <tabs:ConversationTab DataContext="{Binding}"/>
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>
    </Grid>
</UserControl>
