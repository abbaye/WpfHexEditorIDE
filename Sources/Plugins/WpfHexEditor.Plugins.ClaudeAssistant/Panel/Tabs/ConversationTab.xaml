<UserControl x:Class="WpfHexEditor.Plugins.ClaudeAssistant.Panel.Tabs.ConversationTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:msgs="clr-namespace:WpfHexEditor.Plugins.ClaudeAssistant.Panel.Messages">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource DockBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Chat messages -->
        <ScrollViewer x:Name="ChatScroller" Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Messages}" Padding="10,8">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type msgs:ChatMessageViewModel}">
                        <Border Margin="0,4" Padding="10,8" CornerRadius="6"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource DockBorderBrush}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource DockTabInactiveBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUser}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource DockTabSelectedHoverBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsError}" Value="True">
                                            <Setter Property="BorderBrush" Value="#E05252"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <!-- Role label -->
                                <TextBlock FontSize="10" FontWeight="Bold" Margin="0,0,0,4"
                                           Foreground="{DynamicResource DockTabActiveBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="assistant"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                    <Setter Property="Text" Value="you"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <!-- Message text -->
                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontSize="12.5"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                <!-- Streaming indicator -->
                                <TextBlock Text="..." FontWeight="Bold" FontSize="14"
                                           Foreground="{DynamicResource DockTabActiveBrush}"
                                           Visibility="{Binding IsStreaming, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Input bar -->
        <Border Grid.Row="1" Padding="8" BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource DockBorderBrush}"
                Background="{DynamicResource DockBackgroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         Background="{DynamicResource DockTabInactiveBrush}"
                         Foreground="{DynamicResource DockMenuForegroundBrush}"
                         CaretBrush="{DynamicResource DockMenuForegroundBrush}"
                         BorderBrush="{DynamicResource DockBorderBrush}"
                         AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="100"
                         Padding="8,6" KeyDown="OnInputKeyDown"/>

                <Border Grid.Column="1" Width="50" Height="28" CornerRadius="4"
                        Margin="6,0,0,0" Cursor="Hand" VerticalAlignment="Bottom"
                        Background="{DynamicResource DockTabActiveBrush}"
                        MouseLeftButtonDown="OnSendClick">
                    <TextBlock Text="Send" FontSize="11" FontWeight="SemiBold"
                               Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <Border Grid.Column="2" Width="40" Height="28" CornerRadius="4"
                        Margin="4,0,0,0" Cursor="Hand" VerticalAlignment="Bottom"
                        Background="#E05252"
                        Visibility="{Binding IsStreaming, Converter={StaticResource BoolToVis}}"
                        MouseLeftButtonDown="OnCancelClick">
                    <TextBlock Text="Stop" FontSize="11" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
