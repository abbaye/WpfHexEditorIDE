<UserControl x:Class="WpfHexEditor.Plugins.ClaudeAssistant.Panel.Tabs.ConversationTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:msgs="clr-namespace:WpfHexEditor.Plugins.ClaudeAssistant.Panel.Messages">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource DockBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Chat messages -->
        <ScrollViewer x:Name="ChatScroller" Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Messages}" Padding="10,8">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type msgs:ChatMessageViewModel}">
                        <Border Margin="0,3" Padding="10,8" CornerRadius="6"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource DockBorderBrush}"
                                Background="{DynamicResource DockTabInactiveBrush}">
                            <StackPanel>
                                <!-- Role label -->
                                <TextBlock FontSize="10" FontWeight="Bold" Margin="0,0,0,4"
                                           Foreground="{DynamicResource DockTabActiveBrush}"
                                           Text="{Binding Role}"/>
                                <!-- Message text -->
                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontSize="12.5"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Input bar -->
        <Border Grid.Row="1" Padding="8" BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource DockBorderBrush}"
                Background="{DynamicResource DockBackgroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         Background="{DynamicResource DockTabInactiveBrush}"
                         Foreground="{DynamicResource DockMenuForegroundBrush}"
                         CaretBrush="{DynamicResource DockMenuForegroundBrush}"
                         BorderBrush="{DynamicResource DockBorderBrush}"
                         AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="100"
                         Padding="8,6" KeyDown="OnInputKeyDown"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="6,0,0,0"
                            VerticalAlignment="Bottom">
                    <Button Content="Send" Width="60" Height="28"
                            Command="{Binding SendCommand}"/>
                    <Button Content="Stop" Width="50" Height="28" Margin="4,0,0,0"
                            Command="{Binding CancelCommand}"
                            Visibility="{Binding IsStreaming, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
