<UserControl
    x:Class="WpfHexEditor.Plugins.XamlDesigner.Panels.VisualStatePanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:WpfHexEditor.Plugins.XamlDesigner.ViewModels"
    xmlns:models="clr-namespace:WpfHexEditor.Editor.XamlDesigner.Models;assembly=WpfHexEditor.Editor.XamlDesigner"
    MinHeight="120">

    <!-- VisualStateManager Editor panel -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="28"/>  <!-- toolbar -->
            <RowDefinition Height="*"/>   <!-- content -->
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    Background="{DynamicResource DockToolBarBackgroundBrush}"
                    VerticalAlignment="Center">
            <Button Content="+ Group"  Padding="6,2" Margin="2,0"
                    Command="{Binding AddGroupCommand}"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{DynamicResource DockMenuForegroundBrush}"
                    FontSize="11" Cursor="Hand"/>
            <Button Content="- Group"  Padding="6,2" Margin="2,0"
                    Command="{Binding DeleteGroupCommand}"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{DynamicResource DockMenuForegroundBrush}"
                    FontSize="11" Cursor="Hand"/>
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,0"/>
            <Button Content="+ State"  Padding="6,2" Margin="2,0"
                    Command="{Binding AddStateCommand}"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{DynamicResource DockMenuForegroundBrush}"
                    FontSize="11" Cursor="Hand"/>
            <Button Content="- State"  Padding="6,2" Margin="2,0"
                    Command="{Binding DeleteStateCommand}"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{DynamicResource DockMenuForegroundBrush}"
                    FontSize="11" Cursor="Hand"/>
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,0"/>
            <Button Content="&#x25B6; Preview" Padding="6,2" Margin="2,0"
                    Command="{Binding PreviewStateCommand}"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{DynamicResource DockMenuForegroundBrush}"
                    FontSize="11" Cursor="Hand"/>
        </StackPanel>

        <!-- Content: 3-column layout (Groups | States | Setters) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="3"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="3"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Groups -->
            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Text="Groups"
                           FontSize="10" Foreground="{DynamicResource DockMenuForegroundBrush}"
                           Background="{DynamicResource DockToolBarBackgroundBrush}"
                           Padding="4,2"/>
                <ListBox ItemsSource="{Binding Groups}"
                         SelectedItem="{Binding SelectedGroup}"
                         Background="{DynamicResource DockBackgroundBrush}"
                         BorderThickness="0"
                         Foreground="{DynamicResource DockMenuForegroundBrush}"
                         FontSize="11">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:VisualStateGroupModel}">
                            <TextBlock Text="{Binding Name}" Padding="2,1"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="3" HorizontalAlignment="Stretch"
                          Background="{DynamicResource DockBorderBrush}"/>

            <!-- States -->
            <DockPanel Grid.Column="2">
                <TextBlock DockPanel.Dock="Top" Text="States"
                           FontSize="10" Foreground="{DynamicResource DockMenuForegroundBrush}"
                           Background="{DynamicResource DockToolBarBackgroundBrush}"
                           Padding="4,2"/>
                <ListBox ItemsSource="{Binding States}"
                         SelectedItem="{Binding SelectedState}"
                         Background="{DynamicResource DockBackgroundBrush}"
                         BorderThickness="0"
                         Foreground="{DynamicResource DockMenuForegroundBrush}"
                         FontSize="11">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:VisualStateEntryModel}">
                            <TextBlock Text="{Binding Name}" Padding="2,1"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <GridSplitter Grid.Column="3" Width="3" HorizontalAlignment="Stretch"
                          Background="{DynamicResource DockBorderBrush}"/>

            <!-- Setters -->
            <DockPanel Grid.Column="4">
                <TextBlock DockPanel.Dock="Top" Text="Setters"
                           FontSize="10" Foreground="{DynamicResource DockMenuForegroundBrush}"
                           Background="{DynamicResource DockToolBarBackgroundBrush}"
                           Padding="4,2"/>
                <ListBox ItemsSource="{Binding Setters}"
                         Background="{DynamicResource DockBackgroundBrush}"
                         BorderThickness="0"
                         Foreground="{DynamicResource DockMenuForegroundBrush}"
                         FontSize="11">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:VisualStateSetterModel}">
                            <TextBlock FontSize="10" Padding="2,1">
                                <Run Text="{Binding TargetName}"/>
                                <Run Text="."/>
                                <Run Text="{Binding PropertyName}"/>
                                <Run Text=" = "/>
                                <Run Text="{Binding Value}"/>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Grid>
    </Grid>
</UserControl>
