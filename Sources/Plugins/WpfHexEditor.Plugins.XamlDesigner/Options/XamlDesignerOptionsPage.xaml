<!--
    Project: WpfHexEditor.Plugins.XamlDesigner
    File: Options/XamlDesignerOptionsPage.xaml
    Author: Derek Tremblay
    Created: 2026-03-16
    Description:
        Options page for the XAML Designer plugin.
        Shown in IDE Options > Plugins > XAML Designer
        and in Plugin Manager "Settings" tab.
        Theme: DynamicResource PFP_* tokens.
-->
<UserControl x:Class="WpfHexEditor.Plugins.XamlDesigner.Options.XamlDesignerOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Foreground="{DynamicResource PFP_TextBrush}"
             Padding="12"
             xmlns:xdSvc="clr-namespace:WpfHexEditor.Plugins.XamlDesigner.Services">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <xdSvc:XamlDesignerLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>

        <!-- Section: Preview -->
        <TextBlock Text="{DynamicResource XamlDesigner_LivePreview}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource PFP_AccentBrush}"
                   Margin="0,0,0,6"/>

        <CheckBox x:Name="ChkAutoPreview" Content="{DynamicResource XamlDesigner_EnableLivePreview}"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,4"/>

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{DynamicResource XamlDesigner_PreviewDelay}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PFP_TextBrush}"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Slider x:Name="PreviewDelaySlider"
                        Minimum="100" Maximum="2000" TickFrequency="100"
                        IsSnapToTickEnabled="True"
                        Width="140"
                        VerticalAlignment="Center"
                        ValueChanged="OnPreviewDelayChanged"/>
                <TextBlock x:Name="PreviewDelayLabel"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PFP_SubTextBrush}"
                           FontSize="11"/>
            </StackPanel>
        </Grid>

        <!-- Separator -->
        <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,8"/>

        <!-- Section: Designer -->
        <TextBlock Text="{DynamicResource XamlDesigner_DesignerSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource PFP_AccentBrush}"
                   Margin="0,0,0,6"/>

        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{DynamicResource XamlDesigner_DefaultViewMode}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PFP_TextBrush}"/>
            <ComboBox x:Name="ViewModeCombo"
                      Grid.Column="1"
                      Width="160"
                      HorizontalAlignment="Left"
                      Background="{DynamicResource PFP_SectionBackgroundBrush}"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      BorderBrush="{DynamicResource PFP_BorderBrush}">
                <ComboBoxItem Content="{DynamicResource XamlDesigner_SplitView}" Tag="Split" IsSelected="True"/>
                <ComboBoxItem Content="{DynamicResource XamlDesigner_CodeOnly}"             Tag="CodeOnly"/>
                <ComboBoxItem Content="{DynamicResource XamlDesigner_DesignOnly}"           Tag="DesignOnly"/>
            </ComboBox>
        </Grid>

        <CheckBox x:Name="ChkSnapToGrid" Content="{DynamicResource XamlDesigner_SnapToGrid}"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,4"/>

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{DynamicResource XamlDesigner_GridSnapSize}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PFP_TextBrush}"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <TextBox x:Name="TxtSnapSize"
                         Width="50"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Center"
                         Background="{DynamicResource PFP_SectionBackgroundBrush}"
                         Foreground="{DynamicResource PFP_TextBrush}"
                         BorderBrush="{DynamicResource PFP_BorderBrush}"
                         CaretBrush="{DynamicResource PFP_TextBrush}"
                         Padding="4,2"
                         FontSize="12"
                         MaxLength="3"
                         TextAlignment="Right"/>
                <TextBlock Text="px"
                           Margin="6,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PFP_SubTextBrush}"
                           FontSize="11"/>
            </StackPanel>
        </Grid>

        <!-- Separator -->
        <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,8"/>

        <!-- Section: Property Inspector -->
        <TextBlock Text="{DynamicResource XamlDesigner_PropertyInspectorSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource PFP_AccentBrush}"
                   Margin="0,0,0,6"/>

        <CheckBox x:Name="ChkShowDefaultProps" Content="{DynamicResource XamlDesigner_ShowDefaultValues}"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,4"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
