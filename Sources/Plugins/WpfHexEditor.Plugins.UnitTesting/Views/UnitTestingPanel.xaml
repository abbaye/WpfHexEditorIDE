<UserControl x:Class="WpfHexEditor.Plugins.UnitTesting.Views.UnitTestingPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfHexEditor.Plugins.UnitTesting.ViewModels">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Outcome glyph base style -->
        <Style x:Key="OutcomeGlyphStyle" TargetType="TextBlock">
            <Setter Property="FontFamily"        Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize"          Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="4,0,6,0"/>
        </Style>

        <!-- Counter label style (small, bold) -->
        <Style x:Key="CounterValueStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize"          Value="11"/>
            <Setter Property="FontWeight"        Value="SemiBold"/>
            <Setter Property="Margin"            Value="1,0,8,0"/>
        </Style>

        <DataTemplate x:Key="TestResultTemplate" DataType="{x:Type vm:TestResultRow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>

                <!-- Outcome glyph -->
                <TextBlock Grid.Column="0" Text="{Binding OutcomeGlyph}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource OutcomeGlyphStyle}">
                            <Setter Property="Foreground" Value="{DynamicResource UT_SkipForegroundBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Outcome}" Value="Passed">
                                    <Setter Property="Foreground" Value="{DynamicResource UT_PassForegroundBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Outcome}" Value="Failed">
                                    <Setter Property="Foreground" Value="{DynamicResource UT_FailForegroundBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Test name -->
                <TextBlock Grid.Column="1" Text="{Binding Display}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           FontFamily="Cascadia Mono, Consolas, monospace"
                           FontSize="12">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource DockWindowForegroundBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Outcome}" Value="Failed">
                                    <Setter Property="Foreground" Value="{DynamicResource UT_FailForegroundBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Duration (ms) — only for real test results, not output lines -->
                <TextBlock Grid.Column="2" VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="0,0,6,0"
                           FontSize="11"
                           Opacity="0.65"
                           Foreground="{DynamicResource DockWindowForegroundBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value=""/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsOutput}" Value="False">
                                    <Setter Property="Text" Value="{Binding DurationMs, StringFormat='{}{0} ms'}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <DockPanel Background="{DynamicResource DockWindowBackgroundBrush}">

        <!-- Toolbar -->
        <ToolBar DockPanel.Dock="Top"
                 Background="{DynamicResource UT_ToolbarBackgroundBrush}"
                 ToolBarTray.IsLocked="True">
            <Button x:Name="RunButton" ToolTip="Run All Tests (Ctrl+R)"
                    Padding="8,3" Margin="0,0,3,0"
                    Click="OnRunAllClicked">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets"
                               FontSize="13" Margin="0,0,4,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Run All" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button x:Name="StopButton" ToolTip="Stop Tests"
                    Padding="8,3" Margin="0,0,3,0"
                    IsEnabled="False"
                    Click="OnStopClicked">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets"
                               FontSize="13" Margin="0,0,4,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Stop" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button ToolTip="Clear Results"
                    Padding="8,3" Margin="0,0,3,0"
                    Click="OnClearClicked">
                <TextBlock Text="&#xE894;" FontFamily="Segoe MDL2 Assets"
                           FontSize="13" VerticalAlignment="Center"/>
            </Button>
            <Separator/>
            <!-- Pass counter -->
            <StackPanel Orientation="Horizontal" Margin="4,0,0,0">
                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Text="&#xE930;"
                           VerticalAlignment="Center" Margin="0,0,2,0"
                           Foreground="{DynamicResource UT_PassForegroundBrush}"/>
                <TextBlock Style="{StaticResource CounterValueStyle}"
                           Foreground="{DynamicResource UT_PassForegroundBrush}"
                           Text="{Binding PassCount}"/>
            </StackPanel>
            <!-- Fail counter -->
            <StackPanel Orientation="Horizontal">
                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Text="&#xEB90;"
                           VerticalAlignment="Center" Margin="0,0,2,0"
                           Foreground="{DynamicResource UT_FailForegroundBrush}"/>
                <TextBlock Style="{StaticResource CounterValueStyle}"
                           Foreground="{DynamicResource UT_FailForegroundBrush}"
                           Text="{Binding FailCount}"/>
            </StackPanel>
            <!-- Skip counter -->
            <StackPanel Orientation="Horizontal">
                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Text="&#xE89A;"
                           VerticalAlignment="Center" Margin="0,0,2,0"
                           Foreground="{DynamicResource UT_SkipForegroundBrush}"/>
                <TextBlock Style="{StaticResource CounterValueStyle}"
                           Foreground="{DynamicResource UT_SkipForegroundBrush}"
                           Text="{Binding SkipCount}"/>
            </StackPanel>
        </ToolBar>

        <!-- Progress indicator (2px, visible only while running) -->
        <ProgressBar DockPanel.Dock="Top"
                     Height="2"
                     IsIndeterminate="True"
                     Foreground="{DynamicResource UT_PassForegroundBrush}"
                     Background="Transparent"
                     BorderThickness="0"
                     Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"/>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource UT_StatusBarBackgroundBrush}"
                BorderBrush="{DynamicResource DockSplitterBrush}"
                BorderThickness="0,1,0,0"
                Padding="6,3">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{DynamicResource DockWindowForegroundBrush}"
                       FontSize="11" Opacity="0.75"
                       TextTrimming="CharacterEllipsis"/>
        </Border>

        <!-- Results list -->
        <ListView x:Name="ResultsList"
                  ItemsSource="{Binding Results}"
                  ItemTemplate="{StaticResource TestResultTemplate}"
                  Background="Transparent"
                  BorderThickness="0"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  SelectionMode="Single"
                  SelectionChanged="OnResultSelectionChanged">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding"                    Value="2,1"/>
                    <Setter Property="Background"                 Value="Transparent"/>
                    <Setter Property="BorderThickness"            Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Outcome}" Value="Failed">
                            <Setter Property="Background" Value="{DynamicResource UT_FailRowBackgroundBrush}"/>
                        </DataTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource UT_HoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource UT_SelectionBrush}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>
    </DockPanel>
</UserControl>
