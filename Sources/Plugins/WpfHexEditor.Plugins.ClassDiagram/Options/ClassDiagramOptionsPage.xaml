<!--
    Project: WpfHexEditor.Plugins.ClassDiagram
    File: Options/ClassDiagramOptionsPage.xaml
    Author: Derek Tremblay (derektremblay666@gmail.com)
    Contributors: Claude Sonnet 4.6
    Created: 2026-03-19
    Description:
        Options page for the Class Diagram plugin.
        Shown in IDE Options > Plugins > Class Diagram
        and in Plugin Manager "Settings" tab.
        Theme: DynamicResource PFP_* tokens — consistent with all other
        plugin options pages (XamlDesigner, AssemblyExplorer, etc.).
-->
<UserControl x:Class="WpfHexEditor.Plugins.ClassDiagram.Options.ClassDiagramOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Foreground="{DynamicResource PFP_TextBrush}"
             Padding="12"
             xmlns:cdSvc="clr-namespace:WpfHexEditor.Plugins.ClassDiagram.Services;assembly=WpfHexEditor.Plugins.ClassDiagram">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <xmlns:cdSvc:ClassDiagramLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <!-- ── Section: Layout ──────────────────────────────────────────── -->
            <TextBlock {DynamicResource ClassDiagram_LayoutSection}
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource PFP_AccentBrush}"
                       Margin="0,0,0,6"/>

            <CheckBox x:Name="ChkAutoLayout"
                      {DynamicResource ClassDiagram_AutoLayout}
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,4"/>

            <CheckBox x:Name="ChkGroupByNamespace"
                      {DynamicResource ClassDiagram_GroupByNamespace}
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,4"/>

            <!-- Default node width -->
            <Grid Margin="0,4,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" {DynamicResource ClassDiagram_DefaultNodeWidth}
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PFP_TextBrush}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBox x:Name="TxtNodeWidth"
                             Width="60"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Center"
                             Background="{DynamicResource PFP_SectionBackgroundBrush}"
                             Foreground="{DynamicResource PFP_TextBrush}"
                             BorderBrush="{DynamicResource PFP_BorderBrush}"
                             CaretBrush="{DynamicResource PFP_TextBrush}"
                             Padding="4,2"
                             FontSize="12"
                             MaxLength="5"
                             TextAlignment="Right"/>
                    <TextBlock Text="px"
                               Margin="6,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PFP_SubTextBrush}"
                               FontSize="11"/>
                </StackPanel>
            </Grid>

            <!-- Default node height -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" {DynamicResource ClassDiagram_DefaultNodeHeight}
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PFP_TextBrush}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBox x:Name="TxtNodeHeight"
                             Width="60"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Center"
                             Background="{DynamicResource PFP_SectionBackgroundBrush}"
                             Foreground="{DynamicResource PFP_TextBrush}"
                             BorderBrush="{DynamicResource PFP_BorderBrush}"
                             CaretBrush="{DynamicResource PFP_TextBrush}"
                             Padding="4,2"
                             FontSize="12"
                             MaxLength="5"
                             TextAlignment="Right"/>
                    <TextBlock Text="px"
                               Margin="6,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PFP_SubTextBrush}"
                               FontSize="11"/>
                </StackPanel>
            </Grid>

            <!-- ── Separator ─────────────────────────────────────────────── -->
            <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,8"/>

            <!-- ── Section: Canvas ───────────────────────────────────────── -->
            <TextBlock {DynamicResource ClassDiagram_CanvasSection}
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource PFP_AccentBrush}"
                       Margin="0,0,0,6"/>

            <CheckBox x:Name="ChkShowGrid"
                      {DynamicResource ClassDiagram_ShowDotGrid}
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,4"/>

            <CheckBox x:Name="ChkSnapEnabled"
                      {DynamicResource ClassDiagram_SnapToGrid}
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,4"/>

            <!-- Snap size -->
            <Grid Margin="0,4,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" {DynamicResource ClassDiagram_GridSnapSize}
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PFP_TextBrush}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Slider x:Name="SnapSizeSlider"
                            Minimum="1" Maximum="64" TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            Width="140"
                            VerticalAlignment="Center"
                            ValueChanged="OnSnapSizeChanged"/>
                    <TextBlock x:Name="SnapSizeLabel"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PFP_SubTextBrush}"
                               FontSize="11"/>
                </StackPanel>
            </Grid>

            <!-- ── Separator ─────────────────────────────────────────────── -->
            <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,8"/>

            <!-- ── Section: Source Analysis ──────────────────────────────── -->
            <TextBlock {DynamicResource ClassDiagram_SourceAnalysis}
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource PFP_AccentBrush}"
                       Margin="0,0,0,6"/>

            <TextBlock TextWrapping="Wrap"
                       Foreground="{DynamicResource PFP_SubTextBrush}"
                       FontSize="11"
                       Margin="0,0,0,8">
                Controls how C# source files are parsed when using
                "View Class Diagram" or "Generate Class Diagram for Project"
                from Solution Explorer.
            </TextBlock>

            <CheckBox x:Name="ChkIncludePrivate"
                      {DynamicResource ClassDiagram_IncludePrivate}
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,4"/>

            <CheckBox x:Name="ChkIncludeInherited"
                      {DynamicResource ClassDiagram_IncludeInherited}
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,12"/>

            <!-- ── Separator ─────────────────────────────────────────────── -->
            <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,8"/>

            <!-- ── Section: Minimap ──────────────────────────────────────── -->
            <TextBlock {DynamicResource ClassDiagram_MinimapSection}
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource PFP_AccentBrush}"
                       Margin="0,0,0,6"/>

            <CheckBox x:Name="ChkShowMinimapByDefault"
                      {DynamicResource ClassDiagram_ShowMinimap}
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,12"/>

            <!-- ── Separator ─────────────────────────────────────────────── -->
            <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,8"/>

            <!-- ── Section: Outline Panel ────────────────────────────────── -->
            <TextBlock {DynamicResource ClassDiagram_OutlinePanel}
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource PFP_AccentBrush}"
                       Margin="0,0,0,6"/>

            <CheckBox x:Name="ChkOutlineShowMembers"
                      {DynamicResource ClassDiagram_ShowMemberSubItems}
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,4"/>

            <CheckBox x:Name="ChkOutlineColorByVisibility"
                      Content="{DynamicResource ClassDiagram_ColorMemberDots}"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,12"/>

            <!-- ── Separator ─────────────────────────────────────────────── -->
            <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,8"/>

            <!-- ── Section: Hover Tooltips ───────────────────────────────── -->
            <TextBlock {DynamicResource ClassDiagram_HoverTooltips}
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource PFP_AccentBrush}"
                       Margin="0,0,0,6"/>

            <CheckBox x:Name="ChkShowHoverTooltips"
                      {DynamicResource ClassDiagram_ShowDetailTooltip}
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,4"/>

            <!-- Tooltip delay -->
            <Grid Margin="0,4,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" {DynamicResource ClassDiagram_TooltipDelay}
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PFP_TextBrush}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Slider x:Name="TooltipDelaySlider"
                            Minimum="100" Maximum="2000" TickFrequency="100"
                            IsSnapToTickEnabled="True"
                            Width="140"
                            VerticalAlignment="Center"
                            ValueChanged="OnTooltipDelayChanged"/>
                    <TextBlock x:Name="TooltipDelayLabel"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PFP_SubTextBrush}"
                               FontSize="11"/>
                </StackPanel>
            </Grid>

            <!-- ── Separator ─────────────────────────────────────────────── -->
            <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,8"/>

            <!-- ── Section: Session ──────────────────────────────────────── -->
            <TextBlock {DynamicResource ClassDiagram_SessionSection}
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource PFP_AccentBrush}"
                       Margin="0,0,0,6"/>

            <CheckBox x:Name="ChkRestoreLastState"
                      {DynamicResource ClassDiagram_RestoreSession}
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,12"/>

            <!-- ── Separator ─────────────────────────────────────────────── -->
            <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,8"/>

            <!-- ── Section: Solution Generation ─────────────────────────── -->
            <TextBlock {DynamicResource ClassDiagram_SolutionGeneration}
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource PFP_AccentBrush}"
                       Margin="0,0,0,6"/>

            <TextBlock TextWrapping="Wrap"
                       Foreground="{DynamicResource PFP_SubTextBrush}"
                       FontSize="11"
                       Margin="0,0,0,8">
                Controls the behaviour of "Generate Class Diagram for Solution".
                The generated diagram groups types by project with per-project swimlanes
                and persists its state to a .whscd twin file next to the solution.
            </TextBlock>

            <CheckBox x:Name="ChkSolutionShowSwimLanes"
                      {DynamicResource ClassDiagram_ShowSwimlanes}
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,4"/>

            <CheckBox x:Name="ChkSolutionIncludePrivate"
                      Content="{DynamicResource ClassDiagram_IncludePrivate}"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,4"/>

            <CheckBox x:Name="ChkSolutionIncludeInternal"
                      {DynamicResource ClassDiagram_IncludeInternal}
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,4"/>

            <CheckBox x:Name="ChkSolutionExcludeTestProjects"
                      {DynamicResource ClassDiagram_ExcludeTestProjects}
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,8"/>

            <!-- Max files prompt threshold -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" {DynamicResource ClassDiagram_WarnThreshold}
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PFP_TextBrush}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBox x:Name="TxtSolutionMaxFiles"
                             Width="60"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Center"
                             Background="{DynamicResource PFP_SectionBackgroundBrush}"
                             Foreground="{DynamicResource PFP_TextBrush}"
                             BorderBrush="{DynamicResource PFP_BorderBrush}"
                             CaretBrush="{DynamicResource PFP_TextBrush}"
                             Padding="4,2"
                             FontSize="12"
                             MaxLength="5"
                             TextAlignment="Right"/>
                    <TextBlock {DynamicResource ClassDiagram_FilesNeverLabel}
                               Margin="6,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PFP_SubTextBrush}"
                               FontSize="11"/>
                </StackPanel>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
