<!--
    Project: WpfHexEditor.Plugins.ClassDiagram
    File: Options/ClassDiagramOptionsPage.xaml
    Author: Derek Tremblay (derektremblay666@gmail.com)
    Contributors: Claude Sonnet 4.6
    Created: 2026-03-19
    Description:
        Options page for the Class Diagram plugin.
        Shown in IDE Options > Plugins > Class Diagram
        and in Plugin Manager "Settings" tab.
        Theme: DynamicResource PFP_* tokens — consistent with all other
        plugin options pages (XamlDesigner, AssemblyExplorer, etc.).
-->
<UserControl x:Class="WpfHexEditor.Plugins.ClassDiagram.Options.ClassDiagramOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Foreground="{DynamicResource PFP_TextBrush}"
             Padding="12"
             xmlns:cdSvc="clr-namespace:WpfHexEditor.Plugins.ClassDiagram.Services">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <cdSvc:ClassDiagramLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <!-- ── Section: Layout ──────────────────────────────────────────── -->
            <TextBlock Text="{DynamicResource ClassDiagram_LayoutSection}"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource PFP_AccentBrush}"
                       Margin="0,0,0,6"/>

            <CheckBox x:Name="ChkAutoLayout" Content="{DynamicResource ClassDiagram_AutoLayout}"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,4"/>

            <CheckBox x:Name="ChkGroupByNamespace" Content="{DynamicResource ClassDiagram_GroupByNamespace}"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,4"/>

            <!-- Default node width -->
            <Grid Margin="0,4,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{DynamicResource ClassDiagram_DefaultNodeWidth}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PFP_TextBrush}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBox x:Name="TxtNodeWidth"
                             Width="60"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Center"
                             Background="{DynamicResource PFP_SectionBackgroundBrush}"
                             Foreground="{DynamicResource PFP_TextBrush}"
                             BorderBrush="{DynamicResource PFP_BorderBrush}"
                             CaretBrush="{DynamicResource PFP_TextBrush}"
                             Padding="4,2"
                             FontSize="12"
                             MaxLength="5"
                             TextAlignment="Right"/>
                    <TextBlock Text="{DynamicResource CD_PxUnit}"
                               Margin="6,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PFP_SubTextBrush}"
                               FontSize="11"/>
                </StackPanel>
            </Grid>

            <!-- Default node height -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{DynamicResource ClassDiagram_DefaultNodeHeight}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PFP_TextBrush}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBox x:Name="TxtNodeHeight"
                             Width="60"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Center"
                             Background="{DynamicResource PFP_SectionBackgroundBrush}"
                             Foreground="{DynamicResource PFP_TextBrush}"
                             BorderBrush="{DynamicResource PFP_BorderBrush}"
                             CaretBrush="{DynamicResource PFP_TextBrush}"
                             Padding="4,2"
                             FontSize="12"
                             MaxLength="5"
                             TextAlignment="Right"/>
                    <TextBlock Text="{DynamicResource CD_PxUnit}"
                               Margin="6,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PFP_SubTextBrush}"
                               FontSize="11"/>
                </StackPanel>
            </Grid>

            <!-- ── Separator ─────────────────────────────────────────────── -->
            <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,8"/>

            <!-- ── Section: Canvas ───────────────────────────────────────── -->
            <TextBlock Text="{DynamicResource ClassDiagram_CanvasSection}"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource PFP_AccentBrush}"
                       Margin="0,0,0,6"/>

            <CheckBox x:Name="ChkShowGrid" Content="{DynamicResource ClassDiagram_ShowDotGrid}"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,4"/>

            <CheckBox x:Name="ChkSnapEnabled" Content="{DynamicResource ClassDiagram_SnapToGrid}"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,4"/>

            <!-- Snap size -->
            <Grid Margin="0,4,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{DynamicResource ClassDiagram_GridSnapSize}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PFP_TextBrush}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Slider x:Name="SnapSizeSlider"
                            Minimum="1" Maximum="64" TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            Width="140"
                            VerticalAlignment="Center"
                            ValueChanged="OnSnapSizeChanged"/>
                    <TextBlock x:Name="SnapSizeLabel"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PFP_SubTextBrush}"
                               FontSize="11"/>
                </StackPanel>
            </Grid>

            <!-- ── Separator ─────────────────────────────────────────────── -->
            <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,8"/>

            <!-- ── Section: Source Analysis ──────────────────────────────── -->
            <TextBlock Text="{DynamicResource ClassDiagram_SourceAnalysis}"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource PFP_AccentBrush}"
                       Margin="0,0,0,6"/>

            <TextBlock Text="{DynamicResource CD_ParseHintFile}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource PFP_SubTextBrush}"
                       FontSize="11"
                       Margin="0,0,0,8"/>

            <CheckBox x:Name="ChkIncludePrivate" Content="{DynamicResource ClassDiagram_IncludePrivate}"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,4"/>

            <CheckBox x:Name="ChkIncludeInherited" Content="{DynamicResource ClassDiagram_IncludeInherited}"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,12"/>

            <!-- ── Separator ─────────────────────────────────────────────── -->
            <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,8"/>

            <!-- ── Section: Minimap ──────────────────────────────────────── -->
            <TextBlock Text="{DynamicResource ClassDiagram_MinimapSection}"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource PFP_AccentBrush}"
                       Margin="0,0,0,6"/>

            <CheckBox x:Name="ChkShowMinimapByDefault" Content="{DynamicResource ClassDiagram_ShowMinimap}"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,12"/>

            <!-- ── Separator ─────────────────────────────────────────────── -->
            <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,8"/>

            <!-- ── Section: Outline Panel ────────────────────────────────── -->
            <TextBlock Text="{DynamicResource ClassDiagram_OutlinePanel}"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource PFP_AccentBrush}"
                       Margin="0,0,0,6"/>

            <CheckBox x:Name="ChkOutlineShowMembers" Content="{DynamicResource ClassDiagram_ShowMemberSubItems}"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,4"/>

            <CheckBox x:Name="ChkOutlineColorByVisibility"
                      Content="{DynamicResource ClassDiagram_ColorMemberDots}"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,12"/>

            <!-- ── Separator ─────────────────────────────────────────────── -->
            <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,8"/>

            <!-- ── Section: Hover Tooltips ───────────────────────────────── -->
            <TextBlock Text="{DynamicResource ClassDiagram_HoverTooltips}"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource PFP_AccentBrush}"
                       Margin="0,0,0,6"/>

            <CheckBox x:Name="ChkShowHoverTooltips" Content="{DynamicResource ClassDiagram_ShowDetailTooltip}"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,4"/>

            <!-- Tooltip delay -->
            <Grid Margin="0,4,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{DynamicResource ClassDiagram_TooltipDelay}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PFP_TextBrush}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Slider x:Name="TooltipDelaySlider"
                            Minimum="100" Maximum="2000" TickFrequency="100"
                            IsSnapToTickEnabled="True"
                            Width="140"
                            VerticalAlignment="Center"
                            ValueChanged="OnTooltipDelayChanged"/>
                    <TextBlock x:Name="TooltipDelayLabel"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PFP_SubTextBrush}"
                               FontSize="11"/>
                </StackPanel>
            </Grid>

            <!-- ── Separator ─────────────────────────────────────────────── -->
            <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,8"/>

            <!-- ── Section: Session ──────────────────────────────────────── -->
            <TextBlock Text="{DynamicResource ClassDiagram_SessionSection}"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource PFP_AccentBrush}"
                       Margin="0,0,0,6"/>

            <CheckBox x:Name="ChkRestoreLastState" Content="{DynamicResource ClassDiagram_RestoreSession}"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,12"/>

            <!-- ── Separator ─────────────────────────────────────────────── -->
            <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,8"/>

            <!-- ── Section: Solution Generation ─────────────────────────── -->
            <TextBlock Text="{DynamicResource ClassDiagram_SolutionGeneration}"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource PFP_AccentBrush}"
                       Margin="0,0,0,6"/>

            <TextBlock Text="{DynamicResource CD_SolutionHint}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource PFP_SubTextBrush}"
                       FontSize="11"
                       Margin="0,0,0,8"/>

            <CheckBox x:Name="ChkSolutionShowSwimLanes" Content="{DynamicResource ClassDiagram_ShowSwimlanes}"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,4"/>

            <CheckBox x:Name="ChkSolutionIncludePrivate"
                      Content="{DynamicResource ClassDiagram_IncludePrivate}"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,4"/>

            <CheckBox x:Name="ChkSolutionIncludeInternal" Content="{DynamicResource ClassDiagram_IncludeInternal}"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,4"/>

            <CheckBox x:Name="ChkSolutionExcludeTestProjects" Content="{DynamicResource ClassDiagram_ExcludeTestProjects}"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,8"/>

            <!-- Max files prompt threshold -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{DynamicResource ClassDiagram_WarnThreshold}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PFP_TextBrush}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBox x:Name="TxtSolutionMaxFiles"
                             Width="60"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Center"
                             Background="{DynamicResource PFP_SectionBackgroundBrush}"
                             Foreground="{DynamicResource PFP_TextBrush}"
                             BorderBrush="{DynamicResource PFP_BorderBrush}"
                             CaretBrush="{DynamicResource PFP_TextBrush}"
                             Padding="4,2"
                             FontSize="12"
                             MaxLength="5"
                             TextAlignment="Right"/>
                    <TextBlock Text="{DynamicResource ClassDiagram_FilesNeverLabel}"
                               Margin="6,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PFP_SubTextBrush}"
                               FontSize="11"/>
                </StackPanel>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
