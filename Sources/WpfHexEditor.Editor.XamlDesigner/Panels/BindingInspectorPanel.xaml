    Theme: Global theme via XD_* and DockBackgroundBrush tokens (DynamicResource)
    ResourceDictionaries: WpfHexEditor.Shell/Themes/{Theme}/Colors.xaml
    Panel: Binding Inspector — shows active bindings on the selected design canvas element.
    Columns: Property | Path | Mode | Source | Status
-->

<UserControl x:Class="WpfHexEditor.Editor.XamlDesigner.Panels.BindingInspectorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WpfHexEditor.Editor.XamlDesigner.Panels"
             Background="{DynamicResource DockBackgroundBrush}">

    <UserControl.Resources>
        <!-- Icon button style — identical pattern to PropertyInspectorPanel / XamlOutlinePanel -->
        <Style x:Key="XD_BindIconButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="22"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="Padding"         Value="3"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontFamily"      Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Foreground"      Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="2" SnapsToDevicePixels="True"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DockTabHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DockTabActiveBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Status cell color: green-tinted for OK, warning-tinted for Error -->
        <Style x:Key="XD_BindStatusCell" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Padding"    Value="2,1"/>
            <Style.Triggers>
                <Trigger Property="Text" Value="Error">
                    <Setter Property="Foreground" Value="{DynamicResource XD_CanvasBorderBrush}"/>
                    <Setter Property="FontWeight"  Value="SemiBold"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="26"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar (Row 0) ── -->
        <Border x:Name="ToolbarBorder" Grid.Row="0"
                Background="{DynamicResource XD_PanelToolbarBrush}"
                BorderBrush="{DynamicResource XD_PanelToolbarBorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <!-- Always-visible right panel (ToolbarOverflowManager anchor) -->
                <StackPanel x:Name="ToolbarRightPanel" DockPanel.Dock="Right"
                            Orientation="Horizontal" Margin="0,0,2,0">
                    <!-- Refresh bindings -->
                    <Button x:Name="BtnRefresh" Style="{StaticResource XD_BindIconButton}"
                            Content="&#xE72C;" ToolTip="Refresh bindings"/>
                    <!-- Overflow toggle (managed by ToolbarOverflowManager — initially hidden) -->
                    <ToggleButton x:Name="ToolbarOverflowButton"
                                  Width="22" Height="22" Padding="3"
                                  Background="Transparent" BorderThickness="0"
                                  FontFamily="Segoe MDL2 Assets" FontSize="11"
                                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                                  Content="&#xE712;" ToolTip="More options"
                                  Visibility="Collapsed"/>
                </StackPanel>

                <!-- Collapsible group: filter -->
                <StackPanel x:Name="TbgFilter" DockPanel.Dock="Left"
                            Orientation="Horizontal" Margin="4,2,0,2">
                    <TextBox x:Name="TbxFilter"
                             Width="120" Height="20"
                             Background="{DynamicResource DockMenuBackgroundBrush}"
                             Foreground="{DynamicResource DockMenuForegroundBrush}"
                             BorderBrush="{DynamicResource DockBorderBrush}"
                             BorderThickness="1" Padding="3,1"
                             FontSize="11"
                             VerticalContentAlignment="Center">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush Stretch="None" AlignmentX="Left">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="Filter bindings…"
                                                                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                                                                   Opacity="0.4"
                                                                   FontSize="11" Margin="4,1,0,0"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Separator (Row 1) -->
        <Border Grid.Row="1" Height="1"
                Background="{DynamicResource DockBorderBrush}"/>

        <!-- Context label banner (Row 2) -->
        <Border Grid.Row="2"
                Background="{DynamicResource DockMenuBackgroundBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,0,0,1" Padding="6,3">
            <TextBlock x:Name="TbkContextLabel"
                       Text="{Binding ContextLabel}"
                       Foreground="{DynamicResource XD_PropertyNameForeground}"
                       FontSize="11" FontStyle="Italic"/>
        </Border>

        <!-- ── Binding List (Row 3) ── -->
        <ListView x:Name="BindingList" Grid.Row="3"
                  ItemsSource="{Binding FilteredEntries}"
                  Background="{DynamicResource DockBackgroundBrush}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  BorderThickness="0"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto">

            <ListView.View>
                <GridView>
                    <!-- Column: Property -->
                    <GridViewColumn Header="Property" Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type local:BindingEntryViewModel}">
                                <TextBlock Text="{Binding PropertyName}"
                                           Foreground="{DynamicResource XD_PropertyNameForeground}"
                                           FontSize="11" Padding="2,1"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Column: Path -->
                    <GridViewColumn Header="Path" Width="130">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type local:BindingEntryViewModel}">
                                <TextBlock Text="{Binding Path}"
                                           Foreground="{DynamicResource XD_PropertyValueForeground}"
                                           FontSize="11" Padding="2,1"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Path}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Column: Mode -->
                    <GridViewColumn Header="Mode" Width="70">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type local:BindingEntryViewModel}">
                                <TextBlock Text="{Binding Mode}"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           FontSize="11" Padding="2,1"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Column: Source -->
                    <GridViewColumn Header="Source" Width="130">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type local:BindingEntryViewModel}">
                                <TextBlock Text="{Binding Source}"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           FontSize="11" Padding="2,1"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Source}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Column: Status -->
                    <GridViewColumn Header="Status" Width="55">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type local:BindingEntryViewModel}">
                                <TextBlock Text="{Binding Status}"
                                           Style="{StaticResource XD_BindStatusCell}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>
