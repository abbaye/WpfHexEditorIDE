<UserControl x:Class="WpfHexEditor.Editor.XamlDesigner.Panels.XamlOutlinePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfHexEditor.Editor.XamlDesigner.ViewModels"
             Background="{DynamicResource DockBackgroundBrush}">

    <UserControl.Resources>
        <!-- Icon button style matching VS-Like panel standard -->
        <Style x:Key="XD_IconButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="22"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="Padding"         Value="3"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontFamily"      Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Foreground"      Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="2" SnapsToDevicePixels="True"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DockTabHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DockTabActiveBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TreeViewItem style for outline nodes -->
        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded"                 Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="IsSelected"                 Value="{Binding IsSelected, Mode=TwoWay}"/>
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle"           Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DockTabActiveBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource DockTabActiveTextBrush}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DockTabHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="26"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar (Row 0) ── -->
        <Border x:Name="ToolbarBorder" Grid.Row="0"
                Background="{DynamicResource XD_PanelToolbarBrush}"
                BorderBrush="{DynamicResource XD_PanelToolbarBorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <!-- Always-visible right panel (ToolbarOverflowManager anchor) -->
                <StackPanel x:Name="ToolbarRightPanel" DockPanel.Dock="Right"
                            Orientation="Horizontal" Margin="0,0,2,0">
                    <Button x:Name="BtnCollapseAll" Style="{StaticResource XD_IconButton}"
                            Content="&#xE972;" ToolTip="Collapse All"/>
                    <ToggleButton x:Name="ToolbarOverflowButton"
                                  Width="22" Height="22" Padding="3"
                                  Background="Transparent" BorderThickness="0"
                                  FontFamily="Segoe MDL2 Assets" FontSize="11"
                                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                                  Content="&#xE712;" ToolTip="More options"
                                  Visibility="Collapsed"/>
                </StackPanel>

                <!-- Collapsible group: navigation buttons -->
                <StackPanel x:Name="TbgNavigation" DockPanel.Dock="Left"
                            Orientation="Horizontal" Margin="2,0,0,0">
                    <Button x:Name="BtnExpandAll" Style="{StaticResource XD_IconButton}"
                            Content="&#xE9A0;" ToolTip="Expand All"/>
                    <Button x:Name="BtnSyncToCode" Style="{StaticResource XD_IconButton}"
                            Content="&#xE8B0;" ToolTip="Sync selection to code editor"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Separator (Row 1) -->
        <Border Grid.Row="1" Height="1"
                Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── XAML Outline Tree (Row 2) ── -->
        <TreeView x:Name="OutlineTree" Grid.Row="2"
                  Background="{DynamicResource DockBackgroundBrush}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  BorderThickness="0"
                  ItemsSource="{Binding RootNodes}"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate DataType="{x:Type vm:XamlOutlineNode}"
                                          ItemsSource="{Binding Children}">
                    <TextBlock Text="{Binding DisplayLabel}"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                               Padding="2,1"/>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Grid>
</UserControl>
