    Theme: Global theme via XD_* and DockBackgroundBrush tokens (DynamicResource)
    ResourceDictionaries: WpfHexEditor.Shell/Themes/{Theme}/Colors.xaml
    Panel: Live Visual Tree — shows the runtime WPF visual tree of the design canvas.
    Bidirectional sync: node selection → canvas highlight; canvas selection → node highlight.
-->

<UserControl x:Class="WpfHexEditor.Editor.XamlDesigner.Panels.LiveVisualTreePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfHexEditor.Editor.XamlDesigner.ViewModels"
             Background="{DynamicResource DockBackgroundBrush}">

    <UserControl.Resources>
        <!-- Icon button style — same pattern as XamlOutlinePanel -->
        <Style x:Key="XD_LiveTreeIconButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="22"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="Padding"         Value="3"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontFamily"      Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Foreground"      Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="2" SnapsToDevicePixels="True"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DockTabHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DockTabActiveBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TreeViewItem style — same VS-like selection/hover pattern as XamlOutlinePanel -->
        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded"                 Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="IsSelected"                 Value="{Binding IsSelected, Mode=TwoWay}"/>
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle"           Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DockTabActiveBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource DockTabActiveTextBrush}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DockTabHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="26"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar (Row 0) ── -->
        <Border x:Name="ToolbarBorder" Grid.Row="0"
                Background="{DynamicResource XD_PanelToolbarBrush}"
                BorderBrush="{DynamicResource XD_PanelToolbarBorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <!-- Always-visible right panel (ToolbarOverflowManager anchor) -->
                <StackPanel x:Name="ToolbarRightPanel" DockPanel.Dock="Right"
                            Orientation="Horizontal" Margin="0,0,2,0">
                    <!-- Collapse all nodes -->
                    <Button x:Name="BtnCollapseAll" Style="{StaticResource XD_LiveTreeIconButton}"
                            Content="&#xE972;" ToolTip="Collapse All"/>
                    <!-- Overflow toggle (managed by ToolbarOverflowManager — initially hidden) -->
                    <ToggleButton x:Name="ToolbarOverflowButton"
                                  Width="22" Height="22" Padding="3"
                                  Background="Transparent" BorderThickness="0"
                                  FontFamily="Segoe MDL2 Assets" FontSize="11"
                                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                                  Content="&#xE712;" ToolTip="More options"
                                  Visibility="Collapsed"/>
                </StackPanel>

                <!-- Collapsible group: navigation + filter -->
                <StackPanel x:Name="TbgNavigation" DockPanel.Dock="Left"
                            Orientation="Horizontal" Margin="2,2,0,2">
                    <!-- Refresh visual tree -->
                    <Button x:Name="BtnRefresh" Style="{StaticResource XD_LiveTreeIconButton}"
                            Content="&#xE72C;" ToolTip="Refresh visual tree"/>

                    <!-- Filter textbox -->
                    <TextBox x:Name="TbxFilter"
                             Width="110" Height="20"
                             Margin="4,0,0,0"
                             Background="{DynamicResource DockMenuBackgroundBrush}"
                             Foreground="{DynamicResource DockMenuForegroundBrush}"
                             BorderBrush="{DynamicResource DockBorderBrush}"
                             BorderThickness="1" Padding="3,1"
                             FontSize="11"
                             VerticalContentAlignment="Center">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush Stretch="None" AlignmentX="Left">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="Filter types…"
                                                                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                                                                   Opacity="0.4"
                                                                   FontSize="11" Margin="4,1,0,0"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Separator (Row 1) -->
        <Border Grid.Row="1" Height="1"
                Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Live Visual Tree (Row 2) ── -->
        <TreeView x:Name="LiveTree" Grid.Row="2"
                  Background="{DynamicResource DockBackgroundBrush}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  BorderThickness="0"
                  ItemsSource="{Binding RootNodes}"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate DataType="{x:Type vm:LiveTreeNode}"
                                          ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal">
                        <!-- Type icon glyph (Segoe MDL2: E8A5 = "Layer") -->
                        <TextBlock Text="&#xE8A5;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="10"
                                   Foreground="{DynamicResource XD_PropertyNameForeground}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding DisplayLabel}"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Padding="0,1"/>
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Grid>
</UserControl>
