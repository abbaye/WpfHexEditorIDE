<!--
// ==========================================================
// Project: WpfHexEditor.Core.Options
// File: TextEditorOptionsPage.xaml
// Author: Auto
// Created: 2026-03-06
// Description:
//     Options page for the TextEditor (light, read-friendly).
//     Covers: font, indentation, features (line numbers, zoom),
//     .whchg changeset toggle, and syntax colour overrides.
//
// Theme: PanelCommon.xaml + DynamicResource brushes (all themes)
// ==========================================================
-->
<UserControl x:Class="WpfHexEditor.Core.Options.Pages.TextEditorOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cp="clr-namespace:WpfHexEditor.ColorPicker.Controls;assembly=WpfHexEditor.ColorPicker"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,16">

        <!-- ── Font ──────────────────────────────────────────────────────── -->
        <TextBlock Text="{DynamicResource TextOpt_FontSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{DynamicResource TextOpt_FontFamilyLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="FontFamilyCombo" Grid.Column="1"
                      SelectionChanged="OnComboChanged">
                <ComboBoxItem Content="Consolas"        Tag="Consolas"/>
                <ComboBoxItem Content="Courier New"     Tag="Courier New"/>
                <ComboBoxItem Content="Lucida Console"  Tag="Lucida Console"/>
                <ComboBoxItem Content="Cascadia Code"   Tag="Cascadia Code"/>
                <ComboBoxItem Content="Fira Code"       Tag="Fira Code"/>
                <ComboBoxItem Content="JetBrains Mono"  Tag="JetBrains Mono"/>
            </ComboBox>
        </Grid>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{DynamicResource TextOpt_FontSizeLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TxtFontSize" Grid.Column="1"
                     VerticalContentAlignment="Center"
                     LostFocus="OnTextLostFocus"/>
        </Grid>

        <Separator Margin="0,12,0,12"
                   Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Indentation ───────────────────────────────────────────────── -->
        <TextBlock Text="{DynamicResource TextOpt_IndentSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{DynamicResource TextOpt_IndentSizeLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TxtIndentSize" Grid.Column="1"
                     VerticalContentAlignment="Center"
                     LostFocus="OnTextLostFocus"/>
        </Grid>

        <CheckBox x:Name="CheckUseSpaces"
                  Content="{DynamicResource TextOpt_UseSpaces}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <Separator Margin="0,12,0,12"
                   Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Features ──────────────────────────────────────────────────── -->
        <TextBlock Text="{DynamicResource TextOpt_FeaturesSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <CheckBox x:Name="CheckLineNumbers"
                  Content="{DynamicResource TextOpt_ShowLineNumbers}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckShowRefreshRate"
                  Content="{DynamicResource TextOpt_ShowRefreshRate}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckWordWrap"
                  Content="{DynamicResource TextOpt_WordWrap}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckClickableLinks"
                  Content="{DynamicResource TextOpt_ClickableLinks}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckClickableEmails"
                  Content="{DynamicResource TextOpt_ClickableEmails}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{DynamicResource TextOpt_DefaultZoomLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TxtZoom" Grid.Column="1"
                     VerticalContentAlignment="Center"
                     LostFocus="OnTextLostFocus"/>
        </Grid>

        <!-- Mouse wheel speed (lines per notch — same model as HexEditor) -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{DynamicResource TextOpt_MouseWheelLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="MouseWheelCombo"
                      Grid.Column="1"
                      SelectionChanged="OnComboChanged"/>
        </Grid>

        <Separator Margin="0,12,0,12"
                   Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Changeset (.whchg) ─────────────────────────────────────────── -->
        <TextBlock Text="{DynamicResource TextOpt_ChangesetSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <CheckBox x:Name="CheckChangeset"
                  Content="{DynamicResource TextOpt_TrackEdits}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  IsEnabled="False"
                  ToolTip="Not yet implemented"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <Separator Margin="0,12,0,12"
                   Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Syntax colours ────────────────────────────────────────────── -->
        <TextBlock Text="{DynamicResource TextOpt_SyntaxSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <TextBlock Text="{DynamicResource TextOpt_SyntaxNote}"
                   FontSize="11"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Opacity="0.65"
                   Margin="0,0,0,12"/>

        <!-- Background -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{DynamicResource TextOpt_Background}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <CheckBox x:Name="ChkBg" Grid.Column="1"
                      VerticalAlignment="Center"
                      Checked="OnColorCheckChanged"
                      Unchecked="OnColorCheckChanged"/>
            <cp:ColorPicker x:Name="CpBg" Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            ShowAlphaChannel="False"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- Foreground -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{DynamicResource TextOpt_Foreground}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <CheckBox x:Name="ChkFg" Grid.Column="1"
                      VerticalAlignment="Center"
                      Checked="OnColorCheckChanged"
                      Unchecked="OnColorCheckChanged"/>
            <cp:ColorPicker x:Name="CpFg" Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            ShowAlphaChannel="False"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- Keyword -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{DynamicResource TextOpt_Keyword}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <CheckBox x:Name="ChkKw" Grid.Column="1"
                      VerticalAlignment="Center"
                      Checked="OnColorCheckChanged"
                      Unchecked="OnColorCheckChanged"/>
            <cp:ColorPicker x:Name="CpKw" Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            ShowAlphaChannel="False"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- String -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{DynamicResource TextOpt_String}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <CheckBox x:Name="ChkStr" Grid.Column="1"
                      VerticalAlignment="Center"
                      Checked="OnColorCheckChanged"
                      Unchecked="OnColorCheckChanged"/>
            <cp:ColorPicker x:Name="CpStr" Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            ShowAlphaChannel="False"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- Comment -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{DynamicResource TextOpt_Comment}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <CheckBox x:Name="ChkCmt" Grid.Column="1"
                      VerticalAlignment="Center"
                      Checked="OnColorCheckChanged"
                      Unchecked="OnColorCheckChanged"/>
            <cp:ColorPicker x:Name="CpCmt" Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            ShowAlphaChannel="False"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
