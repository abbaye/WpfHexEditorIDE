<UserControl x:Class="WpfHexEditor.Core.Options.Pages.TabGroupsOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,16">

            <!-- ── Split Behavior ──────────────────────────────────────────── -->
            <TextBlock Text="{DynamicResource TabGroups_SplitSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

            <CheckBox x:Name="ChkEnforceEqualSize"
                      Content="{DynamicResource TabGroups_EnforceEqualSize}"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="0,0,0,8"
                      Checked="OnChanged" Unchecked="OnChanged"/>

            <DockPanel Margin="0,0,0,6">
                <TextBlock Text="{DynamicResource TabGroups_MinWidthLabel}"
                           Width="200"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           Margin="0,0,8,0"/>
                <TextBox x:Name="TxtMinWidth"
                         Width="70"
                         HorizontalAlignment="Left"
                         VerticalContentAlignment="Center"
                         LostFocus="OnChanged"/>
            </DockPanel>

            <DockPanel Margin="0,0,0,0">
                <TextBlock Text="{DynamicResource TabGroups_MinHeightLabel}"
                           Width="200"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           Margin="0,0,8,0"/>
                <TextBox x:Name="TxtMinHeight"
                         Width="70"
                         HorizontalAlignment="Left"
                         VerticalContentAlignment="Center"
                         LostFocus="OnChanged"/>
            </DockPanel>

            <Separator Margin="0,16,0,16" Background="{DynamicResource DockBorderBrush}"/>

            <!-- ── Visual ──────────────────────────────────────────────────── -->
            <TextBlock Text="{DynamicResource TabGroups_VisualSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

            <CheckBox x:Name="ChkShowGroupBadge"
                      Content="{DynamicResource TabGroups_ShowGroupBadge}"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="0,0,0,8"
                      Checked="OnChanged" Unchecked="OnChanged"/>

            <Separator Margin="0,16,0,16" Background="{DynamicResource DockBorderBrush}"/>

            <!-- ── Persistence ─────────────────────────────────────────────── -->
            <TextBlock Text="{DynamicResource TabGroups_PersistSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

            <CheckBox x:Name="ChkPersistLayout"
                      Content="{DynamicResource TabGroups_PersistLayout}"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="0,0,0,8"
                      Checked="OnChanged" Unchecked="OnChanged"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
