<UserControl x:Class="WpfHexEditor.Core.Options.Pages.HexEditorEditingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,16">

        <TextBlock Text="{DynamicResource HexEdit_EditingSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <!-- Mode édition par défaut -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{DynamicResource HexEdit_DefaultEditModeLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="EditModeCombo"
                      Grid.Column="1"
                      SelectionChanged="OnComboChanged"/>
        </Grid>

        <!-- Vitesse molette -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{DynamicResource HexEdit_MouseWheelLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="MouseWheelCombo"
                      Grid.Column="1"
                      SelectionChanged="OnComboChanged"/>
        </Grid>

        <Separator Margin="0,8,0,16"
                   Background="{DynamicResource DockBorderBrush}"/>

        <!-- Zoom -->
        <CheckBox x:Name="CheckAllowZoom"
                  Content="{DynamicResource HexEdit_AllowZoom}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <!-- File drop -->
        <CheckBox x:Name="CheckAllowFileDrop"
                  Content="{DynamicResource HexEdit_AllowFileDrop}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,0"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <Separator Margin="0,16,0,16"
                   Background="{DynamicResource DockBorderBrush}"/>

        <TextBlock Text="{DynamicResource HexEdit_DataSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <!-- Byte size -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{DynamicResource HexEdit_ByteSizeLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="ByteSizeCombo" Grid.Column="1"
                      SelectionChanged="OnComboChanged"/>
        </Grid>

        <!-- Byte order -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{DynamicResource HexEdit_ByteOrderLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="ByteOrderCombo" Grid.Column="1"
                      SelectionChanged="OnComboChanged"/>
        </Grid>

        <!-- Copy to clipboard format -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{DynamicResource HexEdit_DefaultCopyFormatLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="CopyModeCombo" Grid.Column="1"
                      SelectionChanged="OnComboChanged"/>
        </Grid>

        <!-- Byte spacer visual style -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{DynamicResource HexEdit_SpacerVisualLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="SpacerVisualCombo" Grid.Column="1"
                      SelectionChanged="OnComboChanged"/>
        </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
