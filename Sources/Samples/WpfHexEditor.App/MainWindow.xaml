<Window x:Class="WpfHexEditor.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:docking="clr-namespace:WpfHexEditor.Docking.Controls;assembly=WpfHexEditor.Docking"
        Title="WpfHexEditor - Docking Test"
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="ApplicationCommands.New"/>
    </Window.InputBindings>

    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.New" Executed="OnNewDocument"/>
    </Window.CommandBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ==================== MENU BAR ==================== -->
        <Menu Grid.Row="0"
              Background="{DynamicResource SurfaceBrush}"
              Foreground="{DynamicResource ForegroundBrush}">

            <MenuItem Header="_File">
                <MenuItem Header="_New Document" InputGestureText="Ctrl+N"
                          Click="OnNewDocument"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="OnExit"/>
            </MenuItem>

            <MenuItem Header="_View">
                <MenuItem x:Name="MenuViewExplorer" Header="_Explorer"
                          IsCheckable="True" IsChecked="True"
                          Click="OnToggleExplorer"/>
                <MenuItem x:Name="MenuViewProperties" Header="_Properties"
                          IsCheckable="True" IsChecked="True"
                          Click="OnToggleProperties"/>
                <MenuItem x:Name="MenuViewOutput" Header="_Output"
                          IsCheckable="True" IsChecked="True"
                          Click="OnToggleOutput"/>
            </MenuItem>

            <MenuItem Header="_Window">
                <MenuItem Header="_Reset Layout" Click="OnResetLayout"/>
            </MenuItem>

            <MenuItem Header="_Theme">
                <MenuItem x:Name="MenuThemeLight" Header="_Light"
                          IsCheckable="True" Tag="Light" Click="OnThemeSelected"/>
                <MenuItem x:Name="MenuThemeDark" Header="_Dark"
                          IsCheckable="True" IsChecked="True" Tag="Dark" Click="OnThemeSelected"/>
                <MenuItem x:Name="MenuThemeVS" Header="_Visual Studio"
                          IsCheckable="True" Tag="VisualStudio" Click="OnThemeSelected"/>
            </MenuItem>
        </Menu>

        <!-- ==================== TOOLBAR ==================== -->
        <ToolBarTray Grid.Row="1" Background="{DynamicResource SurfaceBrush}">
            <ToolBar Background="{DynamicResource SurfaceBrush}"
                     Foreground="{DynamicResource ForegroundBrush}"
                     BorderThickness="0">
                <Button ToolTip="New Document (Ctrl+N)" Padding="8,4"
                        Click="OnNewDocument">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="+" FontWeight="Bold" FontSize="14" Margin="0,0,4,0"/>
                        <TextBlock Text="New Document"/>
                    </StackPanel>
                </Button>
                <Separator/>
                <TextBlock Text="Theme:" VerticalAlignment="Center" Margin="4,0"/>
                <ComboBox x:Name="ThemeCombo" Width="120" SelectedIndex="1"
                          SelectionChanged="OnThemeComboChanged">
                    <ComboBoxItem Content="Light" Tag="Light"/>
                    <ComboBoxItem Content="Dark" Tag="Dark"/>
                    <ComboBoxItem Content="Visual Studio" Tag="VisualStudio"/>
                </ComboBox>
            </ToolBar>
        </ToolBarTray>

        <!-- ==================== DOCK MANAGER ==================== -->
        <docking:DockManager x:Name="DockManager" Grid.Row="2"/>

        <!-- ==================== STATUS BAR ==================== -->
        <Border Grid.Row="3" Background="{DynamicResource AccentBrush}" Padding="6,3">
            <DockPanel>
                <TextBlock x:Name="ThemeStatusText" Text="Theme: Dark"
                           Foreground="White" FontSize="11"
                           DockPanel.Dock="Right" Margin="8,0"/>
                <TextBlock x:Name="StatusText" Text="Ready"
                           Foreground="White" FontSize="11"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
