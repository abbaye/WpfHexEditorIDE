     Description:
         Sample Properties panel shown at the bottom (tabbed with Output).
         Displays a simple key/value ListView to illustrate a typical properties panel.

     Architecture Notes:
         Theme: DockBackgroundBrush, DockTabTextBrush, DockBorderBrush (dynamic)
         ResourceDictionaries applied: inherited from App.xaml active theme.
     ========================================================== -->

<UserControl x:Class="WpfHexEditor.Sample.Docking.Panels.PropertiesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource DockBackgroundBrush}">

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource Panel_ToolbarBrush}"
                BorderBrush="{DynamicResource Panel_ToolbarBorderBrush}"
                BorderThickness="0,0,0,1"
                Height="28">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                <TextBlock Text="PROPERTIES"
                           Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Property grid as ListView with GridView columns -->
        <ListView x:Name="PropertyList"
                  BorderThickness="0"
                  Background="Transparent"
                  Foreground="{DynamicResource DockTabTextBrush}"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Property" Width="160"
                                    DisplayMemberBinding="{Binding Key}" />
                    <GridViewColumn Header="Value"    Width="240"
                                    DisplayMemberBinding="{Binding Value}" />
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</UserControl>
