     Project: WpfHexEditor.Sample.Docking
     File: Panels/ExplorerPanel.xaml
     Author: Derek Tremblay (derektremblay666@gmail.com)
     Contributors: Claude Sonnet 4.6
     Created: 2026-03-07
     Description:
         Sample left-side Explorer panel. Shows a TreeView with demo
         project nodes to illustrate a typical dockable side panel layout.

     Architecture Notes:
         Theme: DockBackgroundBrush, DockTabTextBrush (dynamic — auto-updates on theme switch)
         ResourceDictionaries applied: inherited from App.xaml active theme.
         Patterns: None (pure UI demo panel)
     ========================================================== -->

<UserControl x:Class="WpfHexEditor.Sample.Docking.Panels.ExplorerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource DockBackgroundBrush}"
             MinWidth="160">

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource Panel_ToolbarBrush}"
                BorderBrush="{DynamicResource Panel_ToolbarBorderBrush}"
                BorderThickness="0,0,0,1"
                Height="28">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                <TextBlock Text="EXPLORER"
                           Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- TreeView with demo nodes -->
        <TreeView Background="Transparent"
                  BorderThickness="0"
                  Foreground="{DynamicResource DockTabTextBrush}"
                  Padding="4,4,4,4">
            <TreeViewItem Header="My Project" IsExpanded="True" FontWeight="SemiBold">
                <TreeViewItem Header="src" IsExpanded="True">
                    <TreeViewItem Header="MainWindow.xaml" />
                    <TreeViewItem Header="MainWindow.xaml.cs" />
                    <TreeViewItem Header="App.xaml" />
                    <TreeViewItem Header="App.xaml.cs" />
                </TreeViewItem>
                <TreeViewItem Header="Panels" IsExpanded="True">
                    <TreeViewItem Header="ExplorerPanel.xaml" />
                    <TreeViewItem Header="OutputPanel.xaml" />
                </TreeViewItem>
                <TreeViewItem Header="Resources">
                    <TreeViewItem Header="Logo.ico" />
                </TreeViewItem>
                <TreeViewItem Header="MyProject.csproj" />
            </TreeViewItem>
        </TreeView>
    </DockPanel>
</UserControl>
