     Description:
         Sample bottom Output panel. Displays log lines in a RichTextBox.
         Use Log(message) from code to append timestamped lines.

     Architecture Notes:
         Theme: DockBackgroundBrush, DockTabTextBrush (dynamic — auto-updates on theme switch)
         ResourceDictionaries applied: inherited from App.xaml active theme.
         Patterns: None (pure UI demo panel)
     ========================================================== -->

<UserControl x:Class="WpfHexEditor.Sample.Docking.Panels.OutputPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource DockBackgroundBrush}"
             MinHeight="60">

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource Panel_ToolbarBrush}"
                BorderBrush="{DynamicResource Panel_ToolbarBorderBrush}"
                BorderThickness="0,0,0,1"
                Height="28">
            <DockPanel Margin="4,0">
                <!-- Clear button -->
                <Button DockPanel.Dock="Right"
                        Content="&#xE74D;"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="12"
                        Width="24" Height="24"
                        Margin="0,2,2,2"
                        ToolTip="Clear output"
                        Click="OnClear"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                        Cursor="Hand" />

                <TextBlock Text="OUTPUT"
                           Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Opacity="0.7" />
            </DockPanel>
        </Border>

        <!-- Log output -->
        <RichTextBox x:Name="LogBox"
                     IsReadOnly="True"
                     Background="Transparent"
                     Foreground="{DynamicResource DockTabTextBrush}"
                     BorderThickness="0"
                     FontFamily="Consolas"
                     FontSize="12"
                     Padding="6,4"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto" />
    </DockPanel>
</UserControl>
