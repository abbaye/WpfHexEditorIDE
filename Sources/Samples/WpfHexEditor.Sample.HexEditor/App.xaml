<Application x:Class="WpfHexEditor.Sample.HexEditor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml">
    <!-- Modern Main Window (VS 2026 inspired design) -->
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- TODO: LocalizedResourceDictionary will be re-added from WpfHexEditor.Core.Localization micro-package -->
                <!-- Office Theme (needed for existing dialogs like Options/Paramètres) -->
                <ResourceDictionary Source="Resources/Themes/Office.xaml"/>
                <!-- Ribbon Vector Icons (Temporary - will be removed when Ribbon is deleted) -->
                <ResourceDictionary Source="Resources/RibbonIcons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
