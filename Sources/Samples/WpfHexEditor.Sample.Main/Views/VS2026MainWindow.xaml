<Window x:Class="WpfHexEditor.Sample.Main.Views.VS2026MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfHexEditor.Sample.Main.Views"
        xmlns:components="clr-namespace:WpfHexEditor.Sample.Main.Views.Components"
        xmlns:hexEditor="clr-namespace:WpfHexaEditor;assembly=WPFHexaEditor"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="900" Width="1600"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Window.InputBindings>
        <!-- Keyboard shortcuts -->
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewFileCommand}"/>
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding OpenFileCommand}"/>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveFileCommand}"/>
        <KeyBinding Key="W" Modifiers="Control" Command="{Binding CloseFileCommand}"/>
        <KeyBinding Key="F" Modifiers="Control" Command="{Binding ToggleSearchPanelCommand}"/>
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding UndoCommand}"/>
        <KeyBinding Key="Y" Modifiers="Control" Command="{Binding RedoCommand}"/>
        <KeyBinding Key="A" Modifiers="Control" Command="{Binding SelectAllCommand}"/>
        <KeyBinding Key="G" Modifiers="Control" Command="{Binding GoToPositionCommand}"/>
        <KeyBinding Key="B" Modifiers="Control" Command="{Binding ToggleBookmarkCommand}"/>
        <KeyBinding Key="OemComma" Modifiers="Control" Command="{Binding ToggleSettingsPanelCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Menu -->
            <RowDefinition Height="Auto"/> <!-- Toolbar -->
            <RowDefinition Height="*"/>    <!-- Content -->
        </Grid.RowDefinitions>

        <!-- Menu Bar (Original Structure) -->
        <Menu Grid.Row="0">
            <MenuItem Header="{DynamicResource Menu_File}">
                <MenuItem Header="{DynamicResource Menu_File_Open}" Command="{Binding OpenFileCommand}" InputGestureText="Ctrl+O"/>
                <MenuItem Header="{DynamicResource Menu_File_Save}" Command="{Binding SaveFileCommand}" InputGestureText="Ctrl+S"/>
                <MenuItem Header="{DynamicResource Menu_File_SaveAs}" Command="{Binding SaveAsFileCommand}"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_File_Close}" Command="{Binding CloseFileCommand}"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_File_Exit}" Command="{Binding ExitCommand}"/>
            </MenuItem>

            <MenuItem Header="{DynamicResource Menu_Edit}">
                <MenuItem Header="{DynamicResource Menu_Edit_Undo}" Command="{Binding UndoCommand}" InputGestureText="Ctrl+Z"/>
                <MenuItem Header="{DynamicResource Menu_Edit_Redo}" Command="{Binding RedoCommand}" InputGestureText="Ctrl+Y"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_Edit_Find}" Command="{Binding ToggleSearchPanelCommand}" InputGestureText="Ctrl+F"/>
                <MenuItem Header="{DynamicResource Menu_Edit_FindReplace}" Command="{Binding ToggleSearchPanelCommand}" InputGestureText="Ctrl+H"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_Edit_Copy}" Command="{Binding CopyCommand}" InputGestureText="Ctrl+C"/>
                <MenuItem Header="{DynamicResource Menu_Edit_Paste}" Command="{Binding PasteCommand}" InputGestureText="Ctrl+V"/>
                <MenuItem Header="{DynamicResource Menu_Edit_DeleteSelection}" Command="{Binding DeleteSelectionCommand}" InputGestureText="Del"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_Edit_SelectAll}" Command="{Binding SelectAllCommand}" InputGestureText="Ctrl+A"/>
                <MenuItem Header="{DynamicResource Menu_Edit_ClearSelection}" Command="{Binding ClearSelectionCommand}"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_Edit_Bookmarks}">
                    <MenuItem Header="{DynamicResource Menu_Edit_ToggleBookmark}" Command="{Binding ToggleBookmarkCommand}" InputGestureText="Ctrl+B"/>
                    <MenuItem Header="{DynamicResource Menu_Edit_ClearAllBookmarks}" Command="{Binding ClearBookmarksCommand}"/>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="{DynamicResource Menu_Search}">
                <MenuItem Header="{DynamicResource Menu_Search_FindNext}" Command="{Binding FindNextCommand}" InputGestureText="F3"/>
                <MenuItem Header="{DynamicResource Menu_Search_FindPrevious}" Command="{Binding FindPreviousCommand}" InputGestureText="Shift+F3"/>
            </MenuItem>

            <MenuItem Header="{DynamicResource Menu_Tools}">
                <MenuItem Header="{DynamicResource Menu_Tools_Bookmarks}">
                    <MenuItem Header="{DynamicResource Menu_Edit_ToggleBookmark}" Command="{Binding ToggleBookmarkCommand}" InputGestureText="Ctrl+B"/>
                    <MenuItem Header="{DynamicResource Menu_Edit_ClearAllBookmarks}" Command="{Binding ClearBookmarksCommand}"/>
                    <Separator/>
                    <MenuItem Header="{DynamicResource Menu_Tools_NextBookmark}" Command="{Binding NextBookmarkCommand}" InputGestureText="Ctrl+N"/>
                    <MenuItem Header="{DynamicResource Menu_Tools_PreviousBookmark}" Command="{Binding PreviousBookmarkCommand}" InputGestureText="Ctrl+P"/>
                    <Separator/>
                    <MenuItem Header="{DynamicResource Menu_Tools_ShowAllBookmarks}" Command="{Binding ShowBookmarksCommand}"/>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="{DynamicResource Menu_Position}">
                <MenuItem Header="{DynamicResource Menu_Position_GoTo}" Command="{Binding GoToPositionCommand}" InputGestureText="Ctrl+G"/>
            </MenuItem>

            <MenuItem Header="{DynamicResource Menu_View}">
                <MenuItem Header="{DynamicResource Menu_View_DisplayOptions}">
                    <MenuItem Header="{DynamicResource Menu_View_ShowStatusBar}" IsCheckable="True" IsChecked="True"/>
                    <MenuItem Header="{DynamicResource Menu_View_ShowHeader}" IsCheckable="True" IsChecked="True"/>
                    <MenuItem Header="{DynamicResource Menu_View_ShowOffset}" IsCheckable="True" IsChecked="True"/>
                    <MenuItem Header="{DynamicResource Menu_View_ShowASCII}" IsCheckable="True" IsChecked="True"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_View_BytesPerLine}">
                    <MenuItem Header="8" Tag="8"/>
                    <MenuItem Header="16" Tag="16" IsChecked="True"/>
                    <MenuItem Header="32" Tag="32"/>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="{DynamicResource Menu_Options}">
                <MenuItem Header="{DynamicResource Menu_Options_SettingsPanel}" Command="{Binding ToggleSettingsPanelCommand}" InputGestureText="Ctrl+,">
                    <MenuItem.Icon>
                        <TextBlock Text="⚙️" FontSize="16"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_Options_Advanced}" Click="ShowOptionsDialog_Click">
                    <MenuItem.Icon>
                        <TextBlock Text="🔧" FontSize="16"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_Options_ContextMenu}" IsCheckable="True" IsChecked="True"/>
                <MenuItem Header="{DynamicResource Menu_Options_ShowByteToolTip}" IsCheckable="True"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_Options_AutoHighlight}" IsCheckable="True"/>
                <MenuItem Header="{DynamicResource Menu_Options_CountSelected}" IsCheckable="True"/>
            </MenuItem>

            <MenuItem Header="{DynamicResource Menu_Help}">
                <MenuItem Header="{DynamicResource Menu_Help_About}" Command="{Binding ShowAboutCommand}"/>
                <MenuItem Header="{DynamicResource Menu_Help_KeyboardShortcuts}" Command="{Binding ShowKeyboardShortcutsCommand}"/>
            </MenuItem>
        </Menu>

        <!-- Toolbar (Original Structure) -->
        <ToolBar Grid.Row="1">
            <Button Command="{Binding OpenFileCommand}" ToolTip="{DynamicResource Toolbar_Open_ToolTip}">
                <TextBlock Text="{DynamicResource Toolbar_Open}" FontSize="12"/>
            </Button>
            <Button Command="{Binding SaveFileCommand}" ToolTip="{DynamicResource Toolbar_Save_ToolTip}">
                <TextBlock Text="{DynamicResource Toolbar_Save}" FontSize="12"/>
            </Button>
            <Separator/>
            <Button Command="{Binding UndoCommand}" ToolTip="{DynamicResource Toolbar_Undo_ToolTip}">
                <TextBlock Text="{DynamicResource Toolbar_Undo}" FontSize="12"/>
            </Button>
            <Button Command="{Binding RedoCommand}" ToolTip="{DynamicResource Toolbar_Redo_ToolTip}">
                <TextBlock Text="{DynamicResource Toolbar_Redo}" FontSize="12"/>
            </Button>
            <Separator/>
            <ToggleButton ToolTip="{DynamicResource Toolbar_Insert_ToolTip}">
                <TextBlock Text="{DynamicResource Toolbar_Insert}" FontSize="12" FontWeight="Bold"/>
            </ToggleButton>
            <ToggleButton ToolTip="{DynamicResource Toolbar_ReadOnly_ToolTip}">
                <TextBlock Text="{DynamicResource Toolbar_ReadOnly}" FontSize="12"/>
            </ToggleButton>
        </ToolBar>

        <!-- Main Content with Settings Panel -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- HexEditor Control -->
            <hexEditor:HexEditor x:Name="HexEditorControl"
                                Grid.Column="0"
                                Margin="4"/>

            <!-- Settings Panel (Slide-in from right) -->
            <components:HexEditorSettings x:Name="HexEditorSettingsPanel"
                                         Grid.Column="1"
                                         Visibility="{Binding IsSettingsPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <components:HexEditorSettings.Style>
                    <Style TargetType="components:HexEditorSettings">
                        <Setter Property="Width" Value="0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSettingsPanelVisible}" Value="True">
                                <Setter Property="Width" Value="350"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </components:HexEditorSettings.Style>
            </components:HexEditorSettings>

        </Grid>

    </Grid>

</Window>
