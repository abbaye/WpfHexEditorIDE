<UserControl x:Class="WpfHexEditor.Shell.Panels.Panels.WhfmtCatalogDocument"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfHexEditor.Shell.Panels.ViewModels"
             Background="{DynamicResource SE_BackgroundBrush}"
             Foreground="{DynamicResource SE_ForegroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style x:Key="CatalogButton" TargetType="Button">
            <Setter Property="Padding"         Value="10,4"/>
            <Setter Property="Margin"          Value="0,0,4,0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Background"      Value="{DynamicResource SE_SearchBoxBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource SE_SelectionBorderBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource SE_ForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- DataGrid theme overrides -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"            Value="{DynamicResource SE_BackgroundBrush}"/>
            <Setter Property="Foreground"            Value="{DynamicResource SE_ForegroundBrush}"/>
            <Setter Property="BorderThickness"       Value="0"/>
            <Setter Property="GridLinesVisibility"   Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource SE_SeparatorBrush}"/>
            <Setter Property="RowBackground"         Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="Transparent"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="{DynamicResource SE_ToolbarBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource SE_ForegroundBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource SE_SeparatorBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="FontSize"        Value="11"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Panel_ItemHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Panel_ItemSelectedBrush}"/>
                </Trigger>
                <DataTrigger Binding="{Binding IsLoadFailure}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource SE_ModifiedIndicatorBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{DynamicResource SE_ForegroundBrush}"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Padding"         Value="4,2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>      <!-- Toolbar + Search -->
            <RowDefinition Height="*"/>         <!-- DataGrid + Detail -->
            <RowDefinition Height="Auto"/>      <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ================================================================ -->
        <!-- Toolbar                                                           -->
        <!-- ================================================================ -->
        <Border Grid.Row="0" Background="{DynamicResource SE_ToolbarBrush}"
                BorderBrush="{DynamicResource SE_SeparatorBrush}" BorderThickness="0,0,0,1"
                Padding="8,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: action buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,10,0">
                    <Button Style="{StaticResource CatalogButton}"
                            Command="{Binding OpenSelectedCommand}"
                            ToolTip="Open selected format(s) in Structure Editor">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7AC;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Open" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource CatalogButton}"
                            Command="{Binding ExportSelectedCommand}"
                            ToolTip="Export selected format(s) to disk">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xEDE1;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Export" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Separator Width="1" Margin="4,0" Background="{DynamicResource SE_SeparatorBrush}"/>
                    <Button Style="{StaticResource CatalogButton}"
                            Command="{Binding AddFormatCommand}"
                            ToolTip="Add a user .whfmt file to the catalog">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Add…" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource CatalogButton}"
                            Command="{Binding RefreshCommand}"
                            ToolTip="Refresh catalog">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Right: search -->
                <Border Grid.Column="1"
                        Background="{DynamicResource SE_SearchBoxBrush}"
                        BorderBrush="{DynamicResource SE_SelectionBorderBrush}"
                        BorderThickness="1" CornerRadius="3"
                        Padding="6,3">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"
                                   Foreground="{DynamicResource SE_ForegroundBrush}" Opacity="0.5"/>
                        <TextBox Grid.Column="1" x:Name="SearchBox"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{DynamicResource SE_SearchBoxForegroundBrush}"
                                 VerticalContentAlignment="Center"
                                 ToolTip="Filter by name, category, extension or author"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ================================================================ -->
        <!-- Main: DataGrid + Detail                                           -->
        <!-- ================================================================ -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="120"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="200" MinHeight="100"/>
            </Grid.RowDefinitions>

            <DataGrid x:Name="CatalogGrid" Grid.Row="0"
                      ItemsSource="{Binding FilteredView}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      CanUserSortColumns="True"
                      HeadersVisibility="Column"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                      SelectionChanged="OnGridSelectionChanged"
                      MouseDoubleClick="OnGridDoubleClick">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name"       Binding="{Binding Name}"             Width="200" SortMemberPath="Name"/>
                    <DataGridTextColumn Header="Category"   Binding="{Binding Category}"          Width="110" SortMemberPath="Category"/>
                    <DataGridTextColumn Header="Extensions" Binding="{Binding ExtensionsDisplay}" Width="120" SortMemberPath="ExtensionsDisplay"/>
                    <DataGridTextColumn Header="Version"    Binding="{Binding Version}"           Width="70"  SortMemberPath="Version"/>
                    <DataGridTemplateColumn Header="Quality" Width="80" SortMemberPath="QualityScore">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type vm:WhfmtFormatItemVm}">
                                <Grid>
                                    <ProgressBar Minimum="0" Maximum="100" Height="6"
                                                 Value="{Binding QualityScore}"
                                                 Foreground="{DynamicResource SE_AccentBrush}"
                                                 Background="{DynamicResource SE_SearchBoxBrush}">
                                        <ProgressBar.Style>
                                            <Style TargetType="ProgressBar">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLoadFailure}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ProgressBar.Style>
                                    </ProgressBar>
                                    <TextBlock Text="⚠" VerticalAlignment="Center"
                                               HorizontalAlignment="Center" FontSize="11"
                                               Foreground="{DynamicResource SE_ModifiedIndicatorBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLoadFailure}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Author"  Binding="{Binding Author}"      Width="120" SortMemberPath="Author"/>
                    <DataGridTextColumn Header="Source"  Binding="{Binding SourceLabel}" Width="70"  SortMemberPath="SourceLabel"/>
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Row="1" Height="4"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          Background="{DynamicResource SE_SeparatorBrush}"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- Detail panel -->
            <local:WhfmtFormatDetailPanel Grid.Row="2" DataContext="{Binding Detail}"
                                          xmlns:local="clr-namespace:WpfHexEditor.Shell.Panels.Panels"/>
        </Grid>

        <!-- ================================================================ -->
        <!-- Status bar                                                        -->
        <!-- ================================================================ -->
        <Border Grid.Row="2" Background="{DynamicResource SE_ToolbarBrush}"
                BorderBrush="{DynamicResource SE_SeparatorBrush}" BorderThickness="0,1,0,0"
                Padding="8,2">
            <TextBlock Text="{Binding StatusText}" FontSize="11"
                       Foreground="{DynamicResource SE_ForegroundBrush}" Opacity="0.7"/>
        </Border>
    </Grid>
</UserControl>
