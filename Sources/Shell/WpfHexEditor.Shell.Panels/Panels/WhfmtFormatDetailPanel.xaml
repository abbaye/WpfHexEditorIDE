<UserControl x:Class="WpfHexEditor.Shell.Panels.Panels.WhfmtFormatDetailPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource SE_BackgroundBrush}"
             Foreground="{DynamicResource SE_ForegroundBrush}"
             MinWidth="180">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Icon-only toolbar button for detail panel -->
        <Style x:Key="DetailIconButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="22"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="Padding"         Value="3"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground"      Value="{DynamicResource SE_ForegroundBrush}"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="400"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="2" SnapsToDevicePixels="True"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource Panel_ToolbarButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource Panel_ToolbarButtonActiveBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MetaLabel" TargetType="TextBlock">
            <Setter Property="FontSize"          Value="10"/>
            <Setter Property="Foreground"        Value="{DynamicResource SE_ForegroundBrush}"/>
            <Setter Property="Opacity"           Value="0.5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth"          Value="60"/>
            <Setter Property="Margin"            Value="0,0,8,0"/>
        </Style>

        <Style x:Key="MetaValue" TargetType="TextBlock">
            <Setter Property="FontSize"          Value="11"/>
            <Setter Property="Foreground"        Value="{DynamicResource SE_ForegroundBrush}"/>
            <Setter Property="TextWrapping"      Value="Wrap"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Empty placeholder -->
        <TextBlock Text="Select a format to see details."
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontStyle="Italic" FontSize="12"
                   Foreground="{DynamicResource SE_ForegroundBrush}" Opacity="0.4">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasSelection}" Value="False">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Detail content -->
        <Grid Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="26"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── Mini-toolbar ── -->
            <Border Grid.Row="0"
                    Background="{DynamicResource Panel_ToolbarBrush}"
                    BorderBrush="{DynamicResource Panel_ToolbarBorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="4,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Action buttons -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button Style="{StaticResource DetailIconButton}"
                                Command="{Binding OpenCommand}"
                                ToolTip="Open in Structure Editor">
                            <TextBlock Text="&#xE7AC;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="{DynamicResource SE_ForegroundBrush}"/>
                        </Button>
                        <Button Style="{StaticResource DetailIconButton}"
                                Command="{Binding ExportCommand}"
                                ToolTip="Export to file…">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="{DynamicResource SE_ForegroundBrush}"/>
                        </Button>
                        <Button Style="{StaticResource DetailIconButton}"
                                Command="{Binding CopyJsonCommand}"
                                ToolTip="View raw JSON">
                            <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="{DynamicResource SE_ForegroundBrush}"/>
                        </Button>

                        <!-- Separator -->
                        <Border Width="1" Margin="3,4" Background="{DynamicResource SE_SeparatorBrush}"
                                VerticalAlignment="Stretch"/>

                        <!-- Retry / Exclude (failure only) -->
                        <Button Style="{StaticResource DetailIconButton}"
                                Command="{Binding RetryLoadCommand}"
                                Visibility="{Binding IsLoadFailure, Converter={StaticResource BoolToVis}}"
                                ToolTip="Retry loading this format">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="{DynamicResource Panel_WarningTextBrush}"/>
                        </Button>
                        <Button Style="{StaticResource DetailIconButton}"
                                Command="{Binding ExcludeCommand}"
                                Visibility="{Binding IsLoadFailure, Converter={StaticResource BoolToVis}}"
                                ToolTip="Exclude this format from catalog">
                            <TextBlock Text="&#xEBD3;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="{DynamicResource Panel_WarningTextBrush}"/>
                        </Button>
                    </StackPanel>

                    <!-- Load status indicator -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,4,0"
                                VerticalAlignment="Center">
                        <!-- OK state -->
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11" Text="&#xE73E;"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SE_AccentBrush}"
                                   ToolTip="Format loaded successfully">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoadFailure}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <!-- Failure state -->
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11" Text="&#xEB90;"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Panel_WarningTextBrush}"
                                   ToolTip="Format failed to load"
                                   Visibility="{Binding IsLoadFailure, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Scrollable content ── -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- Name + Description header -->
                    <Border Background="{DynamicResource SE_GroupHeaderBrush}"
                            BorderBrush="{DynamicResource SE_SeparatorBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="10,8">
                        <StackPanel>
                            <TextBlock Text="{Binding Name}"
                                       FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"
                                       Foreground="{DynamicResource SE_ForegroundBrush}"/>
                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap"
                                       FontSize="11" Opacity="0.65" Margin="0,3,0,0"
                                       Foreground="{DynamicResource SE_ForegroundBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Metadata grid -->
                    <Border BorderBrush="{DynamicResource SE_SeparatorBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="10,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="20"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Version"   Style="{StaticResource MetaLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Version}"          Style="{StaticResource MetaValue}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Author"    Style="{StaticResource MetaLabel}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Author}"           Style="{StaticResource MetaValue}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Category"  Style="{StaticResource MetaLabel}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Category}"         Style="{StaticResource MetaValue}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Platform"  Style="{StaticResource MetaLabel}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Platform}"         Style="{StaticResource MetaValue}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Editor"    Style="{StaticResource MetaLabel}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding PreferredEditor}"  Style="{StaticResource MetaValue}"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Diff"      Style="{StaticResource MetaLabel}"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding DiffMode}"         Style="{StaticResource MetaValue}"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Status"    Style="{StaticResource MetaLabel}"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding LoadStatusDisplay}" Style="{StaticResource MetaValue}"/>
                        </Grid>
                    </Border>

                    <!-- Extensions chips -->
                    <Border BorderBrush="{DynamicResource SE_SeparatorBrush}"
                            BorderThickness="0,0,0,1" Padding="10,6">
                        <StackPanel>
                            <TextBlock Text="Extensions" Style="{StaticResource MetaLabel}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding ExtensionsDisplay}"
                                       FontSize="11" FontFamily="Consolas" TextWrapping="Wrap"
                                       Foreground="{DynamicResource SE_AccentBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Quality score -->
                    <Border BorderBrush="{DynamicResource SE_SeparatorBrush}"
                            BorderThickness="0,0,0,1" Padding="10,6">
                        <StackPanel>
                            <TextBlock Text="Quality Score" Style="{StaticResource MetaLabel}" Margin="0,0,0,4"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ProgressBar x:Name="QualityBar"
                                             Grid.Column="0" Value="{Binding QualityScore}"
                                             Minimum="0" Maximum="100" Height="4"
                                             Foreground="{DynamicResource SE_AccentBrush}"
                                             Background="{DynamicResource SE_SearchBoxBrush}"
                                             VerticalAlignment="Center" BorderThickness="0">
                                    <ProgressBar.Style>
                                        <Style TargetType="ProgressBar">
                                            <Setter Property="Foreground" Value="{DynamicResource SE_AccentBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding QualityScore}" Value="0">
                                                    <Setter Property="Foreground" Value="{DynamicResource SE_ValidationErrorBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ProgressBar.Style>
                                </ProgressBar>
                                <TextBlock Grid.Column="1" Margin="8,0,0,0" FontSize="11"
                                           Text="{Binding QualityScore, StringFormat={}{0}/100}"
                                           Foreground="{DynamicResource SE_ForegroundBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Detection + Blocks -->
                    <Border BorderBrush="{DynamicResource SE_SeparatorBrush}"
                            BorderThickness="0,0,0,1" Padding="10,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="20"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Detection" Style="{StaticResource MetaLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DetectionRulesSummary}" Style="{StaticResource MetaValue}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Blocks"    Style="{StaticResource MetaLabel}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding BlockCount}"            Style="{StaticResource MetaValue}"/>
                        </Grid>
                    </Border>

                    <!-- Load failure card -->
                    <Border Margin="10,8,10,4" Padding="8,6" CornerRadius="3"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource Panel_WarningBorderBrush}"
                            Background="{DynamicResource Panel_WarningBackgroundBrush}"
                            Visibility="{Binding IsLoadFailure, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="{DynamicResource Panel_WarningTextBrush}"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Load Error" FontWeight="SemiBold" FontSize="11"
                                           Foreground="{DynamicResource Panel_WarningTextBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding FailureReason}" TextWrapping="Wrap" FontSize="11"
                                       Foreground="{DynamicResource SE_ForegroundBrush}"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
