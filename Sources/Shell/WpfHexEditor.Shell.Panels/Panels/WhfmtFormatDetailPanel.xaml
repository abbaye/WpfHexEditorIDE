<UserControl x:Class="WpfHexEditor.Shell.Panels.Panels.WhfmtFormatDetailPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource SE_BackgroundBrush}"
             Foreground="{DynamicResource SE_ForegroundBrush}"
             MinWidth="180">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="WhfmtPanelStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <!-- Empty placeholder -->
        <TextBlock Text="Select a format to see details."
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontStyle="Italic" FontSize="12"
                   Foreground="{DynamicResource SE_ForegroundBrush}" Opacity="0.4">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasSelection}" Value="False">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Detail content -->
        <Grid Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="26"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── Mini-toolbar ── -->
            <Border Grid.Row="0"
                    Background="{DynamicResource Panel_ToolbarBrush}"
                    BorderBrush="{DynamicResource Panel_ToolbarBorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="4,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Action buttons -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button Style="{StaticResource DetailIconButton}"
                                Command="{Binding OpenCommand}"
                                ToolTip="Open in Structure Editor">
                            <TextBlock Text="&#xE7AC;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="{DynamicResource SE_ForegroundBrush}"/>
                        </Button>
                        <Button Style="{StaticResource DetailIconButton}"
                                Command="{Binding ExportCommand}"
                                ToolTip="Export to file…">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="{DynamicResource SE_ForegroundBrush}"/>
                        </Button>
                        <Button Style="{StaticResource DetailIconButton}"
                                Command="{Binding CopyJsonCommand}"
                                ToolTip="View raw JSON">
                            <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="{DynamicResource SE_ForegroundBrush}"/>
                        </Button>

                        <!-- Separator -->
                        <Border Width="1" Margin="3,4" Background="{DynamicResource SE_SeparatorBrush}"
                                VerticalAlignment="Stretch"/>

                        <!-- Retry / Exclude (failure only) -->
                        <Button Style="{StaticResource DetailIconButton}"
                                Command="{Binding RetryLoadCommand}"
                                Visibility="{Binding IsLoadFailure, Converter={StaticResource BoolToVis}}"
                                ToolTip="Retry loading this format">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="{DynamicResource Panel_WarningTextBrush}"/>
                        </Button>
                        <Button Style="{StaticResource DetailIconButton}"
                                Command="{Binding ExcludeCommand}"
                                Visibility="{Binding IsLoadFailure, Converter={StaticResource BoolToVis}}"
                                ToolTip="Exclude this format from catalog">
                            <TextBlock Text="&#xEBD3;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="{DynamicResource Panel_WarningTextBrush}"/>
                        </Button>
                    </StackPanel>

                    <!-- Load status indicator -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,4,0"
                                VerticalAlignment="Center">
                        <!-- OK state -->
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11" Text="&#xE73E;"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SE_AccentBrush}"
                                   ToolTip="Format loaded successfully">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoadFailure}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <!-- Failure state -->
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11" Text="&#xEB90;"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Panel_WarningTextBrush}"
                                   ToolTip="Format failed to load"
                                   Visibility="{Binding IsLoadFailure, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── TabControl — 5 tabs ── -->
            <TabControl Grid.Row="1" Style="{StaticResource WE_DetailTabControl}">

                <!-- ════════ Tab 1: Overview ════════ -->
                <TabItem Style="{StaticResource WE_DetailTabItem}" Header="Overview">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>

                            <!-- Name + Description header -->
                            <Border Background="{DynamicResource SE_GroupHeaderBrush}"
                                    BorderBrush="{DynamicResource SE_SeparatorBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="10,8">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"
                                               Foreground="{DynamicResource SE_ForegroundBrush}"/>
                                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap"
                                               FontSize="11" Opacity="0.65" Margin="0,3,0,0"
                                               Foreground="{DynamicResource SE_ForegroundBrush}"/>
                                </StackPanel>
                            </Border>

                            <!-- Metadata grid -->
                            <Border BorderBrush="{DynamicResource SE_SeparatorBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="10,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="20"/>
                                        <RowDefinition Height="20"/>
                                        <RowDefinition Height="20"/>
                                        <RowDefinition Height="20"/>
                                        <RowDefinition Height="20"/>
                                        <RowDefinition Height="20"/>
                                        <RowDefinition Height="20"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Version"   Style="{StaticResource MetaLabel}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Version}"          Style="{StaticResource MetaValue}"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Author"    Style="{StaticResource MetaLabel}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Author}"           Style="{StaticResource MetaValue}"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Category"  Style="{StaticResource MetaLabel}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Category}"         Style="{StaticResource MetaValue}"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Platform"  Style="{StaticResource MetaLabel}"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Platform}"         Style="{StaticResource MetaValue}"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Editor"    Style="{StaticResource MetaLabel}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding PreferredEditor}"  Style="{StaticResource MetaValue}"/>

                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Diff"      Style="{StaticResource MetaLabel}"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding DiffMode}"         Style="{StaticResource MetaValue}"/>

                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Status"    Style="{StaticResource MetaLabel}"/>
                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding LoadStatusDisplay}" Style="{StaticResource MetaValue}"/>
                                </Grid>
                            </Border>

                            <!-- Extensions -->
                            <Border BorderBrush="{DynamicResource SE_SeparatorBrush}"
                                    BorderThickness="0,0,0,1" Padding="10,6">
                                <StackPanel>
                                    <TextBlock Text="Extensions" Style="{StaticResource MetaLabel}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding ExtensionsDisplay}"
                                               FontSize="11" FontFamily="Consolas" TextWrapping="Wrap"
                                               Foreground="{DynamicResource SE_AccentBrush}"/>
                                </StackPanel>
                            </Border>

                            <!-- Quality score -->
                            <Border BorderBrush="{DynamicResource SE_SeparatorBrush}"
                                    BorderThickness="0,0,0,1" Padding="10,6">
                                <StackPanel>
                                    <TextBlock Text="Quality Score" Style="{StaticResource MetaLabel}" Margin="0,0,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ProgressBar Grid.Column="0" Value="{Binding QualityScore}"
                                                     Minimum="0" Maximum="100" Height="4"
                                                     Background="{DynamicResource SE_SearchBoxBrush}"
                                                     VerticalAlignment="Center" BorderThickness="0">
                                            <ProgressBar.Style>
                                                <Style TargetType="ProgressBar">
                                                    <Setter Property="Foreground" Value="{DynamicResource SE_AccentBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding QualityScore}" Value="0">
                                                            <Setter Property="Foreground" Value="{DynamicResource SE_ValidationErrorBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ProgressBar.Style>
                                        </ProgressBar>
                                        <TextBlock Grid.Column="1" Margin="8,0,0,0" FontSize="11"
                                                   Text="{Binding QualityScore, StringFormat={}{0}/100}"
                                                   Foreground="{DynamicResource SE_ForegroundBrush}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Detection + Blocks -->
                            <Border BorderBrush="{DynamicResource SE_SeparatorBrush}"
                                    BorderThickness="0,0,0,1" Padding="10,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="20"/>
                                        <RowDefinition Height="20"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Detection" Style="{StaticResource MetaLabel}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DetectionRulesSummary}" Style="{StaticResource MetaValue}"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Blocks"    Style="{StaticResource MetaLabel}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding BlockCount}"            Style="{StaticResource MetaValue}"/>
                                </Grid>
                            </Border>

                            <!-- Load failure card -->
                            <Border Margin="10,8,10,4" Padding="8,6" CornerRadius="3"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource Panel_WarningBorderBrush}"
                                    Background="{DynamicResource Panel_WarningBackgroundBrush}"
                                    Visibility="{Binding IsLoadFailure, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                   Foreground="{DynamicResource Panel_WarningTextBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Load Error" FontWeight="SemiBold" FontSize="11"
                                                   Foreground="{DynamicResource Panel_WarningTextBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding FailureReason}" TextWrapping="Wrap" FontSize="11"
                                               Foreground="{DynamicResource SE_ForegroundBrush}"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ════════ Tab 2: References ════════ -->
                <TabItem Header="References">
                    <TabItem.Style>
                        <Style TargetType="TabItem" BasedOn="{StaticResource WE_DetailTabItem}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasReferences}" Value="False">
                                    <Setter Property="IsEnabled" Value="False"/>
                                    <Setter Property="Opacity"   Value="0.4"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TabItem.Style>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="10,8">

                            <!-- Specifications -->
                            <TextBlock Text="Specifications" Style="{StaticResource MetaLabel}" Margin="0,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding SpecificationsDisplay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,3"
                                                   Foreground="{DynamicResource SE_AccentBrush}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Web Links -->
                            <TextBlock Text="Web Links" Style="{StaticResource MetaLabel}" Margin="0,10,0,6"/>
                            <ItemsControl ItemsSource="{Binding WebLinksDisplay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,3"
                                                   Foreground="{DynamicResource SE_AccentBrush}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ════════ Tab 3: Assertions ════════ -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Assertions"/>
                            <Border CornerRadius="8" Background="{DynamicResource SE_AccentBrush}"
                                    Padding="4,0" Margin="4,0,0,0" VerticalAlignment="Center"
                                    Visibility="{Binding HasAssertions, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding AssertionCount}" FontSize="9"
                                           Foreground="{DynamicResource SE_ForegroundBrush}"/>
                            </Border>
                        </StackPanel>
                    </TabItem.Header>
                    <TabItem.Style>
                        <Style TargetType="TabItem" BasedOn="{StaticResource WE_DetailTabItem}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasAssertions}" Value="False">
                                    <Setter Property="IsEnabled" Value="False"/>
                                    <Setter Property="Opacity"   Value="0.4"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TabItem.Style>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding AssertionsSummary}" Margin="10,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource SE_SeparatorBrush}"
                                            BorderThickness="0,0,0,1" Padding="0,4">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="11"
                                                           Foreground="{DynamicResource SE_ForegroundBrush}"/>
                                                <Border CornerRadius="3" Padding="4,0" Margin="6,0,0,0"
                                                        Background="{DynamicResource Panel_WarningBackgroundBrush}">
                                                    <TextBlock Text="{Binding Severity}" FontSize="9"
                                                               Foreground="{DynamicResource Panel_WarningTextBrush}"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Expression}" FontFamily="Consolas" FontSize="10"
                                                       Foreground="{DynamicResource SE_AccentBrush}"
                                                       TextWrapping="Wrap" Margin="0,2,0,0"/>
                                            <TextBlock Text="{Binding Message}" FontSize="10" Opacity="0.7"
                                                       Foreground="{DynamicResource SE_ForegroundBrush}"
                                                       TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </TabItem>

                <!-- ════════ Tab 4: AI Hints ════════ -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="AI Hints"/>
                            <Border CornerRadius="8" Background="{DynamicResource SE_AccentBrush}"
                                    Padding="4,0" Margin="4,0,0,0" VerticalAlignment="Center"
                                    Visibility="{Binding HasAiHints, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding AiHintCount}" FontSize="9"
                                           Foreground="{DynamicResource SE_ForegroundBrush}"/>
                            </Border>
                        </StackPanel>
                    </TabItem.Header>
                    <TabItem.Style>
                        <Style TargetType="TabItem" BasedOn="{StaticResource WE_DetailTabItem}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasAiHints}" Value="False">
                                    <Setter Property="IsEnabled" Value="False"/>
                                    <Setter Property="Opacity"   Value="0.4"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TabItem.Style>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="10,8">

                            <!-- Analysis context -->
                            <TextBlock Text="Analysis Context" Style="{StaticResource MetaLabel}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding AiAnalysisContext}" FontSize="11" TextWrapping="Wrap"
                                       Foreground="{DynamicResource SE_ForegroundBrush}" Margin="0,0,0,10"/>

                            <!-- Known vulnerabilities -->
                            <TextBlock Text="Known Vulnerabilities" Style="{StaticResource MetaLabel}" Margin="0,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding AiVulnerabilities}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                            <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                       Foreground="{DynamicResource Panel_WarningTextBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBlock Text="{Binding}" FontSize="11" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource SE_ForegroundBrush}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ════════ Tab 5: JSON ════════ -->
                <TabItem Style="{StaticResource WE_DetailTabItem}" Header="JSON"
                         GotFocus="OnJsonTabGotFocus">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                        <TextBox x:Name="JsonTextBox"
                                 Text="{Binding RawJson, Mode=OneWay}"
                                 IsReadOnly="True"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FontFamily="Consolas"
                                 FontSize="11"
                                 Foreground="{DynamicResource SE_ForegroundBrush}"
                                 TextWrapping="NoWrap"
                                 Padding="8,6"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Disabled"
                                 HorizontalScrollBarVisibility="Disabled"/>
                    </ScrollViewer>
                </TabItem>

            </TabControl>
        </Grid>
    </Grid>
</UserControl>
