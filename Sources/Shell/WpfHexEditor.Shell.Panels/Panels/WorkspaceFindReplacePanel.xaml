<UserControl x:Class="WpfHexEditor.Shell.Panels.Panels.WorkspaceFindReplacePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svc="clr-namespace:WpfHexEditor.Shell.Panels.Services"
             Background="{DynamicResource ERR_BackgroundBrush}"
             Foreground="{DynamicResource ERR_ForegroundBrush}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <svc:ShellPanelsLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="WFR_ActionButton" TargetType="Button">
                <Setter Property="Background"   Value="{DynamicResource InfoBar_ButtonBackgroundBrush}"/>
                <Setter Property="Foreground"   Value="{DynamicResource InfoBar_ButtonForegroundBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor"       Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="3"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{DynamicResource InfoBar_ButtonHoverBackgroundBrush}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="22"/>
        </Grid.RowDefinitions>

        <!-- ── Input area ─────────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="4,4,4,2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="{StaticResource WorkspaceFindReplace_FindLabel}"
                       VerticalAlignment="Center" FontSize="11" Margin="0,0,4,0"/>
            <TextBox   x:Name="FindBox"
                       Grid.Row="0" Grid.Column="1"
                       FontSize="11" Padding="3,2"
                       KeyDown="OnFindBoxKeyDown"/>
            <Button    x:Name="FindAllBtn"
                       Grid.Row="0" Grid.Column="2"
                       Style="{StaticResource WFR_ActionButton}"
                       Content="{StaticResource WorkspaceFindReplace_FindAll}"
                       Padding="8,2" Margin="4,0,0,0" FontSize="11"
                       Click="OnFindAllClick"/>

            <TextBlock Grid.Row="2" Grid.Column="0"
                       Text="{StaticResource WorkspaceFindReplace_ReplaceLabel}"
                       VerticalAlignment="Center" FontSize="11" Margin="0,0,4,0"/>
            <TextBox   x:Name="ReplaceBox"
                       Grid.Row="2" Grid.Column="1"
                       FontSize="11" Padding="3,2"/>
            <Button    x:Name="ReplaceAllBtn"
                       Grid.Row="2" Grid.Column="2"
                       Style="{StaticResource WFR_ActionButton}"
                       Content="{StaticResource WorkspaceFindReplace_ReplaceAll}"
                       Padding="8,2" Margin="4,0,0,0" FontSize="11"
                       Click="OnReplaceAllClick"/>

            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"
                        Orientation="Horizontal">
                <CheckBox x:Name="RegexCheck"
                          Content="{StaticResource WorkspaceFindReplace_OptionRegex}"
                          Margin="0,0,10,0" FontSize="11"/>
                <CheckBox x:Name="MatchCaseCheck"
                          Content="{StaticResource WorkspaceFindReplace_OptionMatchCase}"
                          Margin="0,0,10,0" FontSize="11"/>
                <CheckBox x:Name="WholeWordCheck"
                          Content="{StaticResource WorkspaceFindReplace_OptionWholeWord}"
                          Margin="0,0,10,0" FontSize="11"/>
                <Button   x:Name="ClearBtn"
                          Style="{StaticResource WFR_ActionButton}"
                          Content="&#x2715;" ToolTip="Clear results"
                          Padding="5,0" FontSize="11" Click="OnClearClick"/>
            </StackPanel>
        </Grid>

        <!-- ── Results ────────────────────────────────────────── -->
        <ListView x:Name="ResultsList"
                  Grid.Row="1"
                  FontSize="11"
                  BorderThickness="0"
                  Background="Transparent"
                  Foreground="{DynamicResource ERR_ForegroundBrush}"
                  SelectionChanged="OnResultSelected"
                  MouseDoubleClick="OnResultDoubleClick"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="{StaticResource WorkspaceFindReplace_ColFile}"    Width="160"
                                    DisplayMemberBinding="{Binding FileName}"/>
                    <GridViewColumn Header="{StaticResource WorkspaceFindReplace_ColLine}"    Width="50"
                                    DisplayMemberBinding="{Binding Line}"/>
                    <GridViewColumn Header="{StaticResource WorkspaceFindReplace_ColCol}"     Width="40"
                                    DisplayMemberBinding="{Binding Column}"/>
                    <GridViewColumn Header="{StaticResource WorkspaceFindReplace_ColPreview}" Width="400"
                                    DisplayMemberBinding="{Binding Preview}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- ── Status bar ─────────────────────────────────────── -->
        <StatusBar Grid.Row="2" Padding="4,0"
                   Background="{DynamicResource ERR_BackgroundBrush}">
            <TextBlock x:Name="StatusText"
                       FontSize="11"
                       Text="{StaticResource WorkspaceFindReplace_StatusReady}"
                       VerticalAlignment="Center"/>
        </StatusBar>
    </Grid>
</UserControl>
