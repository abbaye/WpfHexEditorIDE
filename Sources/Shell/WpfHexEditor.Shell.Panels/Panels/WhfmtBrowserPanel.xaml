<UserControl x:Class="WpfHexEditor.Shell.Panels.Panels.WhfmtBrowserPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfHexEditor.Shell.Panels.ViewModels"
             Background="{DynamicResource SE_BackgroundBrush}"
             Foreground="{DynamicResource SE_ForegroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- ── Toolbar icon button ── -->
        <Style x:Key="WE_IconButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="24"/>
            <Setter Property="Height"          Value="24"/>
            <Setter Property="Padding"         Value="4"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground"      Value="{DynamicResource SE_ForegroundBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="2" SnapsToDevicePixels="True"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Panel_ItemHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WE_ToggleButton" TargetType="ToggleButton">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="24"/>
            <Setter Property="Height"          Value="24"/>
            <Setter Property="Padding"         Value="4"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground"      Value="{DynamicResource SE_ForegroundBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="2" SnapsToDevicePixels="True"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Panel_ItemHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SE_AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── TreeViewItem style ── -->
        <Style TargetType="TreeViewItem">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="Padding"                    Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle"           Value="{x:Null}"/>
            <Setter Property="IsExpanded"                 Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <Border x:Name="RowBg" Background="Transparent" CornerRadius="2" Margin="0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton x:Name="Expander" Grid.Column="0"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  Width="16" Height="16" Margin="0,0,2,0"
                                                  Style="{x:Null}" Background="Transparent" BorderThickness="0"
                                                  Foreground="{DynamicResource SE_ForegroundBrush}"
                                                  Focusable="False" ClickMode="Press">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <TextBlock x:Name="Arrow" Text="▶" FontSize="8"
                                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource SE_ForegroundBrush}"
                                                           Opacity="0.6"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Arrow" Property="Text" Value="▼"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <ContentPresenter Grid.Column="1" x:Name="PART_Header"
                                                      ContentSource="Header"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <ItemsPresenter x:Name="ItemsHost" Margin="18,0,0,0"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowBg" Property="Background" Value="{DynamicResource Panel_ItemSelectedBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="False"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="RowBg" Property="Background" Value="{DynamicResource Panel_ItemHoverBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Category node header ── -->
        <DataTemplate x:Key="CategoryHeaderTemplate" DataType="{x:Type vm:WhfmtCategoryNodeVm}">
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="{Binding Name}"
                           FontWeight="SemiBold" FontSize="12"
                           Foreground="{DynamicResource SE_ForegroundBrush}"/>
                <Border CornerRadius="8"
                        Background="{DynamicResource SE_AccentBrush}"
                        Padding="5,0" Margin="6,0,0,0" VerticalAlignment="Center" Opacity="0.7">
                    <TextBlock Text="{Binding VisibleCount}" FontSize="10"
                               Foreground="{DynamicResource SE_ForegroundBrush}"/>
                </Border>
                <TextBlock Text="⚠" Margin="4,0,0,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource SE_ModifiedIndicatorBrush}"
                           ToolTip="One or more formats failed to load"
                           Visibility="{Binding HasFailures, Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>
        </DataTemplate>

        <!-- ── Format item row ── -->
        <DataTemplate x:Key="FormatItemTemplate" DataType="{x:Type vm:WhfmtFormatItemVm}">
            <Grid Margin="2,2" Height="32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Name}" FontSize="12"
                               Foreground="{DynamicResource SE_ForegroundBrush}"/>
                    <TextBlock Text="{Binding ExtensionsDisplay}" FontSize="10"
                               Foreground="{DynamicResource SE_ForegroundBrush}" Opacity="0.55"
                               Visibility="{Binding ExtensionsDisplay, Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>

                <!-- Quality / failure badge -->
                <Border Grid.Column="1" CornerRadius="3" Margin="4,0" Padding="4,1" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource SE_AccentBrush}"/>
                            <Setter Property="Opacity"    Value="0.6"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoadFailure}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource SE_ModifiedIndicatorBrush}"/>
                                    <Setter Property="Opacity"    Value="0.5"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock FontSize="10" Foreground="{DynamicResource SE_ForegroundBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding QualityScore, StringFormat={}{0}}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoadFailure}" Value="True">
                                        <Setter Property="Text" Value="⚠"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>

                <!-- User source badge -->
                <Border Grid.Column="2" CornerRadius="3" Padding="4,1" VerticalAlignment="Center"
                        Background="{DynamicResource SE_SelectionBorderBrush}" Opacity="0.6"
                        Visibility="{Binding IsUserFormat, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="User" FontSize="9"
                               Foreground="{DynamicResource SE_ForegroundBrush}"/>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- ── Context menu ── -->
        <ContextMenu x:Key="FormatItemContextMenu"
                     Background="{DynamicResource SE_BackgroundBrush}"
                     Foreground="{DynamicResource SE_ForegroundBrush}">
            <MenuItem Header="Open"               Command="{Binding OpenCommand}"/>
            <MenuItem Header="Open as Read-Only"  Command="{Binding OpenReadOnlyCommand}"/>
            <Separator/>
            <MenuItem Header="Export to File…"    Command="{Binding ExportToFileCommand}"/>
            <MenuItem Header="View JSON"          Command="{Binding ViewJsonCommand}"/>
            <MenuItem Header="Copy Path"          Command="{Binding CopyPathCommand}"/>
            <Separator/>
            <MenuItem Header="Delete"             Command="{Binding DeleteCommand}"/>
            <MenuItem Header="Reveal in Explorer" Command="{Binding RevealInExplorerCommand}"/>
        </ContextMenu>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Search bar -->
            <RowDefinition Height="Auto"/>   <!-- Toolbar -->
            <RowDefinition Height="*"/>      <!-- Main content -->
            <RowDefinition Height="Auto"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ================================================================ -->
        <!-- Search bar                                                        -->
        <!-- ================================================================ -->
        <Border Grid.Row="0" Background="{DynamicResource SE_SearchBoxBrush}"
                BorderBrush="{DynamicResource SE_SeparatorBrush}" BorderThickness="0,0,0,1"
                Padding="6,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Background="Transparent"
                         Foreground="{DynamicResource SE_SearchBoxForegroundBrush}"
                         BorderThickness="0" VerticalContentAlignment="Center"
                         ToolTip="Search formats (name, category, extension, author)">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Resources>
                                <VisualBrush x:Key="CueBanner" TileMode="None" Opacity="0.4"
                                             Stretch="None" AlignmentX="Left">
                                    <VisualBrush.Visual>
                                        <TextBlock Text="Search formats…"
                                                   Foreground="{DynamicResource SE_ForegroundBrush}"
                                                   FontStyle="Italic" FontSize="12" Margin="0"/>
                                    </VisualBrush.Visual>
                                </VisualBrush>
                            </Style.Resources>
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background" Value="{StaticResource CueBanner}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
                <TextBlock Grid.Column="1" Text="✕" Margin="4,0,0,0"
                           Cursor="Hand" VerticalAlignment="Center" Opacity="0.5"
                           Foreground="{DynamicResource SE_ForegroundBrush}"
                           Visibility="{Binding SearchText, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding ClearSearchCommand}"/>
                    </TextBlock.InputBindings>
                </TextBlock>
            </Grid>
        </Border>

        <!-- ================================================================ -->
        <!-- Toolbar                                                           -->
        <!-- ================================================================ -->
        <Border Grid.Row="1" Background="{DynamicResource SE_ToolbarBrush}"
                BorderBrush="{DynamicResource SE_SeparatorBrush}" BorderThickness="0,0,0,1">
            <WrapPanel Margin="4,2" Orientation="Horizontal">
                <!-- View toggle -->
                <ToggleButton Style="{StaticResource WE_ToggleButton}"
                              IsChecked="{Binding IsTreeView}"
                              ToolTip="Tree view (group by category)">
                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                </ToggleButton>

                <Separator Width="1" Margin="3,3" Background="{DynamicResource SE_SeparatorBrush}"/>

                <!-- Built-in / User toggles -->
                <ToggleButton Style="{StaticResource WE_ToggleButton}"
                              IsChecked="{Binding ShowBuiltIns}"
                              ToolTip="Show built-in formats" Width="Auto" Padding="6,4">
                    <TextBlock Text="Built-in" FontSize="11"
                               Foreground="{DynamicResource SE_ForegroundBrush}"/>
                </ToggleButton>
                <ToggleButton Style="{StaticResource WE_ToggleButton}"
                              IsChecked="{Binding ShowUserFormats}"
                              ToolTip="Show user formats" Width="Auto" Padding="6,4">
                    <TextBlock Text="User" FontSize="11"
                               Foreground="{DynamicResource SE_ForegroundBrush}"/>
                </ToggleButton>

                <Separator Width="1" Margin="3,3" Background="{DynamicResource SE_SeparatorBrush}"/>

                <!-- Actions -->
                <Button Style="{StaticResource WE_IconButton}"
                        Command="{Binding RefreshCommand}" ToolTip="Refresh catalog">
                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                </Button>
                <Button Style="{StaticResource WE_IconButton}"
                        Command="{Binding AddFormatCommand}" ToolTip="Add format file…">
                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                </Button>
                <Button Style="{StaticResource WE_IconButton}"
                        Command="{Binding OpenFolderCommand}" ToolTip="Open user formats folder">
                    <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                </Button>

                <Separator Width="1" Margin="3,3" Background="{DynamicResource SE_SeparatorBrush}"/>

                <!-- Watch toggle -->
                <ToggleButton Style="{StaticResource WE_ToggleButton}"
                              IsChecked="{Binding IsWatching, Mode=OneWay}"
                              Command="{Binding ToggleWatchCommand}"
                              ToolTip="Watch folder for changes (hot reload)">
                    <TextBlock Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                </ToggleButton>
            </WrapPanel>
        </Border>

        <!-- ================================================================ -->
        <!-- Main: list + detail                                               -->
        <!-- ================================================================ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="120"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="230" MinWidth="180"/>
            </Grid.ColumnDefinitions>

            <!-- TreeView (grouped) -->
            <TreeView x:Name="FormatTree" Grid.Column="0"
                      ItemsSource="{Binding CategoryNodes}"
                      Background="{DynamicResource SE_BackgroundBrush}"
                      BorderThickness="0"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                      SelectedItemChanged="OnTreeSelectedItemChanged"
                      MouseDoubleClick="OnTreeDoubleClick">
                <TreeView.Style>
                    <Style TargetType="TreeView">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsTreeView}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TreeView.Style>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate DataType="{x:Type vm:WhfmtCategoryNodeVm}"
                                              ItemsSource="{Binding Items}">
                        <ContentPresenter Content="{Binding}"
                                          ContentTemplate="{StaticResource CategoryHeaderTemplate}"/>
                        <HierarchicalDataTemplate.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:WhfmtFormatItemVm}">
                                <ContentPresenter Content="{Binding}"
                                                  ContentTemplate="{StaticResource FormatItemTemplate}"
                                                  ContextMenu="{StaticResource FormatItemContextMenu}"/>
                            </DataTemplate>
                        </HierarchicalDataTemplate.ItemTemplate>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

            <!-- Flat ListView -->
            <ListView x:Name="FormatList" Grid.Column="0"
                      ItemsSource="{Binding FlatItems}"
                      ItemTemplate="{StaticResource FormatItemTemplate}"
                      Background="{DynamicResource SE_BackgroundBrush}"
                      BorderThickness="0"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                      SelectionChanged="OnListSelectionChanged"
                      MouseDoubleClick="OnListDoubleClick">
                <ListView.Style>
                    <Style TargetType="ListView">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsTreeView}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListView.Style>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background"   Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="ContextMenu"  Value="{StaticResource FormatItemContextMenu}"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Panel_ItemHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Panel_ItemSelectedBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          Background="{DynamicResource SE_SeparatorBrush}"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- Detail panel -->
            <local:WhfmtFormatDetailPanel x:Name="DetailPanel" Grid.Column="2"
                                          DataContext="{Binding Detail}"
                                          xmlns:local="clr-namespace:WpfHexEditor.Shell.Panels.Panels"/>
        </Grid>

        <!-- ================================================================ -->
        <!-- Status bar                                                        -->
        <!-- ================================================================ -->
        <Border Grid.Row="3" Background="{DynamicResource SE_ToolbarBrush}"
                BorderBrush="{DynamicResource SE_SeparatorBrush}" BorderThickness="0,1,0,0"
                Padding="8,2">
            <TextBlock Text="{Binding StatusText}" FontSize="11"
                       Foreground="{DynamicResource SE_ForegroundBrush}" Opacity="0.7"/>
        </Border>
    </Grid>
</UserControl>
