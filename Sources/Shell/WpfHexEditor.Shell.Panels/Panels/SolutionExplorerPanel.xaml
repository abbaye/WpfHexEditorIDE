<UserControl x:Class="WpfHexEditor.Shell.Panels.SolutionExplorerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfHexEditor.Shell.Panels.ViewModels"
             xmlns:sa="clr-namespace:WpfHexEditor.Core.SourceAnalysis.Models;assembly=WpfHexEditor.Core.SourceAnalysis"
             Background="{DynamicResource SE_BackgroundBrush}"
             xmlns:svc="clr-namespace:WpfHexEditor.Shell.Panels.Services">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <svc:ShellPanelsLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>


    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ── Small toolbar icon button ── -->
        <Style x:Key="SE_IconButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="22"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="Padding"         Value="3"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="2" SnapsToDevicePixels="True"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Panel_ItemHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── TreeViewItem — VS2026 style ── -->
        <Style TargetType="TreeViewItem">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="Padding"                    Value="0"/>
            <Setter Property="IsExpanded"                 Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle"           Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <!-- Row -->
                            <Grid x:Name="RowGrid" Height="22">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Hover/selected background -->
                                <Border x:Name="RowBg" Grid.ColumnSpan="2"
                                        Background="Transparent" SnapsToDevicePixels="True"/>

                                <!-- Blue accent bar (selected only) -->
                                <Border x:Name="Accent" Grid.Column="0"
                                        Background="{DynamicResource SE_SelectionBorderBrush}"
                                        Visibility="Collapsed" SnapsToDevicePixels="True"/>

                                <!-- Content column -->
                                <DockPanel Grid.Column="1">
                                    <!-- Expand/Collapse arrow -->
                                    <ToggleButton x:Name="Expander"
                                                  DockPanel.Dock="Left"
                                                  Width="14" Height="14"
                                                  IsChecked="{Binding IsExpanded,
                                                      RelativeSource={RelativeSource AncestorType=TreeViewItem}}"
                                                  Focusable="False">
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Grid Background="Transparent" Width="14" Height="14">
                                                                <Path x:Name="Ar"
                                                                      Data="M 4,3 L 11,7 L 4,11 Z"
                                                                      Fill="{DynamicResource SE_ForegroundBrush}"
                                                                      Stretch="Uniform" Margin="3"
                                                                      RenderTransformOrigin="0.5,0.5">
                                                                    <Path.RenderTransform>
                                                                        <RotateTransform Angle="0"/>
                                                                    </Path.RenderTransform>
                                                                </Path>
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="Ar" Property="RenderTransform">
                                                                        <Setter.Value>
                                                                            <RotateTransform Angle="90"/>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ToggleButton.Style>
                                    </ToggleButton>

                                    <!-- Node header -->
                                    <ContentPresenter x:Name="PART_Header"
                                                      ContentSource="Header"
                                                      HorizontalAlignment="Left"
                                                      VerticalAlignment="Center"
                                                      Margin="2,0,4,0"/>
                                </DockPanel>
                            </Grid>

                            <!-- Children -->
                            <ItemsPresenter x:Name="ItemsHost" Margin="14,0,0,0"/>
                        </StackPanel>

                        <ControlTemplate.Triggers>
                            <!-- Hover: direct property trigger — IsMouseOver is driven by the WPF input
                                 system, not by INotifyPropertyChanged, so only a Trigger (not a DataTrigger)
                                 reliably fires on mouse-enter/leave. -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowBg" Property="Background" Value="{DynamicResource Panel_ItemHoverBrush}"/>
                            </Trigger>
                            <!-- Selection visual driven by ViewModel.IsSelected — decoupled from WPF's
                                 single-select TreeViewItem.IsSelected. Declared AFTER hover so it takes
                                 priority when both conditions are true (selected + hovered). -->
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="RowBg"  Property="Background" Value="{DynamicResource Panel_ItemSelectedBrush}"/>
                                <Setter TargetName="Accent" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <Trigger Property="HasItems"  Value="False">
                                <Setter TargetName="Expander"   Property="Visibility" Value="Hidden"/>
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <!-- Hide row + children when node does not match the active search.
                                 ControlTemplate.Triggers (not Style.Triggers) is required here —
                                 Style.Triggers Visibility setter does not reliably fire for
                                 TreeViewItem containers in a virtualised WPF tree. -->
                            <DataTrigger Binding="{Binding IsSearchVisible}" Value="False">
                                <Setter TargetName="RowGrid"   Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TreeView base -->
        <Style TargetType="TreeView">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0,4"/>
        </Style>

        <!-- Icon glyph -->
        <Style x:Key="NodeIcon" TargetType="TextBlock">
            <Setter Property="FontFamily"        Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="0,0,5,0"/>
        </Style>

        <!-- Label -->
        <Style x:Key="NodeLabel" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="{DynamicResource SE_ForegroundBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming"      Value="CharacterEllipsis"/>
        </Style>

        <!-- ── Show All Files toggle button ── -->
        <Style x:Key="SE_IconToggleButton" TargetType="ToggleButton">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="22"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="Padding"         Value="3"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="2" SnapsToDevicePixels="True"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Panel_ItemHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Panel_ItemSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Build spinner storyboard — same pattern as Unit Testing panel -->
        <Storyboard x:Key="SE_SpinStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                             From="0" To="360" Duration="0:0:1.2"/>
        </Storyboard>

        <!-- DataTemplates -->

        <DataTemplate DataType="{x:Type vm:SolutionNodeVm}">
            <Grid>
                <!-- Normal display (IsEditing = false) -->
                <StackPanel x:Name="SolutionDisplayPanel" Orientation="Horizontal">
                    <TextBlock Style="{StaticResource NodeIcon}" Text="&#xE8B7;" Foreground="#E8B25A"/>
                    <TextBlock Style="{StaticResource NodeLabel}" Text="{Binding Label}" FontWeight="SemiBold"/>
                </StackPanel>
                <!-- Inline rename TextBox (IsEditing = true) -->
                <TextBox x:Name="SolutionInlineEditBox"
                         Visibility="Collapsed"
                         Text="{Binding EditingName, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         MinWidth="100"
                         Background="{DynamicResource SE_SearchBoxBrush}"
                         Foreground="{DynamicResource SE_ForegroundBrush}"
                         BorderBrush="{DynamicResource SE_SelectionBorderBrush}"
                         BorderThickness="1"
                         Padding="2,1"
                         KeyDown="OnSolutionInlineEditKeyDown"
                         LostKeyboardFocus="OnSolutionInlineEditLostFocus"/>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                    <Setter TargetName="SolutionDisplayPanel"  Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="SolutionInlineEditBox" Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ProjectNodeVm}">
            <Grid>
                <!-- Normal display (IsEditing = false) -->
                <StackPanel x:Name="ProjectDisplayPanel" Orientation="Horizontal">
                    <TextBlock x:Name="ProjectIcon"
                               Style="{StaticResource NodeIcon}"
                               Text="{Binding Icon}"
                               Foreground="{Binding LanguageColor}"/>
                    <TextBlock x:Name="BuildSpinner"
                               Style="{StaticResource NodeIcon}"
                               Text="&#xE8A2;"
                               Foreground="{DynamicResource SE_ForegroundBrush}"
                               Visibility="Collapsed"
                               RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <RotateTransform/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <!-- x:Name required for DataTrigger Setter targeting -->
                    <TextBlock x:Name="ProjectNameLabel"
                               Style="{StaticResource NodeLabel}"
                               Text="{Binding DisplayName}"
                               FontWeight="SemiBold"/>
                    <!-- Build-dirty indicator: small orange dot, hidden when clean -->
                    <TextBlock x:Name="DirtyDot"
                               Text="&#x25CF;"
                               FontSize="7"
                               Foreground="#E07020"
                               Margin="3,0,0,0"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"
                               ToolTip="{DynamicResource SolutionExplorer_BuildDirtyIndicator}" />
                </StackPanel>
                <!-- Inline rename TextBox (IsEditing = true) -->
                <TextBox x:Name="ProjectInlineEditBox"
                         Visibility="Collapsed"
                         Text="{Binding EditingName, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         MinWidth="100"
                         Background="{DynamicResource SE_SearchBoxBrush}"
                         Foreground="{DynamicResource SE_ForegroundBrush}"
                         BorderBrush="{DynamicResource SE_SelectionBorderBrush}"
                         BorderThickness="1"
                         Padding="2,1"
                         KeyDown="OnProjectInlineEditKeyDown"
                         LostKeyboardFocus="OnProjectInlineEditLostFocus"/>
            </Grid>
            <DataTemplate.Triggers>
                <!-- Startup project → bold (VS behaviour) -->
                <DataTrigger Binding="{Binding IsStartup}" Value="True">
                    <Setter TargetName="ProjectNameLabel" Property="FontWeight" Value="Bold"/>
                </DataTrigger>
                <!-- Build-dirty → show orange dot -->
                <DataTrigger Binding="{Binding IsBuildDirty}" Value="True">
                    <Setter TargetName="DirtyDot" Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <!-- Building → swap project icon for spinning glyph -->
                <DataTrigger Binding="{Binding IsBuilding}" Value="True">
                    <Setter TargetName="ProjectIcon"  Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="BuildSpinner" Property="Visibility" Value="Visible"/>
                    <DataTrigger.EnterActions>
                        <BeginStoryboard x:Name="SE_SpinBegin"
                                         Storyboard="{StaticResource SE_SpinStoryboard}"/>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="SE_SpinBegin"/>
                    </DataTrigger.ExitActions>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                    <Setter TargetName="ProjectDisplayPanel"  Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="ProjectInlineEditBox" Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:FolderNodeVm}">
            <Grid>
                <!-- Normal display (IsEditing = false) -->
                <StackPanel x:Name="FolderDisplayPanel" Orientation="Horizontal"
                            ToolTip="{DynamicResource SolutionExplorer_SolutionFolderTooltip}">
                    <TextBlock x:Name="FolderIcon" Style="{StaticResource NodeIcon}"
                               Text="&#xE8D5;" Foreground="#C4A34A"/>
                    <TextBlock Style="{StaticResource NodeLabel}" Text="{Binding DisplayName}"/>
                </StackPanel>
                <!-- Inline rename TextBox (IsEditing = true) -->
                <TextBox x:Name="FolderInlineEditBox"
                         Visibility="Collapsed"
                         Text="{Binding EditingName, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         MinWidth="100"
                         Background="{DynamicResource SE_SearchBoxBrush}"
                         Foreground="{DynamicResource SE_ForegroundBrush}"
                         BorderBrush="{DynamicResource SE_SelectionBorderBrush}"
                         BorderThickness="1"
                         Padding="2,1"
                         KeyDown="OnFolderInlineEditKeyDown"
                         LostKeyboardFocus="OnFolderInlineEditLostFocus"/>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                    <Setter TargetName="FolderDisplayPanel"  Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="FolderInlineEditBox" Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <!-- Physical folder: yellow icon + distinct tooltip -->
                <DataTrigger Binding="{Binding IsPhysicallyBacked}" Value="True">
                    <Setter TargetName="FolderIcon"          Property="Foreground" Value="#F5C518"/>
                    <Setter TargetName="FolderDisplayPanel"  Property="ToolTip"    Value="{DynamicResource SolutionExplorer_PhysicalFolderTooltip}"/>
                </DataTrigger>
                <!-- Properties folder: VS-like gear icon (declared after IsPhysicallyBacked so it takes precedence) -->
                <DataTrigger Binding="{Binding IsPropertiesFolder}" Value="True">
                    <Setter TargetName="FolderIcon"         Property="Text"       Value="&#xE713;"/>
                    <Setter TargetName="FolderIcon"         Property="Foreground" Value="#9B9B9B"/>
                    <Setter TargetName="FolderDisplayPanel" Property="ToolTip"    Value="{DynamicResource SolutionExplorer_PropertiesFolderTooltip}"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- ── Solution Folder node (VS-like, holds projects) ── -->
        <DataTemplate DataType="{x:Type vm:SolutionFolderNodeVm}">
            <Grid>
                <!-- Normal display -->
                <StackPanel x:Name="SolFolderDisplayPanel" Orientation="Horizontal"
                            ToolTip="{DynamicResource SolutionExplorer_SolutionFolderTooltip}">
                    <TextBlock Style="{StaticResource NodeIcon}" Text="&#xE8B7;" Foreground="#DCA95A"/>
                    <TextBlock Style="{StaticResource NodeLabel}" Text="{Binding DisplayName}"/>
                </StackPanel>
                <!-- Inline rename TextBox -->
                <TextBox x:Name="SolutionFolderInlineEditBox"
                         Visibility="Collapsed"
                         Text="{Binding EditingName, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         MinWidth="100"
                         Background="{DynamicResource SE_SearchBoxBrush}"
                         Foreground="{DynamicResource SE_ForegroundBrush}"
                         BorderBrush="{DynamicResource SE_SelectionBorderBrush}"
                         BorderThickness="1"
                         Padding="2,1"
                         KeyDown="OnSolutionFolderInlineEditKeyDown"
                         LostKeyboardFocus="OnSolutionFolderInlineEditLostFocus"/>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                    <Setter TargetName="SolFolderDisplayPanel"       Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="SolutionFolderInlineEditBox" Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- Solution folder loose file items (README.md, .editorconfig, etc.) -->
        <DataTemplate DataType="{x:Type vm:SolutionFileItemNodeVm}">
            <StackPanel Orientation="Horizontal"
                        ToolTip="{Binding AbsolutePath}">
                <TextBlock Style="{StaticResource NodeIcon}" Text="&#xE8A5;" Foreground="{DynamicResource SE_ForegroundBrush}" Opacity="0.7"/>
                <TextBlock Style="{StaticResource NodeLabel}" Text="{Binding DisplayName}"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:FileNodeVm}">
            <Grid>
                <!-- Normal display (IsEditing = false) -->
                <StackPanel x:Name="DisplayPanel" Orientation="Horizontal">
                    <TextBlock Style="{StaticResource NodeIcon}" Text="{Binding Icon}"
                               Foreground="{DynamicResource SE_ForegroundBrush}"/>
                    <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource NodeLabel}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDefaultTbl}" Value="True">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <!-- Modified dot -->
                    <TextBlock Text=" &#x25CF;" FontSize="9"
                               Foreground="{DynamicResource SE_ModifiedIndicatorBrush}"
                               VerticalAlignment="Center"
                               ToolTip="{DynamicResource SolutionExplorer_UnsavedModifications}"
                               Visibility="{Binding IsModified, Converter={StaticResource BoolToVis}}"/>
                    <!-- External-file badge -->
                    <TextBlock x:Name="ExternalBadge"
                               Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                               Foreground="#E8A419"
                               VerticalAlignment="Center" Margin="3,0,0,0"
                               ToolTip="{DynamicResource SolutionExplorer_ExternalFileIndicator}"
                               Visibility="Collapsed"/>
                    <!-- Externally-modified warning badge -->
                    <TextBlock x:Name="ExternalModBadge"
                               Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                               Foreground="{DynamicResource SE_ModifiedIndicatorBrush}"
                               VerticalAlignment="Center" Margin="2,0,0,0"
                               ToolTip="{DynamicResource SolutionExplorer_ExternalModIndicator}"
                               Visibility="Collapsed"/>
                </StackPanel>

                <!-- Inline rename TextBox (IsEditing = true) -->
                <TextBox x:Name="InlineEditBox"
                         Visibility="Collapsed"
                         Text="{Binding EditingName, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         MinWidth="100"
                         Background="{DynamicResource SE_SearchBoxBrush}"
                         Foreground="{DynamicResource SE_ForegroundBrush}"
                         BorderBrush="{DynamicResource SE_SelectionBorderBrush}"
                         BorderThickness="1"
                         Padding="2,1"
                         KeyDown="OnInlineEditKeyDown"
                         LostKeyboardFocus="OnInlineEditLostFocus"/>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                    <Setter TargetName="DisplayPanel"   Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="InlineEditBox"  Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsExternal}" Value="True">
                    <Setter TargetName="ExternalBadge" Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsModifiedExternally}" Value="True">
                    <Setter TargetName="ExternalModBadge" Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <!-- Pending-cut items (Ctrl+X) are dimmed at 45% opacity, mirroring Visual Studio behaviour -->
                <DataTrigger Binding="{Binding IsPendingCut}" Value="True">
                    <Setter TargetName="DisplayPanel" Property="Opacity" Value="0.45"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:PhysicalFolderNodeVm}">
            <StackPanel x:Name="PhysFolderPanel" Orientation="Horizontal" Opacity="0.45">
                <TextBlock x:Name="PhysFolderIcon" Style="{StaticResource NodeIcon}" Text="&#xE8D5;" Foreground="#F5C518"/>
                <TextBlock Style="{StaticResource NodeLabel}" Text="{Binding DisplayName}"/>
            </StackPanel>
            <DataTemplate.Triggers>
                <!-- Folder has at least one tracked descendant: restore full opacity -->
                <DataTrigger Binding="{Binding IsInProject}" Value="True">
                    <Setter TargetName="PhysFolderPanel" Property="Opacity" Value="1.0"/>
                </DataTrigger>
                <!-- Properties folder: VS-like gear icon -->
                <DataTrigger Binding="{Binding IsPropertiesFolder}" Value="True">
                    <Setter TargetName="PhysFolderIcon" Property="Text"       Value="&#xE713;"/>
                    <Setter TargetName="PhysFolderIcon" Property="Foreground" Value="#9B9B9B"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:PhysicalFileNodeVm}">
            <StackPanel x:Name="PhysFilePanel" Orientation="Horizontal">
                <TextBlock Style="{StaticResource NodeIcon}" Text="{Binding Icon}"
                           Foreground="{DynamicResource SE_ForegroundBrush}"/>
                <TextBlock Style="{StaticResource NodeLabel}" Text="{Binding DisplayName}"/>
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsInProject}" Value="False">
                    <Setter TargetName="PhysFilePanel" Property="Opacity" Value="0.45"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- ── References container (VS-like References group under project) ── -->
        <DataTemplate DataType="{x:Type vm:ReferencesContainerNodeVm}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Style="{StaticResource NodeIcon}" Text="&#xE71D;" Foreground="#9AABB5"/>
                <TextBlock Style="{StaticResource NodeLabel}" Text="{Binding DisplayName}"/>
            </StackPanel>
        </DataTemplate>

        <!-- ── Project reference node (p2p reference inside References) ── -->
        <DataTemplate DataType="{x:Type vm:ProjectReferenceNodeVm}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Style="{StaticResource NodeIcon}" Text="&#xEA3C;" Foreground="#6CA8C4"/>
                <TextBlock Style="{StaticResource NodeLabel}" Text="{Binding DisplayName}"/>
            </StackPanel>
        </DataTemplate>

        <!-- ── Package reference node (NuGet / package inside References) ── -->
        <DataTemplate DataType="{x:Type vm:PackageReferenceNodeVm}">
            <StackPanel Orientation="Horizontal" ToolTip="{Binding Info.Version, StringFormat='Version: {0}', FallbackValue='No version specified'}">
                <TextBlock Style="{StaticResource NodeIcon}" Text="&#xE7B8;" Foreground="#C8A018"/>
                <TextBlock Style="{StaticResource NodeLabel}" Text="{Binding DisplayName}"/>
            </StackPanel>
        </DataTemplate>

        <!-- ── Assembly reference node (<Reference> — BCL or external DLL) ── -->
        <DataTemplate DataType="{x:Type vm:AssemblyReferenceNodeVm}">
            <StackPanel Orientation="Horizontal" ToolTip="{Binding Tooltip}">
                <TextBlock Style="{StaticResource NodeIcon}"
                           Text="{Binding Icon}"
                           Foreground="{DynamicResource SE_ForegroundBrush}"/>
                <TextBlock Style="{StaticResource NodeLabel}" Text="{Binding DisplayName}"/>
            </StackPanel>
        </DataTemplate>

        <!-- ── Analyzers container (sub-folder under References) ─────── -->
        <DataTemplate DataType="{x:Type vm:AnalyzersContainerNodeVm}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Style="{StaticResource NodeIcon}" Text="&#xE9D9;" Foreground="#B5CEA8"/>
                <TextBlock Style="{StaticResource NodeLabel}" Text="{Binding DisplayName}"/>
            </StackPanel>
        </DataTemplate>

        <!-- ── Analyzer node (single Roslyn analyzer DLL) ───────────── -->
        <DataTemplate DataType="{x:Type vm:AnalyzerNodeVm}">
            <StackPanel Orientation="Horizontal" ToolTip="{Binding Tooltip}">
                <TextBlock Style="{StaticResource NodeIcon}" Text="&#xE9D9;" Foreground="#B5CEA8"/>
                <TextBlock Style="{StaticResource NodeLabel}" Text="{Binding DisplayName}"/>
            </StackPanel>
        </DataTemplate>

        <!-- ── Changeset companion file (.whchg) ──────────────────────── -->
        <DataTemplate DataType="{x:Type vm:ChangesetNodeVm}">
            <StackPanel Orientation="Horizontal" Opacity="0.7">
                <TextBlock Style="{StaticResource NodeIcon}" Text="{Binding Icon}"
                           Foreground="{DynamicResource SE_ForegroundBrush}"/>
                <TextBlock Style="{StaticResource NodeLabel}" Text="{Binding DisplayName}"
                           FontStyle="Italic"/>
            </StackPanel>
        </DataTemplate>

        <!-- ── Dependent file node (.xaml.cs under .xaml, .Designer.cs under .cs, etc.) ── -->
        <DataTemplate DataType="{x:Type vm:DependentFileNodeVm}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- Normal display -->
                <StackPanel x:Name="DepFilePanel"
                            Grid.Column="0"
                            Orientation="Horizontal"
                            Opacity="0.82">
                    <TextBlock Style="{StaticResource NodeIcon}"
                               Text="&#xE71B;"
                               Foreground="{DynamicResource SE_ForegroundBrush}"
                               FontSize="10"/>
                    <TextBlock Style="{StaticResource NodeLabel}"
                               Text="{Binding DisplayName}"
                               FontStyle="Italic"/>
                </StackPanel>
                <!-- Inline rename TextBox -->
                <TextBox x:Name="DepInlineEditBox"
                         Grid.Column="0"
                         Text="{Binding EditingName, UpdateSourceTrigger=PropertyChanged}"
                         Visibility="Collapsed"
                         MinWidth="120"
                         Background="{DynamicResource SE_SearchBoxBrush}"
                         Foreground="{DynamicResource SE_ForegroundBrush}"
                         BorderBrush="{DynamicResource SE_AccentBrush}"
                         BorderThickness="1"
                         Padding="2,1"
                         FontSize="12"
                         LostFocus="OnDepInlineEditLostFocus"
                         KeyDown="OnDepInlineEditKeyDown"/>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                    <Setter TargetName="DepFilePanel"    Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="DepInlineEditBox" Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- ── Source outline loading sentinel ── -->
        <DataTemplate DataType="{x:Type vm:LoadingNodeVm}">
            <StackPanel Orientation="Horizontal" Opacity="0.55">
                <TextBlock Style="{StaticResource NodeIcon}"
                           Text="&#xE9F5;"
                           Foreground="{DynamicResource SE_ForegroundBrush}"
                           FontSize="11"/>
                <TextBlock Style="{StaticResource NodeLabel}"
                           Text="{DynamicResource SolutionExplorer_LoadingIndicator}"
                           FontStyle="Italic"/>
            </StackPanel>
        </DataTemplate>

        <!-- ── Source type node (class / struct / interface / enum / record) ── -->
        <DataTemplate DataType="{x:Type vm:SourceTypeNodeVm}">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="TypeIcon"
                           Style="{StaticResource NodeIcon}"
                           Text="{Binding Icon}"
                           Foreground="#4FC1FF"/>
                <TextBlock Style="{StaticResource NodeLabel}"
                           Text="{Binding DisplayName}"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="KindBadge"
                           Foreground="{DynamicResource SE_ForegroundBrush}"
                           Opacity="0.55"
                           VerticalAlignment="Center"
                           FontSize="10"
                           Margin="4,0,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Model.Kind}"
                             Value="{x:Static sa:SourceTypeKind.Interface}">
                    <Setter TargetName="TypeIcon" Property="Foreground" Value="#B8D7A3"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Model.Kind}"
                             Value="{x:Static sa:SourceTypeKind.Struct}">
                    <Setter TargetName="TypeIcon"  Property="Foreground" Value="#4EC9B0"/>
                    <Setter TargetName="KindBadge" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="KindBadge" Property="Text"       Value="struct"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Model.Kind}"
                             Value="{x:Static sa:SourceTypeKind.Enum}">
                    <Setter TargetName="TypeIcon" Property="Foreground" Value="#CE9178"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Model.Kind}"
                             Value="{x:Static sa:SourceTypeKind.Record}">
                    <Setter TargetName="TypeIcon"  Property="Foreground" Value="#C586C0"/>
                    <Setter TargetName="KindBadge" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="KindBadge" Property="Text"       Value="record"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Model.Kind}"
                             Value="{x:Static sa:SourceTypeKind.RecordStruct}">
                    <Setter TargetName="TypeIcon"  Property="Foreground" Value="#C586C0"/>
                    <Setter TargetName="KindBadge" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="KindBadge" Property="Text"       Value="record struct"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- ── Source member node (method / property / field / event / constructor) ── -->
        <DataTemplate DataType="{x:Type vm:SourceMemberNodeVm}">
            <StackPanel Orientation="Horizontal" Opacity="0.88">
                <TextBlock x:Name="MemberIcon"
                           Style="{StaticResource NodeIcon}"
                           Text="{Binding Icon}"
                           Foreground="{DynamicResource SE_ForegroundBrush}"
                           FontSize="11"/>
                <TextBlock Style="{StaticResource NodeLabel}"
                           Text="{Binding DisplayName}"/>
                <TextBlock x:Name="StaticBadge"
                           Text=" S"
                           FontSize="8"
                           Foreground="{DynamicResource SE_ForegroundBrush}"
                           Opacity="0.5"
                           VerticalAlignment="Center"
                           Visibility="Collapsed"/>
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Model.Kind}"
                             Value="{x:Static sa:SourceMemberKind.Method}">
                    <Setter TargetName="MemberIcon" Property="Foreground" Value="#C586C0"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Model.Kind}"
                             Value="{x:Static sa:SourceMemberKind.Constructor}">
                    <Setter TargetName="MemberIcon" Property="Foreground" Value="#4EC9B0"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Model.Kind}"
                             Value="{x:Static sa:SourceMemberKind.Property}">
                    <Setter TargetName="MemberIcon" Property="Foreground" Value="#9CDCFE"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Model.Kind}"
                             Value="{x:Static sa:SourceMemberKind.Event}">
                    <Setter TargetName="MemberIcon" Property="Foreground" Value="#DCDCAA"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Model.IsStatic}" Value="True">
                    <Setter TargetName="StaticBadge" Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="{DynamicResource SE_ToolbarBrush}"
                BorderBrush="{DynamicResource SE_SeparatorBrush}"
                BorderThickness="0,0,0,1" Padding="6,3">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <ToggleButton x:Name="ShowAllFilesButton"
                                  Style="{StaticResource SE_IconToggleButton}"
                                  ToolTip="{DynamicResource SolutionExplorer_ShowAllFilesToolTip}"
                                  Click="OnShowAllFiles">
                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                   Foreground="{DynamicResource SE_ForegroundBrush}"/>
                    </ToggleButton>
                    <Button Style="{StaticResource SE_IconButton}" ToolTip="{DynamicResource SolutionExplorer_CollapseAllToolTip}"          Click="OnCollapseAll">
                        <TextBlock Text="&#xF165;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                   Foreground="{DynamicResource SE_ForegroundBrush}"/>
                    </Button>
                    <Button Style="{StaticResource SE_IconButton}" ToolTip="{DynamicResource SolutionExplorer_SyncWithActiveDocToolTip}" Click="OnSyncWithActiveDocument">
                        <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                   Foreground="{DynamicResource SE_ForegroundBrush}"/>
                    </Button>
                    <Button Style="{StaticResource SE_IconButton}" ToolTip="{DynamicResource SolutionExplorer_RefreshToolTip}" Click="OnRefresh">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                   Foreground="{DynamicResource SE_ForegroundBrush}"/>
                    </Button>
                </StackPanel>

                <!-- Sort and Filter dropdowns (DockPanel.Dock="Left" so they appear first) -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <!-- Sort -->
                    <Button Style="{StaticResource SE_IconButton}" ToolTip="{DynamicResource SolutionExplorer_SortToolTip}"
                            Click="OnSortButtonClick" x:Name="SortButton">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="SortContextMenu">
                                <MenuItem Header="{DynamicResource SolutionExplorer_SortNone}"         Tag="None"         Click="OnSortMenuItemClick"/>
                                <MenuItem Header="{DynamicResource SolutionExplorer_SortName}"         Tag="Name"         Click="OnSortMenuItemClick"/>
                                <MenuItem Header="{DynamicResource SolutionExplorer_SortType}"         Tag="Type"         Click="OnSortMenuItemClick"/>
                                <MenuItem Header="{DynamicResource SolutionExplorer_SortDateModified}" Tag="DateModified" Click="OnSortMenuItemClick"/>
                                <MenuItem Header="{DynamicResource SolutionExplorer_SortSize}"         Tag="Size"         Click="OnSortMenuItemClick"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8CB;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                       Foreground="{DynamicResource SE_ForegroundBrush}"/>
                        </StackPanel>
                    </Button>
                    <!-- Filter -->
                    <Button Style="{StaticResource SE_IconButton}" ToolTip="{DynamicResource SolutionExplorer_FilterToolTip}"
                            Click="OnFilterButtonClick" x:Name="FilterButton">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="FilterContextMenu">
                                <MenuItem Header="{DynamicResource SolutionExplorer_FilterAll}"      Tag="All"      Click="OnFilterMenuItemClick"/>
                                <MenuItem Header="{DynamicResource SolutionExplorer_FilterBinary}"   Tag="Binary"   Click="OnFilterMenuItemClick"/>
                                <MenuItem Header="{DynamicResource SolutionExplorer_FilterText}"     Tag="Text"     Click="OnFilterMenuItemClick"/>
                                <MenuItem Header="{DynamicResource SolutionExplorer_FilterImages}"   Tag="Image"    Click="OnFilterMenuItemClick"/>
                                <MenuItem Header="{DynamicResource SolutionExplorer_FilterLanguage}" Tag="Language" Click="OnFilterMenuItemClick"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                       Foreground="{DynamicResource SE_ForegroundBrush}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Search box -->
        <Border Grid.Row="1" Margin="6,4"
                Background="{DynamicResource SE_SearchBoxBrush}"
                BorderBrush="{DynamicResource SE_SeparatorBrush}"
                BorderThickness="1" CornerRadius="2">
            <Grid Margin="6,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox" Grid.Column="0"
                         Background="Transparent" BorderThickness="0"
                         Foreground="{DynamicResource SE_SearchBoxForegroundBrush}"
                         CaretBrush="{DynamicResource SE_SearchBoxForegroundBrush}"
                         VerticalAlignment="Center"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         GotFocus="SearchBox_GotFocus"
                         LostFocus="SearchBox_LostFocus"/>
                <TextBlock x:Name="SearchPlaceholder" Grid.Column="0"
                           Text="{DynamicResource SolutionExplorer_SearchPlaceholder}"
                           Foreground="{DynamicResource SE_SearchBoxForegroundBrush}"
                           Opacity="0.45" IsHitTestVisible="False"
                           VerticalAlignment="Center"/>
                <Button x:Name="SearchModeButton"
                        Grid.Column="1"
                        Style="{StaticResource SE_IconButton}"
                        ToolTip="{Binding SearchModeTooltip}"
                        Click="OnSearchModeButtonClick"
                        Margin="2,0,0,0" Padding="4,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                   Foreground="{DynamicResource SE_ForegroundBrush}"
                                   Opacity="0.7" VerticalAlignment="Center"/>
                        <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="7"
                                   Foreground="{DynamicResource SE_ForegroundBrush}"
                                   Opacity="0.5" VerticalAlignment="Center" Margin="1,2,0,0"/>
                    </StackPanel>
                    <Button.ContextMenu>
                        <ContextMenu x:Name="SearchModeContextMenu">
                            <MenuItem Header="{DynamicResource SolutionExplorer_SearchModeFileName}"    Tag="FileName"       Click="OnSearchModeMenuItemClick"/>
                            <MenuItem Header="{DynamicResource SolutionExplorer_SearchModeNameContent}" Tag="NameAndContent" Click="OnSearchModeMenuItemClick"/>
                            <MenuItem Header="{DynamicResource SolutionExplorer_SearchModeContentOnly}" Tag="ContentOnly"    Click="OnSearchModeMenuItemClick"/>
                            <Separator/>
                            <MenuItem Header="{DynamicResource SolutionExplorer_SearchModeRegex}"       Tag="Regex"          Click="OnSearchModeMenuItemClick"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
            </Grid>
        </Border>

        <!-- Tree -->
        <TreeView x:Name="SolutionTree" Grid.Row="2"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  VirtualizingStackPanel.VirtualizationMode="Standard"
                  ItemsSource="{Binding Roots}"
                  SelectedItemChanged="OnSelectedItemChanged"
                  PreviewMouseDoubleClick="OnItemDoubleClick"
                  PreviewKeyDown="OnTreePreviewKeyDown"
                  ContextMenuOpening="OnContextMenuOpening"
                  AllowDrop="True"
                  PreviewMouseLeftButtonDown="OnTreeMouseLeftButtonDown"
                  MouseMove="OnTreeMouseMove"
                  DragOver="OnTreeDragOver"
                  Drop="OnTreeDrop"
                  Background="{DynamicResource SE_BackgroundBrush}"
                  Foreground="{DynamicResource SE_ForegroundBrush}">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                    <ContentPresenter Content="{Binding}"/>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>

            <TreeView.ContextMenu>
                <ContextMenu>
                    <ContextMenu.Resources>
                        <Style x:Key="MenuIcon" TargetType="TextBlock">
                            <Setter Property="FontFamily"        Value="Segoe MDL2 Assets"/>
                            <Setter Property="FontSize"          Value="13"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </ContextMenu.Resources>

                    <!-- Go to Definition (SourceTypeNodeVm / SourceMemberNodeVm only) -->
                    <MenuItem x:Name="GoToDefinitionMenuItem" Header="{DynamicResource SolutionExplorer_GoToDefinition}" Click="OnGoToDefinition">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8C7;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator x:Name="GoToDefinitionSeparator"/>

                    <!-- Open / Open With (file, physFile-inProject) -->
                    <MenuItem x:Name="OpenMenuItem" Header="{DynamicResource SolutionExplorer_Open}" Click="OnOpen">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8A7;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="OpenWithMenuItem" Header="{DynamicResource SolutionExplorer_OpenWith}">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8C8;"/>
                        </MenuItem.Icon>
                        <!-- Submenu items are populated dynamically in UpdateContextMenu() -->
                        <MenuItem x:Name="OpenWithHexMenuItem"
                                  Header="{DynamicResource SolutionExplorer_OpenWithHexEditor}"
                                  Tag="__hex__"
                                  Click="OnOpenWithSubItem">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE943;"/>
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>
                    <Separator x:Name="OpenSeparator"/>

                    <!-- Add > submenu (solution / project / folder) -->
                    <MenuItem x:Name="AddSubmenuMenuItem" Header="{DynamicResource SolutionExplorer_Add}">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE710;"/>
                        </MenuItem.Icon>

                        <!-- Items: project &amp; folder only -->
                        <MenuItem x:Name="AddNewItemMenuItem" Header="{DynamicResource SolutionExplorer_AddNewItem}" Click="OnAddNewItem">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8A5;"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem x:Name="AddExistingItemMenuItem" Header="{DynamicResource SolutionExplorer_AddExistingItem}" Click="OnAddExistingItem">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8E5;"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator x:Name="AddItemsSeparator"/>

                        <!-- Import: project &amp; solution -->
                        <MenuItem x:Name="ImportFormatMenuItem" Header="{DynamicResource SolutionExplorer_ImportFormat}" Click="OnImportFormatDefinition">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE896;"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem x:Name="ImportSyntaxMenuItem" Header="{DynamicResource SolutionExplorer_ImportSyntax}" Click="OnImportSyntaxDefinition">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE943;"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator x:Name="AddFolderSeparator"/>

                        <!-- Folders: project &amp; folder; NewPhysicalFolder also on solution -->
                        <MenuItem x:Name="NewFolderMenuItem" Header="{DynamicResource SolutionExplorer_NewFolder}" Click="OnNewFolder">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8F4;"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem x:Name="NewPhysicalFolderMenuItem" Header="{DynamicResource SolutionExplorer_NewSolutionFolder}" Click="OnNewPhysicalFolder">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8D5;"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem x:Name="AddFolderFromDiskMenuItem" Header="{DynamicResource SolutionExplorer_AddExistingFolder}" Click="OnAddFolderFromDisk">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8DA;"/>
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>
                    <Separator x:Name="AddSeparator"/>

                    <!-- Include in Project (Show All Files — physical file not yet tracked) -->
                    <MenuItem x:Name="IncludeInProjectMenuItem" Header="{DynamicResource SolutionExplorer_IncludeInProject}" Click="OnIncludeInProject">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE710;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator x:Name="IncludeSeparator"/>

                    <!-- TBL operations -->
                    <MenuItem x:Name="SetDefaultTblMenuItem" Header="{DynamicResource SolutionExplorer_SetDefaultTbl}" Click="OnSetDefaultTbl">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE735;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="ClearDefaultTblMenuItem" Header="{DynamicResource SolutionExplorer_ClearDefaultTbl}" Click="OnClearDefaultTbl">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE734;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="ConvertToTblxMenuItem" Header="{DynamicResource SolutionExplorer_ConvertToTblx}" Click="OnConvertToTblx">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8AB;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="ApplyTblToActiveMenuItem" Header="{DynamicResource SolutionExplorer_ApplyTblToActive}" Click="OnApplyTblToActive">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8C4;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="ApplyTblToAllMenuItem" Header="{DynamicResource SolutionExplorer_ApplyTblToAll}" Click="OnApplyTblToAll">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xEBE8;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator x:Name="TblSeparator"/>

                    <!-- Navigation (all node types) -->
                    <MenuItem x:Name="OpenInExplorerMenuItem" Header="{DynamicResource SolutionExplorer_OpenInExplorer}" Click="OnOpenInExplorer">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xEC50;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CopyPathMenuItem" Header="{DynamicResource SolutionExplorer_CopyPath}" Click="OnCopyPath">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8C8;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator x:Name="NavigationSeparator"/>

                    <!-- Clipboard: Copy / Cut / Paste (file and folder context) -->
                    <MenuItem x:Name="CopyMenuItem" Header="{DynamicResource SolutionExplorer_Copy}" Click="OnMenuCopy" InputGestureText="Ctrl+C">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8C8;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CutMenuItem" Header="{DynamicResource SolutionExplorer_Cut}" Click="OnMenuCut" InputGestureText="Ctrl+X">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8C6;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="PasteMenuItem" Header="{DynamicResource SolutionExplorer_Paste}" Click="OnMenuPaste" InputGestureText="Ctrl+V">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE77F;"/>
                        </MenuItem.Icon>
                    </MenuItem>

                    <!-- Rename / Remove / Exclude -->
                    <MenuItem x:Name="RenameMenuItem" Header="{DynamicResource SolutionExplorer_Rename}" Click="OnRename">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8AC;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="RemoveMenuItem" Header="{DynamicResource SolutionExplorer_RemoveFromProject}" Click="OnRemove">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE74D;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="DeleteMenuItem" Header="{DynamicResource SolutionExplorer_Delete}" Click="OnDeleteFromDisk">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE74D;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="ExcludeFromProjectMenuItem" Header="{DynamicResource SolutionExplorer_ExcludeFromProject}" Click="OnExcludeFromProject">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8F8;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <!-- Import external file into project directory -->
                    <Separator x:Name="ImportExternalSeparator"/>
                    <MenuItem x:Name="ImportExternalFileMenuItem" Header="{DynamicResource SolutionExplorer_ImportIntoProject}" Click="OnImportExternalFile">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8B5;"/>
                        </MenuItem.Icon>
                    </MenuItem>

                    <!-- Changeset (.whchg) actions -->
                    <Separator x:Name="ChangesetSeparator"/>
                    <MenuItem x:Name="WriteChangesetToDiskMenuItem" Header="{DynamicResource SolutionExplorer_ApplyToDisk}" Click="OnWriteChangesetToDisk">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE9F5;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="DiscardChangesetMenuItem" Header="{DynamicResource SolutionExplorer_DiscardChanges}" Click="OnDiscardChangeset">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE711;"/>
                        </MenuItem.Icon>
                    </MenuItem>

                    <!-- Build (VS projects only) -->
                    <Separator x:Name="BuildSeparator"/>
                    <MenuItem x:Name="BuildProjectMenuItem" Header="{DynamicResource SolutionExplorer_Build}" Click="OnBuildProject">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8B1;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="RebuildProjectMenuItem" Header="{DynamicResource SolutionExplorer_Rebuild}" Click="OnRebuildProject">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE72C;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CleanProjectMenuItem" Header="{DynamicResource SolutionExplorer_Clean}" Click="OnCleanProject">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE74D;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator x:Name="SetStartupSeparator"/>
                    <MenuItem x:Name="SetStartupProjectMenuItem" Header="{DynamicResource SolutionExplorer_SetAsStartup}" Click="OnSetStartupProject">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE768;"/>
                        </MenuItem.Icon>
                    </MenuItem>

                    <!-- References container: Add / Remove Unused appear first (no leading separator) -->
                    <MenuItem x:Name="AddReferenceMenuItem"
                              Header="{DynamicResource SolutionExplorer_AddReference}"
                              Visibility="Collapsed"
                              Click="OnAddReference">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE710;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="RemoveUnusedRefsMenuItem"
                              Header="{DynamicResource SolutionExplorer_RemoveUnusedReferences}"
                              Visibility="Collapsed"
                              Click="OnRemoveUnusedReferences">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE74D;"/>
                        </MenuItem.Icon>
                    </MenuItem>

                    <!-- Separator + Manage NuGet (VS projects; also shown below refs items when refs container) -->
                    <Separator x:Name="NuGetSeparator" Visibility="Collapsed"/>
                    <MenuItem x:Name="ManageNuGetMenuItem"
                              Header="{DynamicResource SolutionExplorer_ManageNugetPackages}"
                              Visibility="Collapsed"
                              Click="OnManageNuGetPackages">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE7B8;"/>
                        </MenuItem.Icon>
                    </MenuItem>

                    <!-- Plugin-contributed items are injected here at runtime -->
                    <Separator x:Name="PluginMenuSeparator" Visibility="Collapsed"/>

                    <!-- Properties -->
                    <Separator x:Name="PropertiesSeparator"/>
                    <MenuItem x:Name="PropertiesMenuItem" Header="{DynamicResource SolutionExplorer_Properties}" Click="OnProperties">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE946;"/>
                        </MenuItem.Icon>
                    </MenuItem>

                    <!-- Manage NuGet Packages for Solution (solution node only) -->
                    <Separator x:Name="SolutionNuGetSeparator" Visibility="Collapsed"/>
                    <MenuItem x:Name="ManageSolutionNuGetMenuItem"
                              Header="{DynamicResource SolutionExplorer_ManageNugetPackagesSolution}"
                              Visibility="Collapsed"
                              Click="OnManageSolutionNuGetPackages">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE7B8;"/>
                        </MenuItem.Icon>
                    </MenuItem>

                    <!-- Solution bottom: Save All + Close Solution -->
                    <Separator x:Name="SolutionBottomSeparator"/>
                    <MenuItem x:Name="SaveAllMenuItem" Header="{DynamicResource SolutionExplorer_SaveAll}" Click="OnSaveAll">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE792;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator x:Name="CloseSolutionSeparator"/>
                    <MenuItem x:Name="CloseSolutionMenuItem" Header="{DynamicResource SolutionExplorer_CloseSolution}" Click="OnCloseSolution">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8BB;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </TreeView.ContextMenu>
        </TreeView>
    </Grid>
</UserControl>
