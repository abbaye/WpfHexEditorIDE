<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark Glassmorphism Theme — Cyan/Teal accents, reuses Dark templates -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="DarkGlass/Colors.xaml" />
        <ResourceDictionary Source="Dark/Menu.xaml" />
        <ResourceDictionary Source="Dark/TabControl.xaml" />
        <ResourceDictionary Source="Dark/ContentControls.xaml" />
    </ResourceDictionary.MergedDictionaries>

</ResourceDictionary>
