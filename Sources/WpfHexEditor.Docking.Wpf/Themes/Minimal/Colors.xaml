<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Minimal Theme — Ultra-clean monochrome palette -->

    <!-- Core UI -->
    <Color x:Key="DockBackgroundColor">#FAFAFA</Color>
    <Color x:Key="DockBorderColor">#E0E0E0</Color>
    <Color x:Key="DockTabActiveColor">#000000</Color>
    <Color x:Key="DockTabInactiveColor">#F5F5F5</Color>
    <Color x:Key="DockTabHoverColor">#E8E8E8</Color>
    <Color x:Key="DockTabTextColor">#666666</Color>
    <Color x:Key="DockTabActiveTextColor">#FFFFFF</Color>
    <Color x:Key="DockSplitterColor">#E0E0E0</Color>
    <Color x:Key="DockOverlayColor">#40000000</Color>
    <Color x:Key="DockDocumentHostBorderColor">#000000</Color>

    <!-- Menu / toolbar -->
    <Color x:Key="DockMenuBackgroundColor">#FFFFFF</Color>
    <Color x:Key="DockMenuForegroundColor">#000000</Color>
    <Color x:Key="DockMenuHighlightColor">#F0F0F0</Color>
    <Color x:Key="DockMenuBorderColor">#E0E0E0</Color>
    <Color x:Key="DockToolBarBackgroundColor">#FFFFFF</Color>
    <Color x:Key="DockWindowBackgroundColor">#FAFAFA</Color>

    <!-- HexEditor Colors -->
    <Color x:Key="HexEditor_BackgroundColor">#FAFAFA</Color>
    <Color x:Key="HexEditor_HeaderBackgroundColor">#F0F0F0</Color>
    <Color x:Key="HexEditor_HeaderForegroundColor">#505050</Color>
    <Color x:Key="HexEditor_ColumnSeparatorColor">#E0E0E0</Color>
    <Color x:Key="HexEditor_ForegroundFirstColor">#1F1F1F</Color>
    <Color x:Key="HexEditor_ForegroundSecondColor">#444444</Color>
    <Color x:Key="HexEditor_ForegroundOffSetHeaderColor">#666666</Color>
    <Color x:Key="HexEditor_SelectionFirstColor">#66000000</Color>
    <Color x:Key="HexEditor_SelectionSecondColor">#33000000</Color>
    <Color x:Key="HexEditor_ForegroundContrast">#FFFFFF</Color>
    <Color x:Key="HexEditor_ForegroundHighLightOffSetHeaderColor">#000000</Color>
    <Color x:Key="HexEditor_AsciiForegroundColor">#505050</Color>
    <Color x:Key="HexEditor_StatusBarBackgroundColor">#EEEEEE</Color>
    <Color x:Key="HexEditor_StatusBarForegroundColor">#444444</Color>
    <Color x:Key="HexEditor_ScrollBarBackgroundColor">#EEEEEE</Color>
    <Color x:Key="HexEditor_ScrollBarThumbColor">#C0C0C0</Color>
    <Color x:Key="HexEditor_ByteModifiedColor">#666666</Color>
    <Color x:Key="HexEditor_HighLightColor">#999999</Color>
    <Color x:Key="HexEditor_AutoHighLiteSelectionByteBrush">#CCCCCC</Color>
    <Color x:Key="HexEditor_TblDteColor">#000000</Color>
    <Color x:Key="HexEditor_TblMteColor">#444444</Color>
    <Color x:Key="HexEditor_TblEndBlockColor">#666666</Color>
    <Color x:Key="HexEditor_TblEndLineColor">#888888</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="DockBackgroundBrush" Color="{StaticResource DockBackgroundColor}" />
    <SolidColorBrush x:Key="DockBorderBrush" Color="{StaticResource DockBorderColor}" />
    <SolidColorBrush x:Key="DockTabActiveBrush" Color="{StaticResource DockTabActiveColor}" />
    <SolidColorBrush x:Key="DockTabInactiveBrush" Color="{StaticResource DockTabInactiveColor}" />
    <SolidColorBrush x:Key="DockTabHoverBrush" Color="{StaticResource DockTabHoverColor}" />
    <SolidColorBrush x:Key="DockTabTextBrush" Color="{StaticResource DockTabTextColor}" />
    <SolidColorBrush x:Key="DockTabActiveTextBrush" Color="{StaticResource DockTabActiveTextColor}" />
    <SolidColorBrush x:Key="DockSplitterBrush" Color="{StaticResource DockSplitterColor}" />
    <SolidColorBrush x:Key="DockDocumentHostBorderBrush" Color="{StaticResource DockDocumentHostBorderColor}" />
    <SolidColorBrush x:Key="DockMenuBackgroundBrush" Color="{StaticResource DockMenuBackgroundColor}" />
    <SolidColorBrush x:Key="DockMenuForegroundBrush" Color="{StaticResource DockMenuForegroundColor}" />
    <SolidColorBrush x:Key="DockMenuHighlightBrush" Color="{StaticResource DockMenuHighlightColor}" />
    <SolidColorBrush x:Key="DockMenuBorderBrush" Color="{StaticResource DockMenuBorderColor}" />
    <SolidColorBrush x:Key="DockToolBarBackgroundBrush" Color="{StaticResource DockToolBarBackgroundColor}" />
    <SolidColorBrush x:Key="DockWindowBackgroundBrush" Color="{StaticResource DockWindowBackgroundColor}" />

    <!-- VS-style title bar button -->
    <Style x:Key="DockTitleButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource DockTabTextBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="4,2"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="2"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DockTabHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DockTabActiveBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Window title bar button -->
    <Style x:Key="TitleBarButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="46"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Cursor" Value="Arrow"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DockTabHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DockTabActiveBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Window title bar close button — red hover -->
    <Style x:Key="TitleBarCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="Transparent"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#E81123"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#F1707A"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
