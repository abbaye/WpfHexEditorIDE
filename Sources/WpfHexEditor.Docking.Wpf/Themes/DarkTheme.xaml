<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark Theme for WpfHexEditor.Docking (VS2022 Dark inspired) -->

    <!-- Colors -->
    <Color x:Key="DockBackgroundColor">#252526</Color>
    <Color x:Key="DockBorderColor">#3F3F46</Color>
    <Color x:Key="DockTabActiveColor">#007ACC</Color>
    <Color x:Key="DockTabInactiveColor">#2D2D30</Color>
    <Color x:Key="DockTabHoverColor">#3E3E40</Color>
    <Color x:Key="DockTabTextColor">#D4D4D4</Color>
    <Color x:Key="DockTabActiveTextColor">#FFFFFF</Color>
    <Color x:Key="DockSplitterColor">#3F3F46</Color>
    <Color x:Key="DockOverlayColor">#40007ACC</Color>
    <Color x:Key="DockDocumentHostBorderColor">#007ACC</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="DockBackgroundBrush" Color="{StaticResource DockBackgroundColor}" />
    <SolidColorBrush x:Key="DockBorderBrush" Color="{StaticResource DockBorderColor}" />
    <SolidColorBrush x:Key="DockTabActiveBrush" Color="{StaticResource DockTabActiveColor}" />
    <SolidColorBrush x:Key="DockTabInactiveBrush" Color="{StaticResource DockTabInactiveColor}" />
    <SolidColorBrush x:Key="DockTabHoverBrush" Color="{StaticResource DockTabHoverColor}" />
    <SolidColorBrush x:Key="DockTabTextBrush" Color="{StaticResource DockTabTextColor}" />
    <SolidColorBrush x:Key="DockTabActiveTextBrush" Color="{StaticResource DockTabActiveTextColor}" />
    <SolidColorBrush x:Key="DockSplitterBrush" Color="{StaticResource DockSplitterColor}" />
    <SolidColorBrush x:Key="DockDocumentHostBorderBrush" Color="{StaticResource DockDocumentHostBorderColor}" />

    <!-- Global UI Colors -->
    <Color x:Key="DockMenuBackgroundColor">#2D2D30</Color>
    <Color x:Key="DockMenuForegroundColor">#F1F1F1</Color>
    <Color x:Key="DockMenuHighlightColor">#3E3E40</Color>
    <Color x:Key="DockMenuBorderColor">#333337</Color>
    <Color x:Key="DockToolBarBackgroundColor">#2D2D30</Color>
    <Color x:Key="DockWindowBackgroundColor">#252526</Color>

    <SolidColorBrush x:Key="DockMenuBackgroundBrush" Color="{StaticResource DockMenuBackgroundColor}" />
    <SolidColorBrush x:Key="DockMenuForegroundBrush" Color="{StaticResource DockMenuForegroundColor}" />
    <SolidColorBrush x:Key="DockMenuHighlightBrush" Color="{StaticResource DockMenuHighlightColor}" />
    <SolidColorBrush x:Key="DockMenuBorderBrush" Color="{StaticResource DockMenuBorderColor}" />
    <SolidColorBrush x:Key="DockToolBarBackgroundBrush" Color="{StaticResource DockToolBarBackgroundColor}" />
    <SolidColorBrush x:Key="DockWindowBackgroundBrush" Color="{StaticResource DockWindowBackgroundColor}" />

    <!-- ── Dark menu styles (VS2022-style) ──────────────────────────────── -->

    <!-- Menu bar: dark background + automatically apply style to direct children -->
    <Style x:Key="DockDarkMenuStyle" TargetType="Menu">
        <Setter Property="Background" Value="{StaticResource DockMenuBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource DockMenuForegroundBrush}" />
        <Setter Property="ItemContainerStyle" Value="{DynamicResource DockDarkMenuItemStyle}" />
    </Style>

    <!-- Full dark MenuItem: complete ControlTemplate for all roles.
         ItemContainerStyle self-reference ensures submenu children also get this style. -->
    <Style x:Key="DockDarkMenuItemStyle" TargetType="{x:Type MenuItem}">
        <Setter Property="Foreground" Value="{StaticResource DockMenuForegroundBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <!-- Recursive: submenu children inherit this style automatically -->
        <Setter Property="ItemContainerStyle" Value="{DynamicResource DockDarkMenuItemStyle}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type MenuItem}">
                    <Border x:Name="templateRoot"
                            SnapsToDevicePixels="True"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid x:Name="Grid" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="MenuItemIconGroup" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" SharedSizeGroup="MenuItemIGTGroup" />
                                <ColumnDefinition Width="20" />
                            </Grid.ColumnDefinitions>

                            <!-- Icon (16×16) -->
                            <ContentPresenter x:Name="Icon"
                                              Grid.Column="0"
                                              ContentSource="Icon"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              Width="16" Height="16"
                                              Margin="4,2" />

                            <!-- Checkmark glyph (replaces icon when IsChecked) -->
                            <Border x:Name="GlyphPanel"
                                    Grid.Column="0"
                                    Visibility="Collapsed"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Width="16" Height="16"
                                    Margin="4,2">
                                <Path Data="M1,5 L4,8 L8,1"
                                      Stroke="{StaticResource DockMenuForegroundBrush}"
                                      StrokeThickness="1.5"
                                      Stretch="Uniform" />
                            </Border>

                            <!-- Header text -->
                            <ContentPresenter x:Name="menuHeaderContainer"
                                              Grid.Column="1"
                                              ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                              VerticalAlignment="Center"
                                              Margin="4,4" />

                            <!-- Keyboard shortcut (right-aligned) -->
                            <TextBlock x:Name="menuGestureText"
                                       Grid.Column="2"
                                       VerticalAlignment="Center"
                                       Margin="8,4,0,4"
                                       Text="{TemplateBinding InputGestureText}"
                                       Foreground="{StaticResource DockMenuForegroundBrush}"
                                       Opacity="0.6" />

                            <!-- Right arrow for sub-menu headers -->
                            <Path x:Name="RightArrow"
                                  Grid.Column="3"
                                  Data="M0,0 L4,3.5 L0,7 Z"
                                  Fill="{TemplateBinding Foreground}"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"
                                  Margin="0,0,6,0"
                                  Visibility="Collapsed" />

                            <!-- Dropdown popup (dark background) -->
                            <Popup x:Name="PART_Popup"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="4"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="{DynamicResource {x:Static SystemParameters.MenuPopupAnimationKey}}"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                                <Border Background="{StaticResource DockMenuBackgroundBrush}"
                                        BorderBrush="{StaticResource DockMenuBorderBrush}"
                                        BorderThickness="1"
                                        Padding="0,2"
                                        SnapsToDevicePixels="True"
                                        Grid.IsSharedSizeScope="True">
                                    <ScrollViewer CanContentScroll="True"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"
                                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Icon absent: hide icon slot -->
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="Icon" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <!-- IsChecked: show checkmark glyph -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="GlyphPanel" Property="Visibility" Value="Visible" />
                            <Setter TargetName="Icon" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <!-- TopLevelHeader: header spans full width, popup placement = Bottom -->
                        <Trigger Property="Role" Value="TopLevelHeader">
                            <Setter TargetName="Icon" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="GlyphPanel" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="RightArrow" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="menuGestureText" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="menuHeaderContainer" Property="Grid.Column" Value="0" />
                            <Setter TargetName="menuHeaderContainer" Property="Grid.ColumnSpan" Value="3" />
                            <Setter TargetName="menuHeaderContainer" Property="Margin" Value="8,4" />
                            <Setter TargetName="PART_Popup" Property="Placement" Value="Bottom" />
                        </Trigger>
                        <!-- TopLevelItem: same layout, no popup -->
                        <Trigger Property="Role" Value="TopLevelItem">
                            <Setter TargetName="Icon" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="GlyphPanel" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="RightArrow" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="menuGestureText" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="menuHeaderContainer" Property="Grid.Column" Value="0" />
                            <Setter TargetName="menuHeaderContainer" Property="Grid.ColumnSpan" Value="4" />
                            <Setter TargetName="menuHeaderContainer" Property="Margin" Value="8,4" />
                        </Trigger>
                        <!-- SubmenuHeader: show right arrow, popup opens to the right -->
                        <Trigger Property="Role" Value="SubmenuHeader">
                            <Setter TargetName="RightArrow" Property="Visibility" Value="Visible" />
                            <Setter TargetName="PART_Popup" Property="Placement" Value="Right" />
                        </Trigger>
                        <!-- IsHighlighted: selection highlight -->
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="templateRoot" Property="Background" Value="{StaticResource DockMenuHighlightBrush}" />
                        </Trigger>
                        <!-- IsEnabled=False: dimmed appearance -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="templateRoot" Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Dark separator line for menus -->
    <Style x:Key="DockDarkMenuSeparatorStyle" TargetType="{x:Type Separator}">
        <Setter Property="Background" Value="{StaticResource DockMenuBorderBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Separator}">
                    <Border Height="1"
                            Margin="24,2,4,2"
                            Background="{TemplateBinding Background}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ToolBar style: dark background, white text buttons -->
    <Style x:Key="DockDarkToolBarStyle" TargetType="ToolBar">
        <Setter Property="Background" Value="{StaticResource DockToolBarBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource DockMenuForegroundBrush}" />
    </Style>

    <Style x:Key="DockDarkToolBarButtonStyle" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource DockMenuForegroundBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{StaticResource DockMenuBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6,2" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource DockMenuHighlightBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Content control overrides: ensure readable text in dark-themed docked/floating panels.
         BasedOn preserves the default WPF template (expand arrows, selection highlight, etc.)
         while overriding only the colors. -->
    <Style TargetType="{x:Type TreeView}" BasedOn="{StaticResource {x:Type TreeView}}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource DockMenuForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DockBorderBrush}" />
    </Style>

    <Style TargetType="{x:Type TreeViewItem}" BasedOn="{StaticResource {x:Type TreeViewItem}}">
        <Setter Property="Foreground" Value="{StaticResource DockMenuForegroundBrush}" />
    </Style>

    <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource DockMenuForegroundBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource DockMenuForegroundBrush}" />
        <Setter Property="SelectionBrush" Value="{StaticResource DockTabActiveBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DockBorderBrush}" />
    </Style>

    <Style TargetType="{x:Type CheckBox}" BasedOn="{StaticResource {x:Type CheckBox}}">
        <Setter Property="Foreground" Value="{StaticResource DockMenuForegroundBrush}" />
    </Style>

    <Style TargetType="{x:Type Label}" BasedOn="{StaticResource {x:Type Label}}">
        <Setter Property="Foreground" Value="{StaticResource DockMenuForegroundBrush}" />
    </Style>

    <!-- ═══ VS2026-style tab control and tab item ═══ -->

    <!-- DockTabControl: content area top, tab strip at bottom, no WPF content border -->
    <Style x:Key="DockTabControlStyle" TargetType="{x:Type TabControl}">
        <Setter Property="Background" Value="{DynamicResource DockBackgroundBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabControl}">
                    <Grid KeyboardNavigation.TabNavigation="Local" SnapsToDevicePixels="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ContentPresenter Grid.Row="0"
                                          x:Name="PART_SelectedContentHost"
                                          ContentSource="SelectedContent"
                                          KeyboardNavigation.TabNavigation="Local"
                                          KeyboardNavigation.DirectionalNavigation="Contained" />
                        <Border Grid.Row="1"
                                Background="{DynamicResource DockMenuBackgroundBrush}"
                                BorderBrush="{DynamicResource DockBorderBrush}"
                                BorderThickness="0,1,0,0">
                            <TabPanel Panel.IsItemsHost="True"
                                      Background="Transparent"
                                      Margin="4,2,4,2" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- DockTabItem: rounded top corners, themed active/hover states -->
    <Style x:Key="DockTabItemStyle" TargetType="{x:Type TabItem}">
        <Setter Property="Foreground" Value="{DynamicResource DockTabTextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8,4,8,4" />
        <Setter Property="Margin" Value="0,1,1,0" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabItem}">
                    <Border x:Name="TabBorder"
                            Background="Transparent"
                            CornerRadius="3,3,0,0"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter ContentSource="Header"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="TabBorder" Property="Background"
                                    Value="{DynamicResource DockTabActiveBrush}" />
                            <Setter Property="Foreground"
                                    Value="{DynamicResource DockTabActiveTextBrush}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="False" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="TabBorder" Property="Background"
                                    Value="{DynamicResource DockTabHoverBrush}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
