<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Cyberpunk Theme — Neon Pink/Purple/Cyan, reuses Dark templates -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Cyberpunk/Colors.xaml" />
        <ResourceDictionary Source="Dark/Menu.xaml" />
        <ResourceDictionary Source="Dark/TabControl.xaml" />
        <ResourceDictionary Source="Dark/ContentControls.xaml" />
    </ResourceDictionary.MergedDictionaries>

</ResourceDictionary>
