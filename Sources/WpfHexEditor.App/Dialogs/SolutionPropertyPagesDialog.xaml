    VS-style "Pages de propriétés Solution" dialog.
    Left: collapsible page tree.  Right: active page UserControl.
    Header: Configuration / Platform selectors.  Footer: Accepter / Annuler / Appliquer.
-->
<ec:ThemedDialog x:Class="WpfHexEditor.App.Dialogs.SolutionPropertyPagesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ec="clr-namespace:WpfHexEditor.Editor.Core.Views;assembly=WpfHexEditor.Editor.Core"
        Title="Pages de propriétés Solution"
        Width="780" Height="560"
        MinWidth="600" MinHeight="400"
        ResizeMode="CanResize"
        Background="{DynamicResource DockWindowBackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.App;component/Themes/DialogStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>    <!-- header -->
            <RowDefinition Height="*"/>       <!-- content -->
            <RowDefinition Height="Auto"/>    <!-- footer -->
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Padding="10,6"
                BorderThickness="0,0,0,1"
                Background="{DynamicResource DockMenuBackgroundBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Configuration :" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="CbHeaderConfig" Width="150" Margin="0,0,12,0"/>

                <TextBlock Text="Plateforme :" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="CbHeaderPlatform" Width="150" Margin="0,0,16,0"/>

                <Button x:Name="BtnConfigMgr"
                        Content="Gestionnaire de configurations…"
                        IsEnabled="False"
                        ToolTip="Configuration Manager — Phase 2"/>
            </StackPanel>
        </Border>

        <!-- ── Content: left tree + right page ─────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="140"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: page navigation tree -->
            <Border Grid.Column="0"
                    BorderThickness="0,0,1,0"
                    BorderBrush="{DynamicResource DockBorderBrush}">
                <TreeView x:Name="PageTree"
                          Background="{DynamicResource DockWindowBackgroundBrush}"
                          BorderThickness="0"
                          SelectedItemChanged="OnPageTreeSelectionChanged">

                    <!-- ▼ Propriétés communes -->
                    <TreeViewItem x:Name="TviCommon"
                                  Header="Propriétés communes"
                                  IsExpanded="True"
                                  FontWeight="SemiBold">
                        <TreeViewItem x:Name="TviStartup"
                                      Header="Configurer des projets de démarrage"
                                      FontWeight="Normal"/>
                        <TreeViewItem x:Name="TviBuildDeps"
                                      Header="Dépendances de build de projet"
                                      FontWeight="Normal"/>
                        <TreeViewItem x:Name="TviSourceFiles"
                                      Header="Fichiers sources pour le débogage"
                                      FontWeight="Normal"/>
                    </TreeViewItem>

                    <!-- ▼ Propriétés de configuration -->
                    <TreeViewItem x:Name="TviConfigProps"
                                  Header="Propriétés de configuration"
                                  IsExpanded="True"
                                  FontWeight="SemiBold">
                        <TreeViewItem x:Name="TviConfig"
                                      Header="Configuration"
                                      FontWeight="Normal"/>
                    </TreeViewItem>
                </TreeView>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource DockBorderBrush}"/>

            <!-- Right: active page host -->
            <ContentPresenter x:Name="PageHost"
                              Grid.Column="2"
                              Margin="0"/>
        </Grid>

        <!-- ── Footer ───────────────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Padding="10,6"
                BorderThickness="0,1,0,0"
                Background="{DynamicResource DockMenuBackgroundBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnAccept"  Content="Accepter"  Width="80" Margin="0,0,6,0"
                        IsDefault="True"  Click="OnAccept"/>
                <Button x:Name="BtnCancel"  Content="Annuler"   Width="80" Margin="0,0,6,0"
                        IsCancel="True"   Click="OnCancel"/>
                <Button x:Name="BtnApply"   Content="Appliquer" Width="80"
                        Click="OnApply"/>
            </StackPanel>
        </Border>
    </Grid>
</ec:ThemedDialog>
