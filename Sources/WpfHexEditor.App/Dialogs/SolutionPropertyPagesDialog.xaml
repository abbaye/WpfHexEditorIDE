    VS-style "Pages de propriétés Solution" dialog.
    Left: collapsible page tree.  Right: active page UserControl.
    Header: Configuration / Platform selectors.  Footer: Accepter / Annuler / Appliquer.
-->
<ec:ThemedDialog x:Class="WpfHexEditor.App.Dialogs.SolutionPropertyPagesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ec="clr-namespace:WpfHexEditor.Editor.Core.Views;assembly=WpfHexEditor.Editor.Core"
        xmlns:appSvc="clr-namespace:WpfHexEditor.App.Services"
        {DynamicResource APP_SolutionPropertiesTitle}
        Width="940" Height="640"
        MinWidth="700" MinHeight="480"
        ResizeMode="CanResize"
        Background="{DynamicResource DockWindowBackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <appSvc:AppLocalizedDictionary/>
                <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.App;component/Themes/DialogStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>    <!-- header -->
            <RowDefinition Height="*"/>       <!-- content -->
            <RowDefinition Height="Auto"/>    <!-- footer -->
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Padding="10,6"
                BorderThickness="0,0,0,1"
                Background="{DynamicResource DockMenuBackgroundBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}">
            <StackPanel Orientation="Horizontal">
                <TextBlock {DynamicResource APP_SolutionConfigLabel} VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="CbHeaderConfig" Width="150" Margin="0,0,12,0"/>

                <TextBlock {DynamicResource APP_SolutionPlatformLabel} VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="CbHeaderPlatform" Width="150" Margin="0,0,16,0"/>

                <Button x:Name="BtnConfigMgr"
                        {DynamicResource APP_ConfigurationManager}
                        IsEnabled="False"
                        {DynamicResource APP_ConfigManagerTooltip}/>
            </StackPanel>
        </Border>

        <!-- ── Content: left tree + right page ─────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270" MinWidth="180"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: page navigation tree -->
            <Border Grid.Column="0"
                    BorderThickness="0,0,1,0"
                    BorderBrush="{DynamicResource DockBorderBrush}">
                <TreeView x:Name="PageTree"
                          Background="{DynamicResource DockWindowBackgroundBrush}"
                          BorderThickness="0"
                          SelectedItemChanged="OnPageTreeSelectionChanged">

                    <!-- ▼ Propriétés communes -->
                    <TreeViewItem x:Name="TviCommon"
                                  {DynamicResource APP_CommonProperties}
                                  IsExpanded="True"
                                  FontWeight="SemiBold">
                        <TreeViewItem x:Name="TviStartup"
                                      {DynamicResource APP_StartupProjects}
                                      FontWeight="Normal"/>
                        <TreeViewItem x:Name="TviBuildDeps"
                                      {DynamicResource APP_ProjectBuildDeps}
                                      FontWeight="Normal"/>
                        <TreeViewItem x:Name="TviSourceFiles"
                                      {DynamicResource APP_DebugSourceFiles}
                                      FontWeight="Normal"/>
                    </TreeViewItem>

                    <!-- ▼ Propriétés de configuration -->
                    <TreeViewItem x:Name="TviConfigProps"
                                  {DynamicResource APP_ConfigProperties}
                                  IsExpanded="True"
                                  FontWeight="SemiBold">
                        <TreeViewItem x:Name="TviConfig"
                                      {DynamicResource APP_ConfigCol}
                                      FontWeight="Normal"/>
                    </TreeViewItem>
                </TreeView>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource DockBorderBrush}"/>

            <!-- Right: active page host -->
            <ContentPresenter x:Name="PageHost"
                              Grid.Column="2"
                              Margin="0"/>
        </Grid>

        <!-- ── Footer ───────────────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Padding="10,6"
                BorderThickness="0,1,0,0"
                Background="{DynamicResource DockMenuBackgroundBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnAccept"  {DynamicResource APP_AcceptButton}  Width="80" Margin="0,0,6,0"
                        IsDefault="True"  Click="OnAccept"/>
                <Button x:Name="BtnCancel"  {DynamicResource APP_CancelButton}   Width="80" Margin="0,0,6,0"
                        IsCancel="True"   Click="OnCancel"/>
                <Button x:Name="BtnApply"   {DynamicResource APP_ApplyButton} Width="80"
                        Click="OnApply"/>
            </StackPanel>
        </Border>
    </Grid>
</ec:ThemedDialog>
