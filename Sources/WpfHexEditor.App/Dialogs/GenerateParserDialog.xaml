<Window x:Class="WpfHexEditor.App.Dialogs.GenerateParserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ec="clr-namespace:WpfHexEditor.Editor.CodeEditor.Controls;assembly=WpfHexEditor.Editor.CodeEditor"
        Title="Generate Parser"
        Width="820" Height="580"
        MinWidth="620" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource DockBackgroundBrush}"
        Foreground="{DynamicResource DockMenuForegroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WpfHexEditor.App;component/Styles/DialogStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header: format name -->
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>  <!-- Options row -->
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>     <!-- Preview -->
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>  <!-- Unsupported notice -->
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>  <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                       VerticalAlignment="Center" Margin="0,0,8,0"
                       Foreground="{DynamicResource DockMenuForegroundBrush}" Opacity="0.7"/>
            <TextBlock x:Name="FormatNameText" FontSize="14" FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
        </StackPanel>

        <!-- ── Options ─────────────────────────────────────────────────────── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Language -->
            <TextBlock Grid.Column="0" Text="Language" VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="LanguageCombo" Grid.Column="2"
                      SelectionChanged="OnLanguageChanged"/>

            <!-- Namespace -->
            <TextBlock Grid.Column="4" Text="Namespace" VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="NamespaceBox" Grid.Column="6"
                     TextChanged="OnOptionChanged"/>

            <!-- Class name -->
            <TextBlock Grid.Column="8" Text="Class name" VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="ClassNameBox" Grid.Column="10"
                     TextChanged="OnOptionChanged"/>
        </Grid>

        <!-- ── Preview ─────────────────────────────────────────────────────── -->
        <Border Grid.Row="4"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="1">
            <ec:CodeEditor x:Name="PreviewEditor"
                           IsReadOnly="True"/>
        </Border>

        <!-- ── Unsupported language notice ─────────────────────────────────── -->
        <Border Grid.Row="6"
                x:Name="UnsupportedNotice"
                Visibility="Collapsed"
                Background="{DynamicResource WarningBackgroundBrush}"
                BorderBrush="{DynamicResource WarningBorderBrush}"
                BorderThickness="1" CornerRadius="3" Padding="10,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                           VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{DynamicResource WarningForegroundBrush}"/>
                <TextBlock x:Name="UnsupportedText" VerticalAlignment="Center"
                           Foreground="{DynamicResource WarningForegroundBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- ── Buttons ─────────────────────────────────────────────────────── -->
        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="CopyBtn" Grid.Column="0" Content="Copy"
                    MinWidth="80" Click="OnCopy"/>
            <Button x:Name="SaveBtn" Grid.Column="2" Content="Save to file…"
                    MinWidth="100" Click="OnSaveToFile"/>

            <Button Grid.Column="4" Content="Close" IsCancel="True"
                    MinWidth="80" Click="OnClose"/>
            <Button x:Name="AddToProjectBtn" Grid.Column="6" Content="Add to project"
                    MinWidth="110" Click="OnAddToProject"/>
        </Grid>
    </Grid>
</Window>
