<Window x:Class="WpfHexEditor.App.Dialogs.SaveChangesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Enregistrer les modifications"
        Width="460" SizeToContent="Height"
        MinWidth="360" MinHeight="160"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource DockWindowBackgroundBrush}">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="Margin"     Value="0,2" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding"  Value="16,5" />
            <Setter Property="MinWidth" Value="80" />
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="Background" Value="{DynamicResource DockBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}" />
        </Style>
    </Window.Resources>

    <StackPanel Margin="20,20,20,16">

        <!-- Header -->
        <TextBlock x:Name="HeaderText"
                   FontSize="13" FontWeight="SemiBold"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12" />

        <!-- File list (bordered box) -->
        <Border BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="1" CornerRadius="3"
                Background="{DynamicResource DockBackgroundBrush}"
                Margin="0,0,0,16" Padding="8,6" MinHeight="38">
            <ItemsControl x:Name="FileList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding Title}"
                                  IsChecked="{Binding IsChecked, Mode=TwoWay}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <StackPanel.Resources>
                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                    <Setter Property="Margin" Value="8,0,0,0" />
                </Style>
            </StackPanel.Resources>

            <Button Content="Enregistrer"
                    IsDefault="True"
                    Click="OnSaveClicked">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Background" Value="#6B3FA0" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="BorderBrush" Value="#7B4FB0" />
                        <Setter Property="Margin" Value="8,0,0,0" />
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="Ne pas enregistrer" Click="OnDontSaveClicked" />
            <Button Content="Annuler" IsCancel="True" Click="OnCancelClicked" />

        </StackPanel>
    </StackPanel>
</Window>
