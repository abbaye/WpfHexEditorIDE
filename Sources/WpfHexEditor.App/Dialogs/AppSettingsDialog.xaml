<Window x:Class="WpfHexEditor.App.Dialogs.AppSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="420" SizeToContent="Height"
        MinWidth="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Margin"       Value="0,12,0,4"/>
            <Setter Property="Foreground"   Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="16">
        <!-- Content -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">

            <!-- ── Save Mode ─────────────────────────────────────── -->
            <TextBlock Text="Save mode" Style="{StaticResource SectionHeader}"/>

            <RadioButton x:Name="RadioDirect"
                         Content="Direct — Ctrl+S writes immediately to the physical file"
                         Margin="0,4,0,0" GroupName="SaveMode"/>

            <RadioButton x:Name="RadioTracked"
                         Content="Tracked — Ctrl+S serialises edits to a .whchg companion file"
                         Margin="0,4,0,0" GroupName="SaveMode"/>

            <!-- ── Auto-serialize ─────────────────────────────────── -->
            <TextBlock Text="Auto-serialize (Tracked mode only)" Style="{StaticResource SectionHeader}"/>

            <CheckBox x:Name="CheckAutoSerialize"
                      Content="Periodically save pending edits to .whchg in the background"
                      Margin="0,4,0,0"/>

            <DockPanel Margin="20,6,0,0" IsEnabled="{Binding IsChecked, ElementName=CheckAutoSerialize}">
                <TextBlock Text="Interval (seconds):" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox  x:Name="TxtInterval"
                          Width="60" HorizontalAlignment="Left"
                          VerticalContentAlignment="Center"/>
            </DockPanel>

        </StackPanel>

        <!-- Buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="OK"     Width="80" Margin="0,0,8,0" IsDefault="True" Click="OnOk"/>
            <Button Content="Cancel" Width="80" IsCancel="True"  Click="OnCancel"/>
        </StackPanel>
    </DockPanel>

</Window>
