<UserControl x:Class="WpfHexEditor.App.Debug.Panels.RegistersPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfHexEditor.App.Debug.ViewModels">

    <DockPanel Background="{DynamicResource PanelBackground}">

        <ToolBar DockPanel.Dock="Top" Background="{DynamicResource ToolbarBackground}">
            <Button Command="{Binding RefreshCommand}"
                    ToolTip="Refresh registers (F5)"
                    Style="{DynamicResource ToolbarButtonStyle}">
                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
            </Button>
            <Separator/>
            <ToggleButton IsChecked="{Binding HexDisplay}"
                          ToolTip="Show values as hexadecimal"
                          Style="{DynamicResource ToolbarButtonStyle}">
                <TextBlock Text="0x" FontWeight="SemiBold"/>
            </ToggleButton>
        </ToolBar>

        <ListView ItemsSource="{Binding Registers}"
                  Background="{DynamicResource PanelBackground}"
                  Foreground="{DynamicResource PanelForeground}"
                  FontFamily="Cascadia Code, Consolas, Courier New"
                  FontSize="12"
                  BorderThickness="0"
                  VirtualizingPanel.IsVirtualizing="True">
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Copy _Value"  InputGestureText="Ctrl+C"
                              Command="{Binding PlacementTarget.DataContext.CopyValueCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.SelectedItem,        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <MenuItem Header="Copy _Name"
                              Command="{Binding PlacementTarget.DataContext.CopyNameCommand,  RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.SelectedItem,        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <Separator/>
                    <MenuItem Header="Toggle _Hex/Decimal"
                              Command="{Binding PlacementTarget.DataContext.ToggleHexCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <MenuItem Header="_Refresh" InputGestureText="F5"
                              Command="{Binding PlacementTarget.DataContext.RefreshCommand,   RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Register" Width="120" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="Value"    Width="200">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type vm:RegisterItem}">
                                <TextBlock Text="{Binding Value}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource PanelForeground}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsChanged}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource DB_LocalChangedBrush}"/>
                                                    <Setter Property="FontWeight"  Value="Bold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Type"     Width="80"  DisplayMemberBinding="{Binding Type}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</UserControl>
