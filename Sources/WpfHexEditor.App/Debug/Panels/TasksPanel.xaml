<UserControl x:Class="WpfHexEditor.App.Debug.Panels.TasksPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DockPanel Background="{DynamicResource PanelBackground}">

        <ToolBar DockPanel.Dock="Top" Background="{DynamicResource PanelBackground}">
            <Button Command="{Binding RefreshCommand}"
                    Content="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                    ToolTip="Refresh Tasks (F5)"/>
        </ToolBar>

        <ListView ItemsSource="{Binding Tasks}"
                  Background="{DynamicResource PanelBackground}"
                  Foreground="{DynamicResource PanelForeground}"
                  BorderThickness="0">
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="_Copy Task Info" InputGestureText="Ctrl+C"
                              Command="{Binding PlacementTarget.DataContext.CopyTaskCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.SelectedItem,       RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <Separator/>
                    <MenuItem Header="_Refresh" InputGestureText="F5"
                              Command="{Binding PlacementTarget.DataContext.RefreshCommand,  RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="ID / Name"  Width="200" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="Status"     Width="140" DisplayMemberBinding="{Binding Status}"/>
                    <GridViewColumn Header="Type"       Width="200" DisplayMemberBinding="{Binding Type}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</UserControl>
