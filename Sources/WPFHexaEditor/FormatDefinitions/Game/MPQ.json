{
  "formatName": "Blizzard MPQ Archive",
  "version": "1.0",
  "extensions": [ ".mpq" ],
  "description": "Blizzard MoPaQ archive format",
  "author": "WPFHexaEditor Team",

  "detection": {
    "signature": "4D50511A",
    "offset": 0,
    "required": true
  },

  "variables": {
    "currentOffset": 0
  },

  "blocks": [
    {
      "type": "signature",
      "name": "MPQ Signature",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "MPQ archive magic bytes"
    },
    {
      "type": "field",
      "name": "Header Size",
      "offset": 4,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Size of the archive header"
    },
    {
      "type": "field",
      "name": "Archive Size",
      "offset": 8,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Total archive size"
    },
    {
      "type": "field",
      "name": "Format Version",
      "offset": 12,
      "length": 2,
      "color": "#FFE66D",
      "opacity": 0.3,
      "description": "MPQ format version"
    }
  ]
}
