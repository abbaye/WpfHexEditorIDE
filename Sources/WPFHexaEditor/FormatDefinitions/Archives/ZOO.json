{
  "formatName": "ZOO Archive",
  "version": "1.0",
  "extensions": [ ".zoo" ],
  "description": "ZOO compressed archive format",
  "author": "WPFHexaEditor Team",

  "detection": {
    "signature": "5A4F4F20",
    "offset": 0,
    "required": true
  },

  "variables": {
    "currentOffset": 0
  },

  "blocks": [
    {
      "type": "signature",
      "name": "ZOO Magic",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "ZOO archive header"
    },
    {
      "type": "field",
      "name": "Archive Start",
      "offset": 20,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Offset to first file"
    }
  ]
}
