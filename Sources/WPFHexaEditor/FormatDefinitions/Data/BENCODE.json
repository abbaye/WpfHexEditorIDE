{
  "formatName": "BitTorrent Bencode",
  "version": "1.0",
  "extensions": [ ".torrent" ],
  "description": "BitTorrent bencoding format for .torrent files",
  "author": "WPFHexaEditor Team",

  "detection": {
    "signature": "64",
    "offset": 0,
    "required": true
