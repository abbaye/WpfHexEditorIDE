{
  "formatName": "Windows System Driver",
  "version": "1.0",
  "extensions": [ ".sys" ],
  "description": "Windows device driver file",
  "author": "WPFHexaEditor Team",

  "detection": {
    "signature": "4D5A",
    "offset": 0,
    "required": true
  },

  "variables": {
    "currentOffset": 0
  },

  "blocks": [
    {
      "type": "signature",
      "name": "DOS Signature",
      "offset": 0,
      "length": 2,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "MZ DOS header"
    },
    {
      "type": "field",
      "name": "PE Header Offset",
      "offset": 60,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Offset to PE header"
    }
  ]
}
